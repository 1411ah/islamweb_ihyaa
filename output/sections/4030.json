{
  "node_id": "4030",
  "title": "قسم 4030",
  "idfrom": 4030,
  "idto": 4030,
  "paragraphs": [
    {
      "kind": "text",
      "text": "وَلْيَتَمَضْمَضْ بَعْدَ"
    },
    {
      "kind": "text",
      "text": "الْخِلَالِ"
    },
    {
      "kind": "text",
      "text": "فَفِيهِ أَثَرٌ عَنْ"
    },
    {
      "kind": "text",
      "text": "(أَهْلِ الْبَيْتِ)"
    },
    {
      "kind": "text",
      "text": "عَلَيْهِمُ السَّلَامُ ."
    },
    {
      "kind": "text",
      "text": "وَأَنْ يَلْعَقَ الْقَصْعَةَ وَيَشْرَبَ مَاءَهَا ."
    },
    {
      "kind": "text",
      "text": "وَيُقَالُ مَنْ لَعَقَ الْقَصْعَةَ وَغَسَلَهَا وَشَرِبَ مَاءَهَا كَانَ لَهُ عِتْقُ رَقَبَةٍ ."
    },
    {
      "kind": "text",
      "text": "وَأَنَّ الْتِقَاطَ الْفُتَاتِ مُهُورُ الْحُورِ الْعِينِ"
    }
  ],
  "has_quran": false,
  "has_hadith": false
}