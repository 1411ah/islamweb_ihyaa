    {
      "kind": "text",
      "text": "وَمِنْ ذَلِكَ"
    },
    {
      "kind": "text",
      "text": "الْوَرَعُ عَنْ مَتْرُوكِ التَّسْمِيَةِ"
    },
    {
      "kind": "text",
      "text": "وَإِنْ لَمْ يَخْتَلِفْ فِيهِ قَوْلُ"
    },
    {
      "kind": "text",
      "text": "الشَّافِعِيُّ"
    },
    {
      "kind": "text",
      "text": "رَحِمَهُ اللَّهُ لِأَنَّ الْآيَةَ ظَاهِرَةٌ فِي إِيجَابِهَا ."
    }
