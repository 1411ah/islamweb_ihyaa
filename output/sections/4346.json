    {
      "kind": "heading",
      "text": "الْخَامِسَةُ :"
    },
    {
      "kind": "text",
      "text": "أَنْ تَكُونَ الْمَرْأَةُ وَلُودًا"
    },
    {
      "kind": "text",
      "text": "فَإِنْ عُرِفَتْ بِالْعُقْرِ فَلْيَمْتَنِعْ عَنْ تَزَوُّجِهَا ."
    },
    {
      "kind": "heading",
      "text": "قَالَ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ :"
    },
    {
      "kind": "hadith",
      "text": "(( عَلَيْكُمْ بِالْوَلُودِ الْوَدُودِ . ))"
    },
    {
      "kind": "text",
      "text": "فَإِنْ لَمْ يَكُنْ لَهَا زَوْجٌ ، وَلَمْ يَعْرِفْ حَالَهَا فَيُرَاعِي صِحَّتَهَا وَشَبَابَهَا فَإِنَّهَا تَكُونُ وَلُودًا فِي الْغَالِبِ مَعَ هَذَيْنَ الْوَصْفَيْنِ ."
    },
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    }
  ],
