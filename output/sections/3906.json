{
  "node_id": "3906",
  "title": "فضيلة قيام الليل",
  "idfrom": 3906,
  "idto": 3906,
  "paragraphs": [
    {
      "kind": "text",
      "text": "فَضِيلَةُ قِيَامِ اللَّيْلِ ."
    },
    {
      "kind": "heading",
      "text": "أَمَّا مِنَ الْآيَاتِ فَقَوْلُهُ تَعَالَى :"
    },
    {
      "kind": "text",
      "text": "إِنَّ رَبَّكَ يَعْلَمُ أَنَّكَ تَقُومُ أَدْنَى مِنْ ثُلُثَيِ اللَّيْلِ"
    },
    {
      "kind": "heading",
      "text": "الْآيَةَ وَقَوْلُهُ تَعَالَى :"
    },
    {
      "kind": "text",
      "text": "إِنَّ نَاشِئَةَ اللَّيْلِ هِيَ أَشَدُّ وَطْئًا وَأَقْوَمُ قِيلا"
    },
    {
      "kind": "heading",
      "text": "وَقَوْلُهُ سُبْحَانَهُ وَتَعَالَى :"
    },
    {
      "kind": "text",
      "text": "تَتَجَافَى جُنُوبُهُمْ عَنِ الْمَضَاجِعِ"
    },
    {
      "kind": "heading",
      "text": "وَقَوْلُهُ تَعَالَى :"
    },
    {
      "kind": "text",
      "text": "أَمَّنْ هُوَ قَانِتٌ آنَاءَ اللَّيْلِ"
    },
    {
      "kind": "text",
      "text": "الْآيَةَ وَقَوْلُهُ عَزَّ وَجَلَّ"
    },
    {
      "kind": "text",
      "text": "وَالَّذِينَ يَبِيتُونَ لِرَبِّهِمْ سُجَّدًا وَقِيَامًا"
    },
    {
      "kind": "heading",
      "text": "وَقَوْلَهُ تَعَالَى :"
    },
    {
      "kind": "text",
      "text": "وَاسْتَعِينُوا بِالصَّبْرِ وَالصَّلاةِ"
    },
    {
      "kind": "text",
      "text": "قِيلَ : هِيَ قِيَامُ اللَّيْلِ يُسْتَعَانُ بِالصَّبْرِ عَلَيْهِ عَلَى مُجَاهَدَةِ النَّفْسِ ."
    }
  ],
  "has_quran": false,
  "has_hadith": false,
  "level": 4
}