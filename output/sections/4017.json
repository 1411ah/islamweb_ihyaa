    {
      "kind": "text",
      "text": "وَلَا يُشْرَبُ قَائِمًا وَلَا مُضْطَجِعًا"
    },
    {
      "kind": "hadith",
      "text": "(( فَإِنَّهُ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ نَهَى عَنِالشُّرْبِ قَائِمًا . ))"
    },
    {
      "kind": "hadith",
      "text": "(( وَرُوِيَ أَنَّهُ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ شَرِبَ قَائِمًا ))"
    },
    {
      "kind": "text",
      "text": "وَلَعَلَّهُ كَانَ لِعُذْرٍ ."
    },
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    }
