{
  "node_id": "2829",
  "title": "قسم 2829",
  "idfrom": 2829,
  "idto": 2829,
  "paragraphs": [
    {
      "kind": "text",
      "text": "وَقَدْ ذَهَبَ جَمَاعَةٌ مِنَ التَّابِعِينَ إِلَى أَنَّ"
    },
    {
      "kind": "text",
      "text": "فِي الْمَالِ حُقُوقًا سِوَى الزَّكَاةِ"
    },
    {
      "kind": "text",
      "text": "(كَالنَّخْعِيِّ)"
    },
    {
      "kind": "text",
      "text": "وَالشَّعْبِيِّ"
    },
    {
      "kind": "text",
      "text": "(وَعَطَاءٍ)"
    },
    {
      "kind": "text",
      "text": "وَمُجَاهِدٍ"
    },
    {
      "kind": "text",
      "text": "قَالَ"
    },
    {
      "kind": "text",
      "text": "الشَّعْبِيُّ"
    },
    {
      "kind": "text",
      "text": "بَعْدَ أَنْ قِيلَ لَهُ : هَلْ فِي الْمَالِ حَقٌّ سِوَى الزَّكَاةِ ؟ قَالَ : نَعَمْ ، أَمَا سَمِعَتْ قَوْلَهُ عَزَّ وَجَلَّ"
    },
    {
      "kind": "text",
      "text": "وَآتَى الْمَالَ عَلَى حُبِّهِ ذَوِي الْقُرْبَى"
    },
    {
      "kind": "text",
      "text": "الْآيَةُ"
    }
  ],
  "has_quran": false,
  "has_hadith": false
}