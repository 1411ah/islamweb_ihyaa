{
  "node_id": "3304",
  "title": "قسم 3304",
  "idfrom": 3304,
  "idto": 3304,
  "paragraphs": [
    {
      "kind": "text",
      "text": "السَّادِسُ : إِذَا فَرَغَ مِنْ ذَلِكَ يَنْبَغِي"
    },
    {
      "kind": "text",
      "text": "أَنْ يُصَلِّيَ خَلْفَ الْمَقَامِ رَكْعَتَيْنِ"
    },
    {
      "kind": "heading",
      "text": "يَقْرَأُ فِي الْأُولَى :"
    },
    {
      "kind": "text",
      "text": "قُلْ يَا أَيُّهَا الْكَافِرُونَ"
    },
    {
      "kind": "text",
      "text": "وَفِي الثَّانِيَةِ الْإِخْلَاصَ وَهُمَا رَكَعَتَا الطَّوَافِ ."
    },
    {
      "kind": "text",
      "text": "قَالَ"
    },
    {
      "kind": "text",
      "text": "الزُّهْرِيُّ"
    },
    {
      "kind": "text",
      "text": "مَضَتِ السُّنَّةُ أَنْ يُصَلِّيَ لِكُلِّ سَبْعٍ رَكْعَتَيْنِ"
    }
  ],
  "has_quran": false,
  "has_hadith": false
}