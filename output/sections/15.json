  "paragraphs": [
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    },
    {
      "kind": "text",
      "text": "(تَنْبِيهٌ) : قَدْ عُرِفَ مِمَّا تَقَدَّمَ أَنَّهُ"
    },
    {
      "kind": "text",
      "text": "لَا يُعْرَفُ بِالْغَزَالِيِّ إِلَّا الشَّيْخُ وَعَمُّهُ الْكَبِيرُ،"
    },
    {
      "kind": "heading",
      "text": "وَقَدْ وَجَدْتُ أَنَا رَجُلَيْنِ مِنْ أَهْلِ عَصْرِهِ يُعْرَفَانِ بِذَلِكَ:"
    },
    {
      "kind": "heading",
      "text": "أَحَدُهُمَا:"
    },
    {
      "kind": "asl",
      "text": "(عَبْدُ الْبَاقِي بْنُ مُحَمَّدِ بْنِ عَبْدِ الْوَاحِدِ الْفَقِيهُ أَبُو مَنْصُورٍ الْغَزَالِيُّ،)"
    },
    {
      "kind": "text",
      "text": "تَفَقَّهَ عَلَى"
    },
    {
      "kind": "asl",
      "text": "(الْكِيَا الْهَرَاسِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَرَوَى عَنْهُ"
    },
    {
      "kind": "text",
      "text": "الْحَافِظُ أَبُو طَاهِرٍ السِّلَفِيُّ"
    },
    {
      "kind": "text",
      "text": "تُوُفِّيَ سَنَةَ 513 ."
    },
    {
      "kind": "heading",
      "text": "وَالثَّانِي:"
    },
    {
      "kind": "asl",
      "text": "(عَلِيُّ بْنُ مَعْصُومِ بْنِ أَبِي ذَرٍّ أَبُو الْحَسَنِ الْغَزَالِيُّ)"
    },
    {
      "kind": "text",
      "text": "مِنْ أَهْلِ"
    },
    {
      "kind": "asl",
      "text": "(الْمَغْرِبِ،)"
    },
    {
      "kind": "text",
      "text": "شَافِعِيُّ الْمَذْهَبِ، وُلِدَ سَنَةَ 496، وَتُوُفِّيَ"
    },
    {
      "kind": "asl",
      "text": "(بِأَسْفَرَايِينَ)"
    },
    {
      "kind": "text",
      "text": "سَنَةَ 555 ."
    },
    {
      "kind": "text",
      "text": "ثُمَّ وَجَدْتُ رَجُلًا آخَرَ تَأَخَّرَ زَمَانُهُ، وَهُوَ"
    },
    {
      "kind": "asl",
      "text": "(الْعَلَاءُ عَلِيُّ بْنُ أَحْمَدَ الْغَزَالِيُّ،)"
    },
    {
      "kind": "text",
      "text": "مُؤَلِّفُ مِيزَانِ الِاسْتِقَامَةِ لِأَهْلِ الْقُرَبِ وَالْكَرَامَةِ، تُوُفِّيَ سَنَةَ 721 ."
    }
  ],
  "has_quran": false,
  "has_hadith": false
}