    },
    {
      "kind": "text",
      "text": "الْبَابُ الْأَوَّلُ : فِي"
    },
    {
      "kind": "heading",
      "text": "فَضْلِ الْعِلْمِ :"
    },
    {
      "kind": "text",
      "text": "وَالتَّعْلِيمِ وَالتَّعَلُّمِ ."
    },
    {
      "kind": "text",
      "text": "وَشَوَاهِدُهُ مِنَ النَّقْلِ وَالْعَقْلِ ."
    },
    {
      "kind": "text",
      "text": "فَضِيلَةُ الْعِلْمِ ."
    },
    {
      "kind": "heading",
      "text": "شَوَاهِدُهَا مِنَ الْقُرْآنِ ، قَوْلُهُ عَزَّ وَجَلَّ :"
    },
    {
      "kind": "text",
      "text": "شَهِدَ اللَّهُ أَنَّهُ لا إِلَهَ إِلا هُوَ وَالْمَلائِكَةُ وَأُولُو الْعِلْمِ قَائِمًا بِالْقِسْطِ"
    },
    {
      "kind": "text",
      "text": "فَانْظُرْ كَيْفَ بَدَأَ سُبْحَانَهُ وَتَعَالَى بِنَفْسِهِ وَثَنَّى بِالْمَلَائِكَةِ وَثَلَّثَ بِأَهْلِ الْعِلْمِ وَنَاهِيكَ بِهَذَا شَرَفًا وَفَضْلًا وَجَلَاءً وَنُبْلًا"
    },
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    }
  ],
