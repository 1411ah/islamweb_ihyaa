{
  "node_id": "431",
  "title": "قسم 431",
  "level": 1,
  "idfrom": 431,
  "idto": 431,
  "paragraphs": [
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    },
    {
      "kind": "text",
      "text": "ثُمَّ شَرَعَ فِي الرَّدِّ عَلَيْهِمْ، وَالتَّصْنِيفِ عَلَى خِلَافِهِمْ، وَدَخَلَ"
    },
    {
      "kind": "text",
      "text": "(بَغْدَادَ)"
    },
    {
      "kind": "text",
      "text": "وَأَخَذَ الْحَدِيثَ عَنْ"
    },
    {
      "kind": "text",
      "text": "زَكَرِيَّا بْنِ يَحْيَى السَّاجِيِّ،أَحَدِ أَئِمَّةِ الْحَدِيثِ وَالْفِقْهِ،"
    },
    {
      "kind": "text",
      "text": "وَعَنْ"
    },
    {
      "kind": "text",
      "text": "(أَبِي خَلِيفَةَ الْحُجِّيِّ،)"
    },
    {
      "kind": "text",
      "text": "(وَسَهْلِ بْنِ سَرْحٍ،)"
    },
    {
      "kind": "text",
      "text": "(وَمُحَمَّدِ بْنِ يَعْقُوبَ الْمَقْرِيِّ،)"
    },
    {
      "kind": "text",
      "text": "(وَعَبْدِ الرَّحْمَنِ بْنِ خَلَفٍ الضَّبِّيِّ)"
    },
    {
      "kind": "text",
      "text": "الْبَصْرِيِّينَ، وَرَوَى عَنْهُمْ كَثِيرًا فِي تَفْسِيرِهِ، وَصَنَّفَ بَعْدَ رُجُوعِهِ مِنَ اعْتِزَالِهِ \"الْمُوجَزَ\"، وَهُوَ ثَلَاثُ مُجَلَّدَاتٍ، كِتَابٌ مُفِيدٌ فِي الرَّدِّ عَلَى الْجَهْمِيَّةِ وَالْمُعْتَزِلَةِ وَمَقَالَاتِ الْإِسْلَامِيِّينَ، وَكِتَابَ الْإِبَانَةِ ."
    },
    {
      "kind": "text",
      "text": "وَقَالَ"
    },
    {
      "kind": "heading",
      "text": "الْخَطِيبُ:"
    },
    {
      "kind": "text",
      "text": "هُوَ بَصْرِيٌّ سَكَنَ"
    },
    {
      "kind": "text",
      "text": "(بَغْدَادَ)"
    },
    {
      "kind": "text",
      "text": "إِلَى أَنْ تُوُفِّيَ، وَكَانَ يَجْلِسُ فِي أَيَّامِ الْجُمُعَاتِ فِي حَلْقَةِ"
    },
    {
      "kind": "text",
      "text": "(أَبِي إِسْحَاقَ[4 ]الْمَرْوَزِيِّ)"
    },
    {
      "kind": "text",
      "text": "الْفَقِيهِ فِي جَامِعِ الْمَنْصُورِ، وَمِمَّنْ أَخَذَ عَنْهُ"
    },
    {
      "kind": "text",
      "text": "(أَبُو عَبْدِ اللَّهِ مُحَمَّدُ بْنُ أَحْمَدَ بْنِ مُحَمَّدِ بْنِ يَعْقُوبَ بْنِ مُجَاهِدٍ الطَّائِيُّ،)"
    },
    {
      "kind": "text",
      "text": "(وَأَبُو الْحَسَنِ الْبَاهِلِيُّ،)"
    },
    {
      "kind": "text",
      "text": "(وَبُنْدَارُ بْنُ الْحَسَنِ الصُّوفِيُّ،)"
    },
    {
      "kind": "text",
      "text": "(وَأَبُو الْحَسَنِ عَلِيُّ بْنُ مُحَمَّدِ بْنِ مَهْدِيٍّ الطَّبَرِيُّ،)"
    },
    {
      "kind": "text",
      "text": "وَهَؤُلَاءِ الْأَرْبَعَةُ أَخَصُّ أَصْحَابِهِ،"
    },
    {
      "kind": "text",
      "text": "(فَابْنُ مُجَاهِدٍ)"
    },
    {
      "kind": "text",
      "text": "هُوَ شَيْخُ"
    },
    {
      "kind": "text",
      "text": "(أَبِي بَكْرٍ الْبَاقِلَّانِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَهُوَ مَالِكِيٌّ، كَمَا صَرَّحَ بِهِ"
    },
    {
      "kind": "text",
      "text": "عِيَاضٌ"
    },
    {
      "kind": "text",
      "text": "فِي الْمَدَارِكِ،"
    },
    {
      "kind": "text",
      "text": "(وَالْبَاهِلِيُّ)"
    },
    {
      "kind": "text",
      "text": "شَيْخُ الْأُسْتَاذَيْنِ"
    },
    {
      "kind": "text",
      "text": "أَبِي إِسْحَاقَ الْإِسْفِرَايِينِيِّ،"
    },
    {
      "kind": "text",
      "text": "(وَأَبِي بَكْرِ بْنِ فَوْرَكَ،)"
    },
    {
      "kind": "text",
      "text": "وَشَيْخُ"
    },
    {
      "kind": "text",
      "text": "الْبَاقِلَّانِيِّ"
    },
    {
      "kind": "text",
      "text": "أَيْضًا، إِلَّا أَنَّهُ أَخَصُّ"
    },
    {
      "kind": "text",
      "text": "(بِابْنِ مُجَاهِدٍ،)"
    },
    {
      "kind": "text",
      "text": "وَالْأُسْتَاذَانِ أَخَصُّ"
    },
    {
      "kind": "text",
      "text": "(بِالْبَاهِلِيِّ.)"
    }
  ],
  "has_quran": false,
  "has_hadith": false
}