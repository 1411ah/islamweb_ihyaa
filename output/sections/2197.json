      "kind": "text",
      "text": "الْخَامِسَةُ"
    },
    {
      "kind": "text",
      "text": "رَاتِبَةُ الْعِشَاءِ الْآخِرَةِ"
    },
    {
      "kind": "text",
      "text": "أَرْبَعُ رَكَعَاتٍ بَعْدَ الْفَرِيضَةِ ."
    },
    {
      "kind": "text",
      "text": "قَالَتْ"
    },
    {
      "kind": "text",
      "text": "عَائِشَةُ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهَا : كَانَ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ"
    },
    {
      "kind": "hadith",
      "text": "(( يُصَلِّي بَعْدَ الْعِشَاءِ الْآخِرَةِ أَرْبَعَ رَكَعَاتٍ ثُمَّ يَنَامُ ))"
    },
    {
