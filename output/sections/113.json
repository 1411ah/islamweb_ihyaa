    {
      "kind": "text",
      "text": "وَإِلَى مَا يَتَعَلَّقُ بِأَحْكَامِهِ"
    },
    {
      "kind": "text",
      "text": "كَمَعْرِفَةِ النَّاسِخِ وَالْمَنْسُوخِ"
    },
    {
      "kind": "text",
      "text": "وَالْعَامِّ وَالْخَاصِّ وَالنَّصِّ وَالظَّاهِرِ ."
    },
    {
      "kind": "text",
      "text": "وَكَيْفِيَّةِ اسْتِعْمَالِ الْبَعْضِ مِنْهُ مَعَ الْبَعْضِ وَهُوَ الْعِلْمُ الَّذِي يُسَمَّى أُصُولَ الْفِقْهِ وَيَتَنَاوَلُ السُّنَّةَ أَيْضًا ."
    },
