    },
    {
      "kind": "text",
      "text": "وَمِنْهَا أَنْ لَا يَعِدَ مُسْلِمًا بِوَعْدٍ إِلَّا وَيَفِي بِهِ ، قَالَ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ :"
    },
    {
      "kind": "hadith",
      "text": "(( الْعِدَةُ عَطِيَّةٌ ))"
    },
    {
      "kind": "heading",
      "text": "وَقَالَ :"
    },
    {
      "kind": "hadith",
      "text": "(( الْعِدَةُ دَيْنٌ ))"
    },
    {
      "kind": "heading",
      "text": "وَقَالَ :"
    },
    {
      "kind": "hadith",
      "text": "(( ثَلَاثُ فِي الْمُنَافِقِ إِذَا حَدَّثَ كَذَبَ وَإِذَا وَعَدَ أَخْلَفَ وَإِذَا ائْتُمِنَ خَانَ ))"
    },
    {
      "kind": "heading",
      "text": "وَقَالَ :"
    },
    {
      "kind": "hadith",
      "text": "(( ثَلَاثٌ مَنْ كُنَّ فِيهِ فَهُوَ مُنَافِقٌ وَإِنْ صَامَ وَصَلَّى ))"
    },
    {
      "kind": "text",
      "text": "وَذَكَرَ ذَلِكَ ."
    },
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    }
  ],
  "has_quran": false,
  "has_hadith": true
}