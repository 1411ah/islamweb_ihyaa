    {
      "kind": "text",
      "text": "الْمَرْتَبَةُ الرَّابِعَةُ : أَنْ يَقُومَ"
    },
    {
      "kind": "text",
      "text": "سُدُسَ اللَّيْلِ أَوْ خُمُسَهُ وَأَفْضَلُهُ"
    },
    {
      "kind": "text",
      "text": "أَنْ يَكُونَ فِي النِّصْفِ الْأَخِيرِ وَقَبْلَ السُّدُسِ الْأَخِيرِ مِنْهُ ."
    }
  ],
  "has_quran": false,
  "has_hadith": false
}