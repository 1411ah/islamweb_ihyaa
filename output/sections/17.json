{
  "node_id": "17",
  "title": "قسم 17",
  "level": 1,
  "idfrom": 17,
  "idto": 17,
  "paragraphs": [
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    },
    {
      "kind": "asl",
      "text": "(الْفَصْلُ الرَّابِعَ عَشَرَ: فِي"
    },
    {
      "kind": "text",
      "text": "تَفْصِيلِ مَا سَمِعَ مِنْ هَؤُلَاءِ وَرَوَاهُ عَنْهُمْ)"
    },
    {
      "kind": "text",
      "text": "قَالَ"
    },
    {
      "kind": "text",
      "text": "(السَّمْعَانِيُّ:)"
    },
    {
      "kind": "text",
      "text": "لَمَّا عَادَ إِلَى وَطَنِهِ كَانَتْ خَاتِمَةُ أَمْرِهِ الْإِقْبَالَ عَلَى طَلَبِ الْحَدِيثِ، وَمَجَالِسِ أَهْلِهِ وَقِرَاءَتِهِ، وَنَسْخِهِ، وَاسْتَدْعَى الْحَافِظَ"
    },
    {
      "kind": "text",
      "text": "(أَبَا الْفِتْيَانِ عُمَرَ بْنَ أَبِي الْحَسَنِ الرُّؤَاسِيَّ)"
    },
    {
      "kind": "text",
      "text": "إِلَى"
    },
    {
      "kind": "text",
      "text": "(طُوسَ)"
    },
    {
      "kind": "text",
      "text": "وَأَكْرَمَهُ، وَاغْتَنَمَ أَيَّامَهُ، وَسَمِعَ مِنْهُ الصَّحِيحَيْنِ، وَمَا أَظُنُّ أَنَّهُ حَدَّثَ بِشَيْءٍ، وَإِنْ حَدَّثَ فَيَسِيرٌ؛ لِأَنَّ رِوَايَةَ الْحَدِيثِ مَا انْتَشَرَتْ عَنْهُ ."
    },
    {
      "kind": "text",
      "text": "وَذَكَرَ"
    },
    {
      "kind": "text",
      "text": "الْحَافِظُ ابْنُ عَسَاكِرَ"
    },
    {
      "kind": "text",
      "text": "أَنَّهُ سَمِعَ صَحِيحَ"
    },
    {
      "kind": "text",
      "text": "الْبُخَارِيِّ"
    },
    {
      "kind": "text",
      "text": "(أَبِي إِسْمَاعِيلَ الْحَفْصِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَقَالَ"
    },
    {
      "kind": "text",
      "text": "ابْنُ النَّجَّارِ"
    },
    {
      "kind": "text",
      "text": "فِي تَارِيخِهِ: وَلَمْ يَكُنْ لَهُ إِسْنَادُ وَلَا طَلَبُ شَيْءٍ مِنَ الْحَدِيثِ، وَلَمْ أَرَ لَهُ إِلَّا حَدِيثًا وَاحِدًا ."
    },
    {
      "kind": "text",
      "text": "وَقَوْلُ"
    },
    {
      "kind": "text",
      "text": "ابْنِ النَّجَّارِ"
    },
    {
      "kind": "text",
      "text": "كَأَنَّهُ يُشِيرُ إِلَى أَوَّلِ أَمْرِهِ؛ فَإِنَّ إِقْبَالَهُ كَانَ إِذْ ذَاكَ عَلَى تَحْصِيلِ الْفُنُونِ، وَفِي سِيَاقِ الذَّهَبِيِّ فِي تَرْجَمَتِهِ: ثُمَّ رَجَعَ إِلَى"
    },
    {
      "kind": "text",
      "text": "(بَغْدَادَ،)"
    },
    {
      "kind": "text",
      "text": "وَعَقَدَ بِهَا مَجْلِسَ الْوَعْظِ، وَتَكَلَّمَ عَلَى لِسَانِ أَهْلِ الْحَقِيقَةِ، وَحَدَّثَ بِكِتَابِ الْإِحْيَاءِ ."
    },
    {
      "kind": "text",
      "text": "وَقَالَ"
    },
    {
      "kind": "text",
      "text": "(عَبْدُ الْغَافِرِ:)"
    },
    {
      "kind": "text",
      "text": "وَكَانَتْ خَاتِمَةُ أَمْرِهِ إِقْبَالَهُ عَلَى حَدِيثِ الْمُصْطَفَى -صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ- وَمُجَالَسَةَ أَهْلِهِ، وَمُطَالَعَةَ الصَّحِيحَيْنِ"
    },
    {
      "kind": "text",
      "text": "الْبُخَارِيِّ"
    },
    {
      "kind": "text",
      "text": "وَمُسْلِمٍ،"
    },
    {
      "kind": "text",
      "text": "اللَّذَيْنِ هُمَا حُجَّةُ الْإِسْلَامِ، وَلَوْ عَاشَ لَسَبَقَ الْكُلَّ فِي ذَلِكَ الْفَنِّ بِيَسِيرٍ مِنَ الْأَيَّامِ لِيَسْتَفْرِغَ فِي تَحْصِيلِهِ ."
    },
    {
      "kind": "text",
      "text": "وَلَا شَكَّ أَنَّهُ سَمِعَ الْحَدِيثَ فِي الْأَيَّامِ الْمَاضِيَةِ، وَاشْتَغَلَ فِي آخِرِ عُمُرِهِ بِسَمَاعِهَا، وَلَمْ تَتَّفِقْ لَهُ الرِّوَايَةُ، وَلَا ضَرَرَ، وَفِيمَا خَلَّفَهُ مِنَ الْكُتُبِ الْمُصَنَّفَةِ فِي الْأُصُولِ وَالْفُرُوعِ وَسَائِرِ الْأَنْوَاعِ يَخْلُدُ ذِكْرُهُ، وَتَقَرَّرَ عِنْدَ الْمُطَالِعِينَ الْمُسْتَفِيدِينَ مِنْهَا أَنَّهُ لَمْ يُخْلِفْ مِثْلَهُ بَعْدَهُ ."
    },
    {
      "kind": "text",
      "text": "قَالَ: وَسَمِعْتُ أَنَّهُ سَمِعَ مِنْ سُنَنِ"
    },
    {
      "kind": "text",
      "text": "أَبِي دَاوُدَ السِّجِسْتَانِيِّ"
    },
    {
      "kind": "text",
      "text": "(الْحَاكِمِ أَبِي الْفَتْحِ الْحَاكِمِيِّ الطُّوسِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَمَا عَثَرْتُ عَلَى سَمَاعِهِ، وَسَمِعَ مِنَ الْأَحَادِيثِ الْمُتَفَرِّقَةِ أَيْضًا اتِّفَاقًا مَعَ الْفُقَهَاءِ، فَمَا عَثَرْتُ عَلَيْهِ مِمَّا سَمِعَهُ مِنْ كِتَابِ مَوْلِدِ النَّبِيِّ -صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ- مِنْ تَأْلِيفِ"
    },
    {
      "kind": "text",
      "text": "(أَبِي بَكْرٍ أَحْمَدَ بْنِ عَمْرِو بْنِ أَبِي عَاصِمٍ الشَّيْبَانِيِّ،)"
    },
    {
      "kind": "text",
      "text": "رِوَايَةِ الشَّيْخِ"
    },
    {
      "kind": "text",
      "text": "(أَبِي بَكْرٍ أَحْمَدَ بْنِ مُحَمَّدِ بْنِ الْحَارِثِ الْأَصْبَهَانِيِّ،)"
    },
    {
      "kind": "text",
      "text": "(أَبِي مُحَمَّدٍ عَبْدِ اللَّهِ بْنِ مُحَمَّدِ بْنِ جَعْفَرِ بْنِ حِبَّانَ،)"
    },
    {
      "kind": "text",
      "text": "عَنِ الْمُصَنِّفِ، وَقَدْ سَمِعَهُ"
    },
    {
      "kind": "text",
      "text": "الْغَزَالِيُّ"
    },
    {
      "kind": "text",
      "text": "مِنَ الشَّيْخِ"
    },
    {
      "kind": "text",
      "text": "(أَبِي عَبْدِ اللَّهِ مُحَمَّدِ بْنِ أَحْمَدَ الْحِوَارِيِّ)"
    },
    {
      "kind": "heading",
      "text": "مَعَ ابْنَيْهِ الشَّيْخَيْنِ:"
    },
    {
      "kind": "text",
      "text": "(عَبْدِ الْجَبَّارِ)"
    },
    {
      "kind": "text",
      "text": "(وَعَبْدِ الْحَمِيدِ،)"
    },
    {
      "kind": "text",
      "text": "وَجَمَاعَةٍ مِنَ الْفُقَهَاءِ ."
    },
    {
      "kind": "text",
      "text": "وَمِنَ الرِّوَايَةِ عَنْ حُجَّةِ الْإِسْلَامِ: أَخْبَرَنَا الْمُسْنِدُ"
    },
    {
      "kind": "text",
      "text": "(عُمَرُ بْنُ أَحْمَدَ بْنِ عَقِيلٍ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(عَبْدُ اللَّهِ بْنُ سَالِمِ بْنِ مُحَمَّدٍ،)"
    },
    {
      "kind": "text",
      "text": "(وَأَحْمَدُ بْنُ مُحَمَّدِ بْنِ أَحْمَدَ،)"
    },
    {
      "kind": "text",
      "text": "(وَالْحَسَنُ بْنُ عَلِيِّ بْنِ يَحْيَى)"
    },
    {
      "kind": "text",
      "text": "قَالُوا: أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(الْحَافِظُ شَمْسُ الدِّينِ مُحَمَّدُ بْنُ الْعَلَاءِ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(النُّورُ عَلِيُّ بْنُ يَحْيَى،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(يُوسُفُ بْنُ عَبْدِ اللَّهِ الْأَرْمَيُونِيُّ،)"
    },
    {
      "kind": "text",
      "text": "(وَيُوسُفُ بْنُ زَكَرِيَّا،)"
    },
    {
      "kind": "text",
      "text": "(وَأَحْمَدُ بْنُ مُحَمَّدِ بْنِ أَبِي بَكْرٍ)"
    },
    {
      "kind": "text",
      "text": "قَالُوا: أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(الْحَافِظُ مُحَمَّدُ بْنُ عَبْدِ الرَّحْمَنِ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(مُحَمَّدُ بْنُ عَبْدِ الرَّحِيمِ بْنِ مُحَمَّدٍ الْحَاكِمُ.)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو نَصْرٍ عَبْدُ الْوَهَّابِ بْنُ عَلِيِّ بْنِ عَبْدِ الْكَافِي،)"
    },
    {
      "kind": "text",
      "text": "قَرَأْتُ عَلَى"
    },
    {
      "kind": "text",
      "text": "(أَبِي عَبْدِ اللَّهِ مُحَمَّدِ بْنِ أَحْمَدَ الْحَافِظُ)"
    },
    {
      "kind": "text",
      "text": "فِي سَنَةِ 743 أَخْبَرَنِي الْحَافِظُ"
    },
    {
      "kind": "text",
      "text": "(أَبُو مُحَمَّدٍ الدِّمْيَاطِيُّ،)"
    },
    {
      "kind": "text",
      "text": "(الْحَافِظِ عَبْدِ الْعَظِيمِ بْنِ عَبْدِ الْقَوِيِّ الْمُنْذِرِيِّ،)"
    },
    {
      "kind": "text",
      "text": "أَنْبَأَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو الْمُتَضَوِّرِ فَتْحُ بْنُ خَلَفٍ السَّعْدِيُّ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا الْإِمَامُ"
    },
    {
      "kind": "text",
      "text": "(شِهَابُ الدِّينِ أَبُو الْفَتْحِ مُحَمَّدُ بْنُ مَحْمُودٍ الطُّوسِيُّ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(مُحْيِي الدِّينِ مُحَمَّدُ بْنُ يَحْيَى الْفَقِيهُ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(حُجَّةُ الْإِسْلَامِ أَبُو حَامِدٍ مُحَمَّدُ بْنُ مُحَمَّدٍ الْغَزَالِيُّ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا الشَّيْخُ"
    },
    {
      "kind": "text",
      "text": "(مُحَمَّدُ بْنُ يَحْيَى بْنِ مُحَمَّدٍ السَّجَّاعِيُّ الزَّوْزَنِيُّ)"
    },
    {
      "kind": "text",
      "text": "(بِزَوْزَنَ)"
    },
    {
      "kind": "text",
      "text": "فِي دَارِهِ قِرَاءَةً عَلَيْهِ، حَدَّثَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو الْقَاسِمِ الْحَسَنُ بْنُ مُحَمَّدِ بْنِ حَبِيبٍ الْمُفَسِّرُ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا أَبُو بَكْرٍ مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ مُحَمَّدٍ، حَدَّثَنَا أَبُو الْقَاسِمِ أَحْمَدُ بْنُ عَبْدِ اللَّهِ بْنِ عَامِرٍ الطَّائِيُّ بِالْبَصْرَةِ، حَدَّثَنِي أَبِي فِي سَنَةِ 260، حَدَّثَنِي"
    },
    {
      "kind": "text",
      "text": "(عَلِيُّ بْنُ مُوسَى الرَّضِيُّ)"
    },
    {
      "kind": "text",
      "text": "فِي سَنَةِ 164 حَدَّثَنِي"
    },
    {
      "kind": "text",
      "text": "(أَبِي مُوسَى بْنُ جَعْفَرٍ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنِي"
    },
    {
      "kind": "text",
      "text": "(أَبِي جَعْفَرُ بْنُ مُحَمَّدٍ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنِي"
    },
    {
      "kind": "text",
      "text": "(أَبِي مُحَمَّدُ بْنُ عَلِيٍّ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنِي"
    },
    {
      "kind": "text",
      "text": "(أَبِي عَلِيُّ بْنُ الْحُسَيْنِ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنِي"
    },
    {
      "kind": "text",
      "text": "(أَبِي الْحُسَيْنُ بْنُ عَلِيٍّ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنِي"
    },
    {
      "kind": "text",
      "text": "(أَبِي عَلِيُّ بْنُ أَبِي طَالِبٍ)"
    },
    {
      "kind": "heading",
      "text": "-رَضِيَ اللَّهُ عَنْهُ- قَالَ: قَالَ رَسُولُ اللَّهِ -صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ-:"
    },
    {
      "kind": "hadith",
      "text": "(( يَظْهَرُ قَوْمٌ لَا خَلَاقَ لَهُمْ فِي الدُّنْيَا، شَابُّهُمْ فَاسِقٌ وَشَيْخُهُمْ مَارِقٌ، وَصَبِيُّهُمْ عَارِمٌ، الْآمِرُ بِالْمَعْرُوفِ وَالنَّاهِي عَنِ الْمُنْكَرِ بَيْنَهُمْ مُسْتَضْعَفٌ، وَالْفَاسِقُ وَالْمُنَافِقُ بَيْنَهُمْ مُشْرِفٌ، إِنْ كُنْتَ غَنِيًّا وَقَّرُوكَ، وَإِنْ كُنْتَ فَقِيرًا حَقَّرُوكَ، هَمَّازُونَ لَمَازُّونَ، يَمْشُونَ بِالنَّمِيمَةِ، وَيَدُسُّونَ بِالْخَدِيعَةِ، أُولَئِكَ فَرَاشُ نَارٍ، وَذُبَابُ طَمَعٍ، وَعِنْدَ ذَلِكَ يُوَلِّيهِمُ اللَّهُ أُمَرَاءَ ظَلَمَةً، وَوُزَرَاءَ خَوَنَةً، وَرُفَقَاءَ غَشَمَةً، وَتَوَقَّعْ عِنْدَ ذَلِكَ جَرَادًا شَامِلًا، وَغَلَاءً مُتْلِفًا، وَرُخْصًا مُجْحِفًا، وَيَتَتَابَعُ الْبَلَاءُ، كَمَا يَتَتَابَعُ الْخَرَزُ مِنَ الْخَيْطِ إِذَا انْقَطَعَ\". ))"
    },
    {
      "kind": "text",
      "text": "قَالَ"
    },
    {
      "kind": "text",
      "text": "(ابْنُ السُّبْكِيِّ:)"
    },
    {
      "kind": "text",
      "text": "هَذَا حَدِيثٌ ضَعِيفٌ وَاهٍ، قُلْتُ: ذَكَرَا"
    },
    {
      "kind": "text",
      "text": "ابْنُ النَّجَّارِ"
    },
    {
      "kind": "text",
      "text": "فِي تَارِيخِهِ عَنِ"
    },
    {
      "kind": "text",
      "text": "الدَّارَقُطْنِيِّ"
    },
    {
      "kind": "text",
      "text": "(أَبِي حَاتِمٍ الْبُسْتِيِّ)"
    },
    {
      "kind": "text",
      "text": "فِي كِتَابِهِ، قَالَ"
    },
    {
      "kind": "text",
      "text": "(عَلِيُّ بْنُ مُوسَى الرَّضِيُّ)"
    },
    {
      "kind": "text",
      "text": "يَرْوِي عَنْ أَبِيهِ الْعَجَائِبَ، وَكَانَ يَهِيجُ وَيُخْطِئُ ."
    },
    {
      "kind": "text",
      "text": "وَقَالَ"
    },
    {
      "kind": "text",
      "text": "(الذَّهَبِيُّ)"
    },
    {
      "kind": "heading",
      "text": "فِي الدِّيوَانِ:"
    },
    {
      "kind": "text",
      "text": "(عَلِيُّ بْنُ مُوسَى)"
    },
    {
      "kind": "text",
      "text": "لَهُ عَجَائِبُ عَنْ أَبِيهِ عَنْ جِدِّهِ، وَقَالَ فِي الذَّيْلِ مِثْلَ هَذِهِ الْمَقَالَةِ، عَنِ"
    },
    {
      "kind": "text",
      "text": "(ابْنِ طَاهِرٍ،)"
    },
    {
      "kind": "text",
      "text": "ثُمَّ قَالَ: قُلْتُ: الشَّأْنُ فِي صِحَّةِ الْإِسْنَادِ إِلَيْهِ رَحْمَةُ اللَّهِ عَلَيْهِ ."
    },
    {
      "kind": "text",
      "text": "وَمِنْ مَرْوِيَّاتِ"
    },
    {
      "kind": "text",
      "text": "الْغَزَالِيِّ"
    },
    {
      "kind": "text",
      "text": "مِنْ نُسْخَةِ الْمَوْلِدِ بِالسَّنَدِ إِلَيْهِ، قَالَ: أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو عَبْدِ اللَّهِ الْحِوَارِيُّ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو بَكْرٍ الْأَصْبَهَانِيُّ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو مُحَمَّدِ بْنُ حِبَّانَ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو بَكْرِ بْنُ أَبِي عَاصِمٍ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا"
    },
    {
      "kind": "text",
      "text": "(إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا"
    },
    {
      "kind": "text",
      "text": "(عَبْدُ الْعَزِيزِ بْنُ أَبِي ثَابِتٍ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا"
    },
    {
      "kind": "text",
      "text": "(الزُّبَيْرُ بْنُ مُوسَى،)"
    },
    {
      "kind": "text",
      "text": "(أَبِي الْحُوَيْرِثِ،)"
    },
    {
      "kind": "text",
      "text": "قَالَ سَمِعْتُ"
    },
    {
      "kind": "text",
      "text": "عَبْدَ الْمَلِكِ بْنَ مَرْوَانَ"
    },
    {
      "kind": "text",
      "text": "قَالَ:  \"قِيلَ"
    },
    {
      "kind": "text",
      "text": "(لِغِيَاثِ بْنِ أَشْيَمَ الْكَتَّانِيِّ:)"
    },
    {
      "kind": "text",
      "text": "أَنْتَ أَكْبَرُ أَمْ رَسُولُ اللَّهِ -صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ- قَالَ رَسُولُ اللَّهِ -صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ- أَكْبَرُ مِنِّي، وَأَنَا أَسَنُّ مِنْهُ، وُلِدَ رَسُولُ اللَّهِ -صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ- عَامَ الْفِيلِ\" هَكَذَا نَقَلَهُ"
    },
    {
      "kind": "text",
      "text": "(عَبْدُ الْغَافِرِ.)"
    },
    {
      "kind": "text",
      "text": "قَالَ: وَتَمَامُ الْكِتَابِ فِي جُزْأَيْنِ: مَسْمُوعٌ لَهُ ."
    },
    {
      "kind": "text",
      "text": "وَقَالَ الْحَافِظُ"
    },
    {
      "kind": "text",
      "text": "(عِمَادُ الدِّينِ بْنُ كَثِيرٍ)"
    },
    {
      "kind": "text",
      "text": "فِي طَبَقَاتِهِ: قَرَأْتُ عَلَى شَيْخِنَا"
    },
    {
      "kind": "text",
      "text": "(الْحَافِظِ أَبِي الْحَجَّاجِ الْمُزَنِيِّ،)"
    },
    {
      "kind": "text",
      "text": "قُلْتُ: أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(الشَّمْسُ أَبُو عَبْدِ اللَّهِ مُحَمَّدُ بْنُ عَبْدِ الرَّحِيمِ الْمَقْدِسِيُّ)"
    },
    {
      "kind": "text",
      "text": "قِرَاءَةً عَلَيْهِ، أَنْبَأَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو الْمُظَفَّرِ عَبْدُ الرَّحِيمِ بْنُ السَّمْعَانِيِّ)"
    },
    {
      "kind": "text",
      "text": "إِذْنًا، أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(السَّيِّدُ أَبُو الْقَاسِمِ عَبْدُ اللَّهِ بْنُ مُحَمَّدِ بْنِ الْحُسَيْنِ الْحَسَنِيُّ الْكُوفِيُّ)"
    },
    {
      "kind": "text",
      "text": "قِرَاءَةً عَلَيْهِ، أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو عَلِيٍّ الْفَضْلُ بْنُ مُحَمَّدٍ الْفَارْمَذِيُّ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا الْإِمَامُ"
    },
    {
      "kind": "text",
      "text": "(أَبُو حَامِدٍ أَحْمَدُ بْنُ مُحَمَّدٍ الْغَزَالِيُّ الْفَقِيهُ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو بَكْرٍ مُحَمَّدُ بْنُ أَحْمَدَ الْقَطَّانُ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو سَعِيدٍ إِسْمَاعِيلُ بْنُ مُحَمَّدِ بْنِ عَبْدِ الْعَزِيزِ الْخَلَّالُ الْجُرْجَانِيُّ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو الْعَبَّاسِ مُحَمَّدُ بْنُ الْحَسَنِ بْنِ قُتَيْبَةَ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا"
    },
    {
      "kind": "text",
      "text": "(مُحَمَّدُ بْنُ أَبِي اللَّيْثِ الْعَسْقَلَانِيُّ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا"
    },
    {
      "kind": "text",
      "text": "الْمُعْتَمِرُ بْنُ سُلَيْمَانَ،"
    },
    {
      "kind": "text",
      "text": "عَنْ أَبِيهِ، عَنْ"
    },
    {
      "kind": "text",
      "text": "سُلَيْمَانَ بْنِ مِهْرَانَ،"
    },
    {
      "kind": "text",
      "text": "زَيْدِ بْنِ وَهْبٍ،"
    },
    {
      "kind": "text",
      "text": "ابْنِ مَسْعُودٍ"
    },
    {
      "kind": "text",
      "text": "-رَضِيَ اللَّهُ عَنْهُ- حَدَّثَنَا نَبِيُّ اللَّهِ -صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ- وَهُوَ الصَّادِقُ الْمَصْدُوقُ، هَكَذَا وَقَعَ فِي رِوَايَتِنَا، وَهُوَ"
    },
    {
      "kind": "text",
      "text": "حَدِيثٌ مُتَّفِقٌ عَلَى صِحَّتِهِ ."
    },
    {
      "kind": "text",
      "text": "رَوَاهُ السِّتَّةُ مِنْ طُرُقٍ مُتَعَدِّدَةٍ مِنْ حَدِيثِ"
    },
    {
      "kind": "text",
      "text": "سُلَيْمَانَ بْنِ مِهْرَانَ الْأَعْمَشِ،"
    },
    {
      "kind": "text",
      "text": "زَيْدِ بْنِ وَهْبٍ،"
    },
    {
      "kind": "text",
      "text": "ابْنِ مَسْعُودٍ"
    },
    {
      "kind": "text",
      "text": "قَالَ: حَدَّثَنَا رَسُولُ اللَّهِ -صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ- وَهُوَ الصَّادِقُ الْمَصْدُوقُ"
    },
    {
      "kind": "hadith",
      "text": "(( أَنَّ خَلْقَ أَحَدِكُمْ يُجْمَعُ فِي بَطْنِ أُمِّهِ أَرْبَعِينَ لَيْلَةً ))"
    },
    {
      "kind": "text",
      "text": "ثُمَّ سَاقَ الْحَدِيثَ ."
    },
    {
      "kind": "text",
      "text": "قُلْتُ: وَلِي مُؤَاخَذَتَانِ عَلَى"
    },
    {
      "kind": "text",
      "text": "(الْحَافِظِ ابْنِ كَثِيرٍ:)"
    },
    {
      "kind": "text",
      "text": "الْأُولَى: هَذَا الْحَدِيثُ مِنْ رِوَايَةِ"
    },
    {
      "kind": "text",
      "text": "(أَبِي حَامِدٍ الْغَزَالِيِّ الْكَبِيرِ،)"
    },
    {
      "kind": "text",
      "text": "وَهُوَ عَمُّ"
    },
    {
      "kind": "text",
      "text": "(أَبِي حَامِدٍ)"
    },
    {
      "kind": "text",
      "text": "صَاحِبِ التَّرْجَمَةِ، فَكَيْفَ يُورِدُهُ فِي عِدَادِ مَرْوِيَّاتِ حُجَّةِ الْإِسْلَامِ، وَمِنَ الدَّلِيلِ عَلَى ذَلِكَ أَنَّ هَذَا اسْمُهُ"
    },
    {
      "kind": "text",
      "text": "(أَحْمَدُ،)"
    },
    {
      "kind": "text",
      "text": "وَحُجَّةُ الْإِسْلَامِ اسْمُهُ"
    },
    {
      "kind": "text",
      "text": "(مُحَمَّدٌ.)"
    },
    {
      "kind": "text",
      "text": "وَثَانِيًا: فَإِنَّ"
    },
    {
      "kind": "text",
      "text": "(أَبَا عَلِيٍّ الْفَارْمَذِيَّ)"
    },
    {
      "kind": "text",
      "text": "شَيْخُ حُجَّةِ الْإِسْلَامِ لَا تِلْمِيذُهُ ."
    },
    {
      "kind": "text",
      "text": "وَالثَّانِيَةُ: أَوْرَدَ فِي السَّنَدِ"
    },
    {
      "kind": "text",
      "text": "(مُحَمَّدَ بْنَ أَبِي اللَّيْثِ الْعَسْقَلَانِيَّ،)"
    },
    {
      "kind": "heading",
      "text": "وَهُوَ غَلَطٌ، صَوَابُهُ:"
    },
    {
      "kind": "text",
      "text": "مُحَمَّدُ بْنُ أَبِي السَّرِيِّ."
    },
    {
      "kind": "text",
      "text": "وَالْحَدِيثُ الْمَذْكُورُ خَرَّجَهُ"
    },
    {
      "kind": "text",
      "text": "(الْحَافِظُ ابْنُ حَجَرٍ)"
    },
    {
      "kind": "text",
      "text": "فِي جُزْءٍ مُسْتَقِلٍّ، ثُمَّ قَالَ"
    },
    {
      "kind": "text",
      "text": "(ابْنُ كَثِيرٍ:)"
    },
    {
      "kind": "text",
      "text": "وَبِالْإِسْنَادِ الْمُتَقَدِّمِ إِلَى"
    },
    {
      "kind": "text",
      "text": "الْغَزَالِيِّ"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا"
    },
    {
      "kind": "text",
      "text": "(أَحْمَدُ بْنُ مُحَمَّدِ بْنِ عُمَرَ الْخَفَّافُ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا"
    },
    {
      "kind": "text",
      "text": "أَبُو الْعَبَّاسِ السَّرَّاجُ،"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا"
    },
    {
      "kind": "text",
      "text": "(إِسْحَاقُ بْنُ إِبْرَاهِيمَ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو الْوَلِيدِ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا"
    },
    {
      "kind": "text",
      "text": "أَبُو عَوَانَةَ،"
    },
    {
      "kind": "text",
      "text": "(هِلَالٍ الْوَزَّانِ،)"
    },
    {
      "kind": "text",
      "text": "عَائِشَةَ"
    },
    {
      "kind": "heading",
      "text": "-رَضِيَ اللَّهُ عَنْهَا- قَالَتْ: قَالَ رَسُولُ اللَّهِ -صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ-:"
    },
    {
      "kind": "hadith",
      "text": "(( لَعَنَ اللَّهُ الْيَهُودَ وَالنَّصَارَىَ; اتَّخَذُوا قُبُورَ أَنْبِيَائِهِمْ مَسَاجِدَ ))"
    },
    {
      "kind": "text",
      "text": "الْحَدِيثَ ."
    },
    {
      "kind": "text",
      "text": "قَالَ شَيْخُنَا"
    },
    {
      "kind": "text",
      "text": "(الْمِزِّيُّ:)"
    },
    {
      "kind": "text",
      "text": "كَذَا وَقَعَ فِي سَمَاعِنَا، لَيْسَ بَيْنَ"
    },
    {
      "kind": "text",
      "text": "(أَبِي حَامِدٍ)"
    },
    {
      "kind": "text",
      "text": "وَبَيْنَ"
    },
    {
      "kind": "text",
      "text": "(الْخَفَّافِ)"
    },
    {
      "kind": "text",
      "text": "أَحَدٌ، وَهُوَ خَطَأٌ، قَدْ سَقَطَ مِنْهُ شَيْءٌ ."
    },
    {
      "kind": "text",
      "text": "قُلْتُ: وَهَذَا كَذَلِكَ مِنْ رِوَايَةِ عَمِّ حُجَّةِ الْإِسْلَامِ، وَهُوَ يَرْوِي عَنِ"
    },
    {
      "kind": "text",
      "text": "(الْخَفَّافِ)"
    },
    {
      "kind": "text",
      "text": "بِلَا وَاسِطَةٍ، وَلَمْ يَسْقُطْ مِنَ الْإِسْنَادِ شَيْءٌ، وَإِنَّمَا يَكُونُ ذَلِكَ إِذَا ادَّعَى أَنَّهُ مِنْ رِوَايَةِ حُجَّةِ الْإِسْلَامِ وَلَيْسَ كَذَلِكَ ."
    }
