    {
      "kind": "text",
      "text": "وَأَمَّا"
    },
    {
      "kind": "text",
      "text": "الْبَقَرُ .فَلَا شَيْءَ فِيهَا حَتَّى تَبْلُغَ ثَلَاثِينَ ، فَفِيهَا تَبِيعٌ"
    },
    {
      "kind": "text",
      "text": "وَهُوَ الَّذِي فِي السَّنَةِ الثَّانِيَةِ ."
    },
    {
      "kind": "text",
      "text": "ثَمَّ فِي أَرْبَعِينَ مُسِنَّةٌ وَهِيَ الَّتِي فِي السَّنَةِ الثَّالِثَةِ ."
    },
    {
      "kind": "text",
      "text": "ثُمَّ فِي سِتِّينَ تَبِيعَانِ ."
    },
    {
      "kind": "text",
      "text": "وَاسْتَقَرَّ الْحِسَابُ بَعْدَ ذَلِكَ ؛ فَفِي كُلِّ أَرْبَعِينَ مُسِنَّةٌ ، وَفِي كُلِّ ثَلَاثِينَ تَبِيعٌ ."
    },
    {
      "kind": "break",
      "text": ""
    }
  ],
