      "kind": "break",
      "text": "[SECTION_BREAK]"
    },
    {
      "kind": "text",
      "text": "الثَّانِي : الِاسْتِعَانَةُ"
    },
    {
      "kind": "text",
      "text": "عَلَى تَغْيِيرِ الْمُنْكَرِ"
    },
    {
      "kind": "text",
      "text": "وَرَدِّ الْعَاصِي إِلَى مَنْهَجِ الصَّلَاحِ"
    },
    {
      "kind": "text",
      "text": "كَمَا رُوِيَ أَنَّ"
    },
    {
      "kind": "text",
      "text": "عُمَرَ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُ مَرَّ عَلَى"
    },
    {
      "kind": "text",
      "text": "عُثْمَانَ"
    },
    {
      "kind": "text",
      "text": "، وَقِيلَ : عَلَى"
    },
    {
      "kind": "text",
      "text": "طَلْحَةَ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُ فَسَلَّمَ عَلَيْهِ فَلَمْ يَرُدَّ السَّلَامَ فَذَهَبَ إِلَى"
    },
    {
      "kind": "text",
      "text": "أَبِي بَكْرٍ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُ فَذَكَرَ لَهُ ذَلِكَ فَجَاءَ"
    },
    {
      "kind": "text",
      "text": "أَبُو بَكْرٍ"
    },
    {
      "kind": "text",
      "text": "إِلَيْهِ لِيُصْلِحَ ذَلِكَ وَلَمْ يَكُنْ ذَلِكَ غِيبَةً عِنْدَهُمْ وَكَذَلِكَ لَمَّا بَلَغَ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُ أَنَّ"
    },
    {
      "kind": "text",
      "text": "(أَبَا جَنْدَلٍ)"
    },
    {
      "kind": "text",
      "text": "قَدْ عَاقَرَ الْخَمْرَ"
    },
    {
      "kind": "text",
      "text": "(بِالشَّامِ)"
    },
    {
      "kind": "text",
      "text": "، كَتَبَ إِلَيْهِ : بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ"
    },
    {
      "kind": "text",
      "text": "تَنْزِيلُ الْكِتَابِ مِنَ اللَّهِ الْعَزِيزِ الْعَلِيمِ"
    },
    {
      "kind": "text",
      "text": "غَافِرِ الذَّنْبِ وَقَابِلِ التَّوْبِ شَدِيدِ الْعِقَابِ"
    },
    {
      "kind": "text",
      "text": "، الْآيَةَ ، فَتَابَ وَلَمْ يَرَ ذَلِكَ"
    },
    {
      "kind": "text",
      "text": "عُمَرُ"
    },
    {
      "kind": "text",
      "text": "مِمَّنْ أَبْلَغَهُ غِيبَةً إِذْ كَانَ قَصْدُهُ أَنْ يُنْكِرَ عَلَيْهِ ذَلِكَ ، فَيَنْفَعَهُ نُصْحُهُ مَا لَا يَنْفَعُهُ نُصْحُ غَيْرِهِ ، وَإِنَّمَا إِبَاحَةُ هَذَا بِالْقَصْدِ الصَّحِيحِ ، فَإِنْ لَمْ يَكُنْ ذَلِكَ هُوَ الْمَقْصُودَ كَانَ حَرَامًا ."
    },
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    }
  ],
  "has_quran": false,
  "has_hadith": false
}