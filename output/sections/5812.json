{
  "node_id": "5812",
  "title": "قسم 5812",
  "level": 1,
  "idfrom": 5812,
  "idto": 5812,
  "paragraphs": [
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    },
    {
      "kind": "text",
      "text": "وَدَخَلَ"
    },
    {
      "kind": "text",
      "text": "(مُحَمَّدُ بْنُ وَاسِعٍ)"
    },
    {
      "kind": "text",
      "text": "عَلَى"
    },
    {
      "kind": "text",
      "text": "(بِلَالِ بْنِ أَبِي بُرْدَةَ)"
    },
    {
      "kind": "heading",
      "text": "فَقَالَ لَهُ :"
    },
    {
      "kind": "text",
      "text": "مَا تَقُولُ فِي الْقَدَرِ"
    },
    {
      "kind": "text",
      "text": "فَقَالَ ؟ : جِيرَانُكَ أَهْلُ الْقُبُورِ فَتَفَكَّرْ فِيهِمْ فَإِنَّ فِيهِمْ شُغْلًا عَنِ الْقَدَرِ وَعَنِ"
    },
    {
      "kind": "text",
      "text": "(الشَّافِعِيِّ)"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُ قَالَ حَدَّثَنِي عَمِّي"
    },
    {
      "kind": "text",
      "text": "(مُحَمَّدُ بْنُ عَلِيِّ)"
    },
    {
      "kind": "text",
      "text": "قَالَ : إِنِّي لَحَاضِرٌ مَجْلِسَ أَمِيرِ الْمُؤْمِنِينَ"
    },
    {
      "kind": "text",
      "text": "(أَبِي جَعْفَرٍ الْمَنْصُورِ)"
    },
    {
      "kind": "text",
      "text": "وَفِيهِ"
    },
    {
      "kind": "text",
      "text": "(ابْنُ أَبِي ذُؤَيْبٍ)"
    },
    {
      "kind": "text",
      "text": "وَكَانَ وَالِيَ"
    },
    {
      "kind": "text",
      "text": "(الْمَدِينَةِ)"
    },
    {
      "kind": "text",
      "text": "(الْحَسَنِ بْنِ زَيْدِ)"
    },
    {
      "kind": "text",
      "text": "قَالَ : فَأَتَى"
    },
    {
      "kind": "text",
      "text": "(الْغِفَارِيُّونَ)"
    },
    {
      "kind": "text",
      "text": "فَشَكَوْا إِلَى"
    },
    {
      "kind": "text",
      "text": "(أَبِي جَعْفَرٍ)"
    },
    {
      "kind": "text",
      "text": "شَيْئًا مِنْ أَمْرِ"
    },
    {
      "kind": "text",
      "text": "(الْحَسَنِ بْنِ زَيْدٍ)"
    },
    {
      "kind": "text",
      "text": "فَقَالَ"
    },
    {
      "kind": "text",
      "text": "(الْحَسَنُ :)"
    },
    {
      "kind": "text",
      "text": "يَا أَمِيرَ الْمُؤْمِنِينَ سَلْ عَنْهُمُ"
    },
    {
      "kind": "text",
      "text": "(ابْنَ أَبِي ذُؤَيْبٍ)"
    },
    {
      "kind": "text",
      "text": "قَالَ : فَسَأَلَهُ فَقَالَ مَا تَقُولُ فِيهِمْ يَا"
    },
    {
      "kind": "text",
      "text": "فَقَالَ أَشْهَدُ أَنَّهُمْ أَهْلُ تَحَطُّمٍ فِي أَعْرَاضِ النَّاسِ كَثِيرُو الْأَذَى لَهُمْ ."
    },
    {
      "kind": "text",
      "text": "(أَبُو جَعْفَرٍ)"
    },
    {
      "kind": "text",
      "text": "قَدْ سَمِعْتُمْ فَقَالَ"
    },
    {
      "kind": "text",
      "text": "يَا أَمِيرَ الْمُؤْمِنِينَ سَلْهُ عَنِ"
    },
    {
      "kind": "text",
      "text": "فَقَالَ : يَا"
    },
    {
      "kind": "text",
      "text": "مَا تَقُولُ فِي"
    },
    {
      "kind": "text",
      "text": "(الْحَسَنِ بْنِ زَيْدٍ ؟)"
    },
    {
      "kind": "text",
      "text": "فَقَالَ : أَشْهَدُ عَلَيْهِ أَنَّهُ يَحْكَمُ بِغَيْرِ الْحَقِّ وَيَتَّبِعُ هَوَاهُ ، فَقَالَ : قَدْ سَمِعْتَ يَا"
    },
    {
      "kind": "text",
      "text": "(حَسَنُ)"
    },
    {
      "kind": "text",
      "text": "مَا قَالَ فِيكَ"
    },
    {
      "kind": "text",
      "text": "وَهُوَ الشَّيْخُ الصَّالِحُ ، فَقَالَ : يَا أَمِيرَ الْمُؤْمِنِينَ اسْأَلْهُ عَنْ نَفْسِكَ ."
    },
    {
      "kind": "text",
      "text": "فَقَالَ : مَا تَقُولُ فِيَّ ؟ قَالَ : تَعْفِينِي يَا أَمِيرَ الْمُؤْمِنِينَ ، قَالَ : أَسْأَلُكَ بِاللَّهِ إِلَّا أَخْبَرْتَنِي ."
    },
    {
      "kind": "text",
      "text": "قَالَ : تَسْأَلُنِي بِاللَّهِ كَأَنَّكَ لَا تَعْرِفُ نَفْسَكَ ، قَالَ : وَاللَّهِ لَتُخْبِرَنِّي ، قَالَ : أَشْهَدُ أَنَّكَ أَخَذْتَ هَذَا الْمَالَ مِنْ غَيْرِ حَقِّهِ فَجَعَلْتَهُ فِي غَيْرِ أَهْلِهِ ، وَأَشْهَدُ أَنَّ الظُّلْمَ بِبَابِكَ فَاشٍ ."
    },
    {
      "kind": "heading",
      "text": "قَالَ فَجَاءَ :"
    },
    {
      "kind": "text",
      "text": "مِنْ مَوْضِعِهِ حَتَّى وَضَعَ يَدَهُ فِي قَفَا"
    },
    {
      "kind": "text",
      "text": "(ابْنِ أَبِي ذُؤَيْبٍ)"
    },
    {
      "kind": "text",
      "text": "فَقَبَضَ عَلَيْهِ ، ثُمَّ قَالَ لَهُ : أَمَا وَاللَّهِ لَوْلَا أَنِّي جَالِسٌ هَهُنَا لَأَخَذْتُ"
    },
    {
      "kind": "text",
      "text": "(فَارِسَ)"
    },
    {
      "kind": "text",
      "text": "(وَالرُّومَ)"
    },
    {
      "kind": "text",
      "text": "(وَالدَّيْلَمَ)"
    },
    {
      "kind": "text",
      "text": "وَالتُّرْكَ بِهَذَا الْمَكَانِ مِنْكَ ، قَالَ فَقَالَ"
    },
    {
      "kind": "text",
      "text": "(ابْنُ أَبِي ذُؤَيْبٍ :)"
    },
    {
      "kind": "text",
      "text": "يَا أَمِيرَ الْمُؤْمِنِينَ قَدْ وَلِيَ"
    },
    {
      "kind": "text",
      "text": "أَبُو بَكْرٍ"
    },
    {
      "kind": "text",
      "text": "وَعُمَرُ"
    },
    {
      "kind": "text",
      "text": "فَأَخَذَا الْحَقَّ وَقَسَمَا بِالسَّوِيَّةِ وَأَخَذَا بِأَقْفَاءِ"
    },
    {
      "kind": "text",
      "text": "(وَالرُّومِ)"
    },
    {
      "kind": "text",
      "text": "وَأَصْغَرَا آنَافَهُمْ قَالَ : فَخَلَّى"
    },
    {
      "kind": "text",
      "text": "قَفَاهُ وَخَلَّى سَبِيلَهُ ، وَقَالَ : وَاللَّهِ لَوْلَا أَنِّي أَعْلَمُ أَنَّكَ صَادِقٌ لَقَتَلْتُكَ ، فَقَالَ"
    },
    {
      "kind": "text",
      "text": "وَاللَّهِ يَا أَمِيرَ الْمُؤْمِنِينَ إِنِّي لَأَنْصَحُ لَكَ مِنِ ابْنِكَ"
    },
    {
      "kind": "text",
      "text": "(الْمَهْدِيِّ ،)"
    },
    {
      "kind": "text",
      "text": "قَالَ : فَبَلَغَنَا أَنَّ"
    },
    {
      "kind": "text",
      "text": "لَمَّا انْصَرَفَ مِنْ مَجْلِسِ"
    },
    {
      "kind": "text",
      "text": "(الْمَنْصُورِ)"
    },
    {
      "kind": "text",
      "text": "لَقِيَهُ"
    },
    {
      "kind": "text",
      "text": "سُفْيَانُ الثَّوْرِيُّ"
    },
    {
      "kind": "text",
      "text": "فَقَالَ لَهُ : يَا"
    },
    {
      "kind": "text",
      "text": "(أَبَا الْحَارِثِ)"
    },
    {
      "kind": "text",
      "text": "لَقَدْ سَرَّنِي مَا خَاطَبْتَ بِهِ هَذَا الْجَبَّارَ وَلَكِنْ سَاءَنِي قَوْلُكَ لَهُ ابْنُكَ"
    },
    {
      "kind": "text",
      "text": "(الْمَهْدِيُّ ،)"
    },
    {
      "kind": "text",
      "text": "فَقَالَ : يَغْفِرُ اللَّهُ لَكَ يَا"
    },
    {
      "kind": "text",
      "text": "(أَبَا عَبْدِ اللَّهِ)"
    },
    {
      "kind": "text",
      "text": "كُلُّنَا مَهْدِيٌّ كُلُّنَا كَانَ فِي الْمَهْدِ ."
    },
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    }
  ],
  "has_quran": false,
  "has_hadith": false
}