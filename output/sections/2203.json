    {
      "kind": "text",
      "text": "وَتَرْكُ الْآكَدِ أَبْعَدُ لَا سِيَّمَا"
    },
    {
      "kind": "text",
      "text": "وَالْفَرَائِضُ تُكْمَلُ بِالنَّوَافِلِ"
    },
    {
      "kind": "text",
      "text": "فَمَنْ لَمْ يَسْتَكْثِرْ مِنْهَا يُوشِكُ أَنْ لَا تَسْلَمَ لَهُ فَرِيضَةٌ مِنْ غَيْرِ جَابِرٍ ."
    }
  ],
