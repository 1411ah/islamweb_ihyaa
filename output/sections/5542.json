{
  "node_id": "5542",
  "title": "قسم 5542",
  "idfrom": 5542,
  "idto": 5542,
  "paragraphs": [
    {
      "kind": "text",
      "text": "وَأَوَّلُ الْوَقْتِ رِضْوَانُ اللَّهِ ."
    },
    {
      "kind": "text",
      "text": "تَيَمَّمَ"
    },
    {
      "kind": "text",
      "text": "ابْنُ عُمَرَ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُمَا فَقِيلَ لَهُ : أَتَتَيَمَّمُ وَجُدْرَانُ"
    },
    {
      "kind": "text",
      "text": "(الْمَدِينَةِ)"
    },
    {
      "kind": "text",
      "text": "تَنْظُرُ إِلَيْكَ ? فَقَالَ : أَوَ أَبْقَى إِلَى أَنْ أَدْخُلَهَا ؟ وَمَهْمَا"
    },
    {
      "kind": "text",
      "text": "وَجَدَ الْمَاءَ بَعْدَ الشُّرُوعِ فِي الصَّلَاةِ"
    },
    {
      "kind": "text",
      "text": "لَمْ تَبْطُلْ صَلَاتُهُ وَلَمْ يَلْزَمْهُ الْوُضُوءُ ."
    },
    {
      "kind": "text",
      "text": "وَإِذَا وَجَدَهُ"
    },
    {
      "kind": "text",
      "text": "قَبْلَ الشُّرُوعِ فِي الصَّلَاةِ"
    },
    {
      "kind": "text",
      "text": "لَزِمَهُ الْوُضُوءُ ."
    }
  ],
  "has_quran": false,
  "has_hadith": false
}