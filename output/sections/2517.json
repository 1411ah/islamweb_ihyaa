    {
      "kind": "text",
      "text": "وَفِي مَعْنَى هَذَا كُلُّ أَمْرٍ يُبْتَدَأُ بِهِ مِمَّا لَهُ وَقْعٌ وَلِذَلِكَ وَرَدَ"
    },
    {
      "kind": "text",
      "text": "رَكْعَتَانِ عِنْدَ الْإِحْرَامِ"
    },
    {
      "kind": "text",
      "text": "وَرَكْعَتَانِ عِنْدَ ابْتِدَاءِ السَّفَرِ"
    },
    {
      "kind": "text",
      "text": "وَرَكْعَتَانِ عِنْدَ الرُّجُوعِ مِنَ السَّفَرِ"
    },
    {
      "kind": "text",
      "text": "فِي الْمَسْجِدِ قَبْلَ دُخُولِ الْبَيْتِ فَكُلُّ ذَلِكَ مَأْثُورٌ مِنْ فِعْلِ رَسُولِ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ ."
    },
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    }
