{
  "node_id": "1087",
  "title": "الطرف الثاني في المزال به",
  "idfrom": 1087,
  "idto": 1087,
  "paragraphs": [
    {
      "kind": "text",
      "text": "هَذَا فِي الْمَاءِ الرَّاكِدِ ."
    },
    {
      "kind": "text",
      "text": "وَأَمَّا"
    },
    {
      "kind": "text",
      "text": "الْمَاءُ الْجَارِي إِذَا تَغَيَّرَ بِالنَّجَاسَةِ"
    },
    {
      "kind": "text",
      "text": "فَالْجَرْيَةُ الْمُتَغَيِّرَةُ نَجِسَةٌ دُونَ مَا فَوْقَهَا وَمَا تَحْتَهَا لِأَنَّ جَرِيَّاتِ الْمَاءِ مُتَفَاصِلَاتٌ ."
    }
  ],
  "has_quran": false,
  "has_hadith": false,
  "level": 4
}