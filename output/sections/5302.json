    {
      "kind": "text",
      "text": "وَقَالَ"
    },
    {
      "kind": "text",
      "text": "ابْنُ عَبَّاسٍ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُمَا"
    },
    {
      "kind": "text",
      "text": "عِيَادَةُ الْمَرِيضِ مَرَّةً سُنَّةٌ"
    },
    {
      "kind": "text",
      "text": "فَمَا ازْدَادَتْ فَنَافِلَةٌ وَقَالَ بَعْضُهُمْ : عِيَادَةُ الْمَرِيضِ بَعْدَ ثَلَاثٍ ."
    },
    {
      "kind": "text",
      "text": "وَقَالَ عَلَيْهِ السَّلَامُ أَغِبُّوا فِي الْعِيَادَةِ وَأَرْبِعُوا فِيهَا ."
    },
    {
      "kind": "break",
      "text": ""
    }
  ],
