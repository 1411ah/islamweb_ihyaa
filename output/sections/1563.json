    {
      "kind": "text",
      "text": "وَأَمَّا السُّنَنُ مِنَ الْأَذْكَارِ"
    },
    {
      "kind": "text",
      "text": "فَدُعَاءُ الِاسْتِفْتَاحِ"
    },
    {
      "kind": "text",
      "text": "ثُمَّ التَّعَوُّذُ ثُمَّ"
    },
    {
      "kind": "text",
      "text": "قَوْلُهُ آمِينَ فَإِنَّهُ سُنَّةٌ مُؤَكَّدَةٌ"
    },
    {
      "kind": "text",
      "text": "ثُمَّ قِرَاءَةُ السُّورَةِ ."
    },
    {
      "kind": "break",
      "text": ""
    }
