{
  "node_id": "29",
  "title": "قسم 29",
  "idfrom": 29,
  "idto": 29,
  "paragraphs": [
    {
      "kind": "text",
      "text": "(بَيَانُ مَنِ اخْتَصَرَ كِتَابَ الْإِحْيَاءِ)"
    },
    {
      "kind": "text",
      "text": "أَوَّلُ مَنِ اخْتَصَرَهُ أَخُو الْمُصَنِّفِ، وَهُوَ"
    },
    {
      "kind": "text",
      "text": "(أَبُو الْفُتُوحِ أَحْمَدُ بْنُ مُحَمَّدٍ الْغَزَالِيُّ،)"
    },
    {
      "kind": "text",
      "text": "تُوُفِّيَ"
    },
    {
      "kind": "text",
      "text": "(بِقَزْوِينَ)"
    },
    {
      "kind": "text",
      "text": "سَنَةَ 520 وَسَمَّاهُ \"لُبَابُ الْإِحْيَاءِ\" ثُمَّ اخْتَصَرَهُ"
    },
    {
      "kind": "text",
      "text": "(أَحْمَدُ بْنُ مُوسَى الْمَوْصِلِيُّ)"
    },
    {
      "kind": "text",
      "text": "الْمُتَوَفَّى سَنَةَ 622، ثُمَّ"
    },
    {
      "kind": "text",
      "text": "(مُحَمَّدُ بْنُ سَعِيدٍ الْيَمَنِيُّ،)"
    },
    {
      "kind": "text",
      "text": "(وَيَحْيَى بْنُ أَبِي الْخَيْرِ الْيَمَنِيُّ،)"
    },
    {
      "kind": "text",
      "text": "(وَمُحَمَّدُ بْنُ عُمَرَ بْنِ عُثْمَانَ الْبَلْخِيُّ،)"
    },
    {
      "kind": "text",
      "text": "وَسَمَّاهُ \"عَيْنُ الْعِلْمِ\""
    },
    {
      "kind": "text",
      "text": "(وَعَبْدُ الْوَهَّابِ بْنُ عَلِيٍّ الْخَطِيبُ الْمَرَاغِيُّ،)"
    },
    {
      "kind": "text",
      "text": "وَسَمَّاهُ \"لُبَابُ الْإِحْيَاءِ\" أَلَّفَهُ فِي بَيْتِ الْمَقْدِسِ، وَهُوَ عِنْدِي، وَالشَّمْسُ"
    },
    {
      "kind": "text",
      "text": "(مُحَمَّدُ بْنُ عَلِيِّ بْنِ جَعْفَرٍ الْعَجْلُونِيُّ الْمَشْهُورُ بِالْبِلَالِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَهُوَ شَيْخُ خَانَقَاهْ سَعِيدِ السُّعَدَاءِ"
    },
    {
      "kind": "text",
      "text": "(بِمِصْرَ،)"
    },
    {
      "kind": "text",
      "text": "تُوُفِّيَ سَنَةَ 820، قَالَ"
    },
    {
      "kind": "heading",
      "text": "الْحَافِظُ السَّخَاوِيُّ:"
    },
    {
      "kind": "text",
      "text": "وَهُوَ أَحْسَنُ الْمُخْتَصَرَاتِ،"
    },
    {
      "kind": "text",
      "text": "(وَالْجَلَالُ السُّيُوطِيُّ الْحَافِظُ،)"
    },
    {
      "kind": "text",
      "text": "وَآخَرُونَ ."
    }
  ],
  "has_quran": false,
  "has_hadith": false
}