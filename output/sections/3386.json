{
  "node_id": "3386",
  "title": "قسم 3386",
  "idfrom": 3386,
  "idto": 3386,
  "paragraphs": [
    {
      "kind": "text",
      "text": "وَيُسْتَحَبُّ أَنْ يَضَعَ يَدَهُ عَلَى الرُّمَّانَةِ السُّفْلَى الَّتِي كَانَ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ يَضَعُ يَدَهُ عَلَيْهَا عِنْدَ الْخُطْبَةِ"
    },
    {
      "kind": "text",
      "text": "وَيُسْتَحَبُّ لَهُ أَنْ يَأْتِيَأُحُدًا"
    },
    {
      "kind": "text",
      "text": "يَوْمَ الْخَمِيسِ"
    },
    {
      "kind": "text",
      "text": "وَيَزُورُ قُبُورَ الشُّهَدَاءِ"
    },
    {
      "kind": "text",
      "text": "فَيُصَلِّي الْغَدَاةَ فِي مَسْجِدِ النَّبِيِّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ ثُمَّ يَخْرُجُ وَيَعُودُ إِلَى الْمَسْجِدِ لِصَلَاةِ الظُّهْرِ فَلَا يَفُوتُهُ فَرِيضَةٌ فِي الْجَمَاعَةِ فِي الْمَسْجِدِ ."
    },
    {
      "kind": "text",
      "text": "وَيُسْتَحَبُّ أَنْ يَخْرُجَ كُلَّ يَوْمٍ إِلَى"
    },
    {
      "kind": "text",
      "text": "(الْبَقِيعِ)"
    },
    {
      "kind": "text",
      "text": "بَعْدَ السَّلَامِ عَلَى رَسُولِ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ ، وَيَزُورُ قَبْرَ"
    },
    {
      "kind": "text",
      "text": "عُثْمَانَ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُ وَقَبْرَ"
    },
    {
      "kind": "text",
      "text": "الْحَسَنِ بْنِ عَلِيٍّ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُمَا وَفِيهِ أَيْضًا قَبْرُ"
    },
    {
      "kind": "text",
      "text": "(عَلِيِّ بْنِ الْحُسَيْنِ)"
    },
    {
      "kind": "text",
      "text": "(وَمُحَمَّدِ بْنِ عَلِيٍّ)"
    },
    {
      "kind": "text",
      "text": "(وَجَعْفَرِ بْنِ مُحَمَّدٍ)"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُمْ وَيُصَلِّي فِي مَسْجِدِ"
    },
    {
      "kind": "text",
      "text": "(فَاطِمَةَ)"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهَا وَيَزُورُ قَبْرَ"
    },
    {
      "kind": "text",
      "text": "(إِبْرَاهِيمَ ابْنِ رَسُولِ اللَّهِ)"
    },
    {
      "kind": "text",
      "text": ". صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ وَقَبْرَ"
    },
    {
      "kind": "text",
      "text": "(صَفِيَّةَ)"
    },
    {
      "kind": "text",
      "text": "عَمَّةِ رَسُولِ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ فَذَلِكَ كُلُّهُ"
    },
    {
      "kind": "text",
      "text": "(بِالْبَقِيعِ)"
    }
  ],
  "has_quran": false,
  "has_hadith": false
}