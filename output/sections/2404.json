{
  "node_id": "2404",
  "title": "صلاة الخسوف والكسوف",
  "idfrom": 2404,
  "idto": 2404,
  "paragraphs": [
    {
      "kind": "text",
      "text": "وَالنَّظَرُ فِي كَيْفِيَّتِهَا وَوَقْتِهَا ؛ أَمَّا"
    },
    {
      "kind": "text",
      "text": "الْكَيْفِيَّةُ فَإِذَا كَسَفَتِ الشَّمْسُ"
    },
    {
      "kind": "text",
      "text": "فِي وَقْتٍ الصَّلَاةُ فِيهِ مَكْرُوهَةٌ أَوْ غَيْرُ مَكْرُوهَةٍ نُودِيَ الصَّلَاةَ جَامِعَةً ."
    }
  ],
  "has_quran": false,
  "has_hadith": false,
