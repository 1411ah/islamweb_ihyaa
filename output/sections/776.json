    {
      "kind": "text",
      "text": "الرُّكْنُ الثَّانِي"
    },
    {
      "kind": "text",
      "text": "الْعِلْمُ بِصِفَاتِ اللَّهِ تَعَالَى"
    },
    {
      "kind": "heading",
      "text": "وَمَدَارُهُ عَلَى عَشَرَةِ أُصُولٍ :"
    },
    {
      "kind": "heading",
      "text": "الْأَصْلُ الْأَوَّلُ :"
    },
    {
      "kind": "text",
      "text": "الْعِلْمُ بِأَنَّ صَانِعُ الْعَالَمِ ، قَادِرٌ وَأَنَّهُ تَعَالَى فِي قَوْلِهِ"
    },
    {
      "kind": "text",
      "text": "وَهُوَ عَلَى كُلِّ شَيْءٍ قَدِيرٌ"
    },
    {
      "kind": "text",
      "text": "صَادِقٌ ."
    },
    {
      "kind": "break",
      "text": ""
    }
  ],
