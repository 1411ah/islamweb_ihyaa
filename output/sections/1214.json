  "paragraphs": [
    {
      "kind": "text",
      "text": "(وَمُزْدَلِفَةَ)"
    },
    {
      "kind": "text",
      "text": "وَلِدُخُولِ"
    },
    {
      "kind": "text",
      "text": "(مَكَّةَ)"
    },
    {
      "kind": "text",
      "text": "وَثَلَاثَةُ أَغْسَالٍ أَيَّامُ التَّشْرِيقِ وَلِطَوَافِ الْوَدَاعِ عَلَى قَوْلٍ"
    },
    {
      "kind": "text",
      "text": "وَالْكَافِرُ إِذَا أَسْلَمَ"
    },
    {
      "kind": "text",
      "text": "غَيْرَ جُنُبٍ وَالْمَجْنُونُ إِذَا أَفَاقَ وَلِمَنْ غَسَّلَ مَيِّتًا فَكُلُّ ذَلِكَ مُسْتَحَبٌّ ."
    }
  ],
