    {
      "kind": "text",
      "text": "الْأَصْلُ الرَّابِعُ ."
    },
    {
      "kind": "text",
      "text": "أَنَّ"
    },
    {
      "kind": "text",
      "text": "اللَّهَ تَعَالَى مُتَفَضِّلٌ بِالْخَلْقِ وَالِاخْتِرَاعُ وَمُتَطَوِّلٌ بِتَكْلِيفِ الْعِبَادِ"
    },
    {
      "kind": "text",
      "text": "وَلَمْ يَكُنِ الْخَلْقُ وَالتَّكْلِيفُ وَاجِبًا عَلَيْهِ ."
    },
    {
      "kind": "text",
      "text": "وَقَالَتِ"
    },
    {
      "kind": "text",
      "text": "(الْمُعْتَزِلَةُ)"
    },
    {
      "kind": "text",
      "text": "وَجَبَ عَلَيْهِ ذَلِكَ لِمَا فِيهِ مِنْ مَصْلَحَةٍ ; الْعِبَادِ ."
    },
    {
      "kind": "break",
