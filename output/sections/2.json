      "text": "(لِأَبِي طَالِبٍ الْمَكِّيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَعَلَيْهِمَا مَدَارُ كِتَابِ الشَّيْخِ غَالِبًا، وَمَنَازِلُ السَّائِرِينَ"
    },
    {
      "kind": "text",
      "text": "(لِشَيْخِ الْإِسْلَامِ الْهَرَوِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَعَوَارِفُ الْمَعَارِفِ"
    },
    {
      "kind": "text",
      "text": "(لِلشِّهَابِ السُّهْرَوَرْدِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَالتَّعَرُّفُ"
    },
    {
      "kind": "text",
      "text": "(لِأَبِي نَصْرٍ الْكَلَابَاذِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَتَأْيِيدُ الْحَقِيقَةِ الْعَلِيَّةِ"
    },
    {
      "kind": "text",
      "text": "(لِلْحَافِظِ السُّيُوطِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَمَنَارَاتُ السَّائِرِينَ وَمَقَامَاتُ الطَّائِرِينَ لِلشَّيْخِ"
    },
    {
      "kind": "text",
      "text": "(نَجْمِ الدِّينِ دَايَهْ،)"
    },
    {
      "kind": "text",
      "text": "وَمُفِيدُ الْعُلُومِ"
    },
    {
      "kind": "text",
      "text": "(لِأَبِي بَكْرٍ الْخَوَارِزْمِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَالذَّهَبُ الْإِبْرِيزُ فِي مَنَاقِبِ سَيِّدِي عَبْدِ الْعَزِيزِ تَأْلِيفُ أَفْضَلِ الْمُتَأَخِّرِينَ"
    },
    {
      "kind": "text",
      "text": "(أَحْمَدَ بْنِ مُبَارَكٍ اللَّمَطِيِّ السِّجْلَمَاسِيِّ.)"
    },
    {
      "kind": "text",
      "text": "وَمِنْ كُتُبِ التَّوَارِيخِ: الْوَافِي بِالْوَفِيَّاتِ"
    },
    {
      "kind": "text",
      "text": "(لِلصَّلَاحِ الصَّفَدِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَالطَّبَقَاتُ الْكُبْرَى"
