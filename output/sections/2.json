      "kind": "text",
      "text": "وَالْحَافِظِ"
    },
    {
      "kind": "text",
      "text": "(عِمَادِ الدِّينِ بْنِ كَثِيرٍ الدِّمَشْقِيِّ.)"
    },
    {
      "kind": "text",
      "text": "وَفِي أَسْمَاءِ الرِّجَالِ: الْكَاشِفُ"
    },
    {
      "kind": "text",
      "text": "(لِلْحَافِظِ الذَّهَبِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَالدِّيوَانُ لَهُ، وَالْمُشْتَبَهُ لَهُ، وَالْكُنَى"
    },
    {
      "kind": "text",
      "text": "(لِابْنِ الْمُهَنْدِسِ،)"
    },
    {
      "kind": "text",
      "text": "وَالتَّبْصِيرُ"
    },
    {
      "kind": "text",
      "text": "(لِلْحَافِظِ ابْنِ حَجَرٍ.)"
    },
    {
      "kind": "text",
      "text": "وَأَمَّا مَا نَقَلْتُ مِنْهُ مَسْأَلَةً أَوْ فَائِدَةً أَوْ كَلِمَةً غَرِيبَةً أَوْ نَادِرَةً عَجِيبَةً مِنْ أَجْزَاءٍ وَمَعَاجِمَ وَمَسَانِيدَ، وَمَشْيَخَاتٍ وَرَسَائِلَ، وَأَمَالِي وَمُسْتَخْرَجَاتٍ فَشَيْءٌ لَا أُحْصِيهِ الْآنَ، كَمَا سَتَقِفُ عَلَيْهِ عِنْدَ رَفْعِ السُّتُورِ عَنْ وَجْهِ الْبَيَانِ ."
    },
    {
      "kind": "text",
      "text": "وَلْنَصْرِفْ عِنَانَ الْهِمَّةِ عَنْ ذِكْرِ الْمَآخِذِ إِلَى بَيَانِ الْبَاعِثِ الْأَعْظَمِ عَلَى جَمْعِ هَذَا الشَّرْحِ وَتَرْتِيبِهِ وَتَنْسِيقِهِ عَلَى هَذَا الْمِنْوَالِ، وَتَهْذِيبِهِ بَعْدَ إِشَارَاتٍ صَدَرَتْ مِنْ بَعْضِ الْعُلَمَاءِ، وَتَكَرَّرَ إِلْحَاحُهُمْ عَلَى فِيهِ، فَأَقُولُ:"
    },
    {
      "kind": "heading",
      "text": "اعْلَمْ أَنَّ الْبَاعِثَ لِي عَلَى الْإِقْدَامِ فِي شَرْحِ هَذَا الْكِتَابِ أُمُورٌ ثَلَاثَةٌ:"
    },
    {
      "kind": "heading",
      "text": "الْأَوَّلُ:"
    },
    {
      "kind": "text",
      "text": "الْإِكْثَارُ مِنْ ذِكْرِ الصَّالِحِينَ، وَأُولِي الْخَيْرِ وَالدِّينِ،"
    },
    {
      "kind": "text",
      "text": "وَسِيَاقُ أَطْرَافٍ مِنْ أَحْوَالِهِمْ؛ فَإِنَّ ذَلِكَ مِنْ أَكْبَرِ الْأَسْبَابِ الْبَاعِثَةِ عَلَى مَحَبَّتِهِمْ ."
    },
    {
      "kind": "text",
      "text": "وَهِيَ أَحَدُ أَسْبَابِ الْفَوْزِ؛ لِمَا أَخْبَرَنَا بِهِ شَيْخُنَا الْمُسْنِدُ الْجَلِيلُ"
    },
    {
      "kind": "text",
      "text": "(عُمَرُ بْنُ أَحْمَدَ بْنِ عَقِيلٍ)"
    },
    {
      "kind": "text",
      "text": "فِيمَا شَافَهَنِي فِيهِ، أَخْبَرَنَا الْإِمَامُ الْمُحَدِّثُ"
    },
    {
      "kind": "text",
      "text": "(عَبْدُ اللَّهِ بْنُ سَالِمِ بْنِ مُحَمَّدِ بْنِ عِيسَى،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(الشَّمْسُ مُحَمَّدُ بْنُ الْعَلَاءِ الْحَافِظُ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(النُّورُ عَلِيُّ بْنُ يَحْيَى،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(يُوسُفُ بْنُ عَبْدِ اللَّهِ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(مُحَمَّدُ بْنُ عَبْدِ الرَّحْمَنِ الْحَافِظُ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو الْفَضْلِ أَحْمَدُ بْنُ عَلِيِّ بْنِ مُحَمَّدٍ الْحَافِظُ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(الشِّهَابُ أَحْمَدُ بْنُ خَلِيلٍ الْعَلَائِيُّ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا وَالِدِي، أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو الرَّبِيعِ سُلَيْمَانُ بْنُ حَمْزَةَ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(مُحَمَّدُ بْنُ عَبْدِ الْوَاحِدِ الْحَافِظُ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَحْمَدُ بْنُ مُحَمَّدِ بْنِ نَصْرٍ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(الْحَسَنُ بْنُ أَحْمَدَ الْمُقْرِئُ)"
    },
    {
      "kind": "text",
      "text": "حُضُورًا، أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَحْمَدُ بْنُ عَبْدِ اللَّهِ الْحَافِظُ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو بَكْرِ بْنُ خَلَّادٍ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(الْحَارِثُ بْنُ أَبِي أُسَامَةَ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا"
    },
    {
      "kind": "text",
      "text": "(عَبْدُ اللَّهِ بْنُ بَكْرٍ السَّهْمِيُّ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا"
    },
    {
      "kind": "text",
      "text": "(حُمَيْدٌ،)"
    },
    {
      "kind": "text",
      "text": "أَنَسٍ"
    },
    {
      "kind": "heading",
      "text": "-رَضِيَ اللَّهُ عَنْهُ- قَالَ:"
    },
    {
      "kind": "hadith",
      "text": "(( جَاءَ أَعْرَابِيٌّ إِلَى رَسُولِ اللَّهِ -صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ- فَقَالَ: يَا رَسُولَ اللَّهِ، مَتَى السَّاعَةُ؟ فَقَامَ النَّبِيُّ -صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ- إِلَى الصَّلَاةِ، ثُمَّ صَلَّى، ثُمَّ قَالَ: أَيْنَ السَّائِلُ عَنِ السَّاعَةِ؟ قَالَ الرَّجُلُ: أَنَا، قَالَ: مَا أَعْدَدْتَ لَهَا؟ قَالَ: يَا رَسُولَ اللَّهِ، مَا أَعْدَدْتُ لَهَا كَبِيرَ صَلَاةٍ وَلَا صِيَامٍ، إِلَّا أَنِّي أُحِبُّ اللَّهَ وَرَسُولَهُ، فَقَالَ رَسُولُ اللَّهِ -صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ-: الْمَرْءُ مَعَ مَنْ أَحَبَّ، وَأَنْتَ مَعَ مَنْ أَحْبَبْتَ\" قَالَأَنَسٌ:فَمَا رَأَيْتُ الْمُسْلِمِينَ فَرِحُوا بِشَيْءٍ بَعْدَ الْإِسْلَامِ فَرَحَهُمْ بِهَا. ))"
    },
    {
      "kind": "text",
      "text": "رَوَاهُ"
    },
    {
      "kind": "text",
      "text": "التِّرْمِذِيُّ"
    },
    {
      "kind": "text",
      "text": "مِنْ حَدِيثِ"
    },
    {
      "kind": "text",
      "text": "إِسْمَاعِيلَ بْنِ جَعْفَرٍ،"
    },
    {
      "kind": "text",
      "text": "(حُمَيْدٍ)"
    },
    {
      "kind": "text",
      "text": "بِهِ ."
    },
    {
      "kind": "text",
      "text": "وَقَدْ رَوَى عَنْ"
    },
    {
      "kind": "text",
      "text": "أَنَسٍ"
    },
    {
      "kind": "text",
      "text": "هَذَا الْحَدِيثَ خَلْقٌ كَثِيرٌ، غَيْرُ"
    },
    {
      "kind": "text",
      "text": "(حُمَيْدٍ،)"
    },
    {
      "kind": "text",
      "text": "مِنْهُمُ"
    },
    {
      "kind": "text",
      "text": "الزُّهْرِيُّ،"
    },
    {
      "kind": "text",
      "text": "(وَسَالِمُ بْنُ أَبِي الْجَعْدِ،)"
    },
    {
      "kind": "text",
      "text": "فَالْبُخَارِيُّ"
    },
    {
      "kind": "text",
      "text": "رَوَاهُ مِنْ طَرِيقِ"
    },
    {
      "kind": "text",
      "text": "(سَالِمٍ،)"
    },
    {
      "kind": "text",
      "text": "وَمُسْلِمٌ"
    },
    {
      "kind": "text",
      "text": "مِنْ طَرِيقِ"
    },
    {
      "kind": "text",
      "text": "مَعْمَرٍ"
    },
    {
      "kind": "text",
      "text": "(وَسُفْيَانَ،)"
    },
    {
      "kind": "text",
      "text": "كِلَاهُمَا عَنِ"
    },
    {
      "kind": "text",
      "text": "الزُّهْرِيِّ."
    },
    {
      "kind": "text",
      "text": "وَقَدْ رُوِيَ أَيْضًا عَنْ"
    },
    {
      "kind": "text",
      "text": "أَبِي مُوسَى الْأَشْعَرِيِّ،"
    },
    {
      "kind": "text",
      "text": "(وَأَبِي ذَرٍّ الْغِفَارِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَأَبِي مَسْعُودٍ الْبَدْرِيِّ"
    },
    {
      "kind": "text",
      "text": "-رَضِيَ اللَّهُ عَنْهُمْ- وَالْحَدِيثُ مَشْهُورٌ جِدًّا أَوْ مُتَوَاتِرٌ، عَنِ النَّبِيِّ -صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ- لِكَثْرَةِ طُرُقِهِ، وَلَيْسَ هَذَا مَوْضِعَ سِيَاقِهَا ."
    },
    {
      "kind": "text",
      "text": "الثَّانِي مِنَ الْبَوَاعِثِ عَلَى جَمْعِ هَذَا الشَّرْحِ: رَجَاءُ الِانْتِفَاعِ بِهِ لِمَنْ يَنْظُرُ فِيهِ مِنَ الْأُمَّةِ، وَذَلِكَ مِنَ الْأَعْمَالِ الصَّالِحَةِ، وَالْأُمُورِ الْمُهِمَّةِ، وَقَدْ وَعَدَ النَّبِيُّ -صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ- فَاعِلَهُ بِمُسَاهَمَةِ الْمُهْتَدِي بِهِ مِنَ الثَّوَابِ، وَنَاهِيكَ بِذَلِكَ مِنْ عَمَلٍ يَتَجَدَّدُ لِلْمَرْءِ بَعْدَ مَوْتِهِ مَدَى الْأَحْقَابِ ."
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(عَبْدُ الْخَالِقِ بْنُ أَبِي بَكْرِ بْنِ الْمُزَيَّنِ،)"
    },
    {
      "kind": "text",
      "text": "(وَمُحَمَّدُ بْنُ عَلَاءِ الدِّينِ بْنِ عَبْدِ الْبَاقِي،)"
    },
    {
      "kind": "text",
      "text": "(وَإِسْمَاعِيلُ بْنُ عَبْدِ اللَّهِ بْنِ عَلِيٍّ،)"
    },
    {
      "kind": "text",
      "text": "الْحَنَفِيُّونَ،"
    },
    {
      "kind": "text",
      "text": "(وَمُحَمَّدُ بْنُ الطَّيِّبِ بْنِ مُحَمَّدٍ،)"
    },
    {
      "kind": "text",
      "text": "وَآخَرُونَ، سَمَاعًا عَلَيْهِمْ، قَالُوا: أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو طَاهِرٍ مُحَمَّدُ بْنُ إِبْرَاهِيمَ بْنِ حَسَنٍ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا وَالِدِي، أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(الْقُطْبُ أَحْمَدُ بْنُ عَبْدِ النَّبِيِّ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو الْمَوَاهِبِ أَحْمَدُ بْنُ عَلِيِّ بْنِ عَبْدِ الْقُدُّوسِ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا وَالِدِي، أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(الْقَصَّابُ عَبْدُ الْوَهَّابِ بْنُ أَحْمَدَ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(زَكَرِيَّا بْنُ مُحَمَّدٍ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو الْفَضْلِ أَحْمَدُ بْنُ عَلِيٍّ الْحَافِظُ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو الْخَيْرِ بْنُ أَبِي سَعِيدٍ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا أَبِي، أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو بَكْرِ بْنُ أَحْمَدَ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(مُحَمَّدٌ الْأَرْبَلِيُّ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَتْنَا"
    },
    {
      "kind": "text",
      "text": "(شَهْدَةُ الْكَاتِبَةُ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَحْمَدُ بْنُ بُنْدَارٍ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(مُحَمَّدُ بْنُ بُكَيْرٍ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو مُحَمَّدِ بْنُ بُكَيْرٍ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو مُحَمَّدٍ بْنُ مَاسِي،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(يُوسُفُ الْقَاضِي،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا"
    },
    {
      "kind": "text",
      "text": "(مُحَمَّدُ بْنُ أَبِي بَكْرٍ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا"
    },
    {
      "kind": "text",
      "text": "أَبُو عَوَانَةَ،"
    },
    {
      "kind": "text",
      "text": "عَبْدِ الْمَلِكِ بْنِ عُمَيْرٍ،"
    },
    {
      "kind": "text",
      "text": "(الْمُنْذِرِ بْنِ جَرِيرٍ،)"
    },
    {
      "kind": "text",
      "text": "عَنْ أَبِيهِ -رَضِيَ اللَّهُ عَنْهُ- قَالَ: قَالَ رَسُولُ اللَّهِ -صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ-:"
    },
    {
      "kind": "hadith",
      "text": "(( مَنْ سَنَّ سُنَّةً حَسَنَةً كَانَ لَهُ أَجْرُهَا، وَأَجْرُ مَنْ عَمِلَ بِهَا مِنْ غَيْرِ أَنْ يَنْقُصَ مِنْ أُجُورِهِمْ شَيْءٌ،وَمَنِ اسْتَنَّ سُنَّةً سَيِّئَةً فَعَمِلَ بِهَا كَانَ عَلَيْهِ وِزْرُهَا، وَمِثْلُ أَوْزَارِ مَنْ عَمِلَ بِهَا مِنْ غَيْرِ أَنْ يَنْقُصَ مِنْ أَوْزَارِهِمْ شَيْءٌ\". ))"
    },
    {
      "kind": "text",
      "text": "هَذَا حَدِيثٌ حَسَنُ الْإِسْنَادِ، بَلْ صَحِيحٌ، أَخْرَجَهُ"
    },
    {
      "kind": "text",
      "text": "مُسْلِمٌ"
    },
    {
      "kind": "text",
      "text": "مِنْ طُرُقٍ، وَالْإِمَامُ"
    },
    {
      "kind": "text",
      "text": "أَحْمَدُ،"
    },
    {
      "kind": "text",
      "text": "وَالتِّرْمِذِيُّ،"
    },
    {
      "kind": "text",
      "text": "وَالنَّسَائِيُّ،"
    },
    {
      "kind": "text",
      "text": "وَابْنُ مَاجَهْ،"
    },
    {
      "kind": "text",
      "text": "وَالدَّارِمِيُّ،"
    },
    {
      "kind": "text",
      "text": "وَأَبُو عَوَانَةَ،"
    },
    {
      "kind": "text",
      "text": "وَابْنُ حِبَّانَ،"
    },
    {
      "kind": "text",
      "text": "كُلُّهُمْ عَنْ"
    },
    {
      "kind": "text",
      "text": "(جَرِيرٍ.)"
    },
    {
      "kind": "text",
      "text": "وَقَدْ رُوِيَ أَيْضًا مِنْ طَرِيقِ"
    },
    {
      "kind": "text",
      "text": "حُذَيْفَةَ بْنِ الْيَمَانِ"
    },
    {
      "kind": "text",
      "text": "- رَضِيَ اللَّهُ عَنْهُ- وَفِيهِ قِصَّةٌ ."
    },
    {
      "kind": "text",
      "text": "وَفِي الْبَابِ عَنْ"
    },
    {
      "kind": "text",
      "text": "أَبِي هُرَيْرَةَ،"
    },
    {
      "kind": "text",
      "text": "وَأَبِي جُحَيْفَةَ،"
    },
    {
      "kind": "text",
      "text": "وَوَاثِلَةَ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُمْ ."
    },
    {
      "kind": "text",
      "text": "الثَّالِثُ مِنْهَا: حَثُّ النَّفْسِ عَلَى سُلُوكِ هَذِهِ الْأُمُورِ وَاتِّبَاعِهَا، وَالْكَفِّ عَنْ مَذْمُومِ كُلِّ الْأَخْلَاقِ وَارْتِدَاعِهَا، وَإِصْغَائِهَا إِلَى مَا يُقَرِّبُهَا إِلَى مَوْلَاهَا وَحُسْنِ اسْتِمَاعِهَا، وَمُجَاهَدَتِهَا عَلَى طَلَبِ الْفَوْزِ فِي الْآخِرَةِ، لَعَلَّ صَفْقَتَهَا تَكُونُ رَابِحَةً لَا خَاسِرَةً فَإِنَّ"
    },
    {
      "kind": "text",
      "text": "النَّفْسَ أَمَّارَةٌ بِالسُّوءِ إِلَّا أَنْ يَتَدَارَكَهَا اللَّهُ بِرَحْمَتِهِ،"
    },
    {
      "kind": "text",
      "text": "وَالشَّيْطَانُ حَرِيصٌ عَلَى إِهْلَاكِهَا بِالْغِوَايَةِ، وَلَا عَاصِمَ لَهَا مِنْهُ إِلَّا اللَّهُ سُبْحَانَهُ بِلُطْفِهِ، وَإِعَانَتِهِ، وَمُجَاهَدَةِ النَّفْسِ فِي أَعْمَالِ الطَّاعَاتِ، وَالِانْكِفَافِ عَنِ الْمُخَالَفَاتِ إِلَى الْأُمُورِ الْمَطْلُوبَةِ بِالذَّاتِ، قَالَ اللَّهُ تَعَالَى:"
    },
    {
      "kind": "text",
      "text": "وَالَّذِينَ جَاهَدُوا فِينَا لَنَهْدِيَنَّهُمْ سُبُلَنَا"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا السَّيِّدُ الْمُحَدِّثُ"
    },
    {
      "kind": "text",
      "text": "(سُلَيْمَانُ بْنُ يَحْيَى بْنِ عُمَرَ بْنِ عَبْدِ الْقَادِرِ الْحُسَيْنِيُّ الزَّبِيدِيُّ)"
    },
    {
      "kind": "text",
      "text": "سَمَاعًا،"
    },
    {
      "kind": "text",
      "text": "(وَالسَّيِّدُ الْقُطْبُ أَبُو الْمَرَاحِمِ وَجِيهُ الدِّينِ عَبْدُ الرَّحْمَنِ بْنُ السَّيِّدِ مُصْطَفَى الْعَيْدَرُوسِيُّ،)"
    },
    {
      "kind": "text",
      "text": "إِجَازَةً مُشَافَهَةً، قَالَا: أَخْبَرَنَا السَّيِّدُ الْوَجِيهُ"
    },
    {
      "kind": "text",
      "text": "(عَبْدُ الرَّحْمَنِ بْنُ عَبْدِ اللَّهِ بْنِ أَحْمَدَ الْعَلَوِيُّ التَّرَنْحِيُّ،)"
    },
    {
      "kind": "text",
      "text": "قَالَ الْأَوَّلُ: إِجَازَةً مُكَاتَبَةً، وَقَالَ الثَّانِي: مُشَافَهَةً، أَخْبَرَنَا خَالِي"
    },
    {
      "kind": "text",
      "text": "السَّيِّدُ الْوَجِيهُ"
    },
    {
      "kind": "text",
      "text": "(عَبْدُ الرَّحْمَنِ بْنُ مُحَمَّدٍ الْعَيْدَرُوسِيُّ،)"
    },
    {
      "kind": "text",
      "text": "ح وَأَخْبَرَنَا أَعْلَى مِنْ ذَلِكَ"
    },
    {
      "kind": "text",
      "text": "(عُمَرُ بْنُ أَحْمَدَ بْنِ عَقِيلٍ)"
    },
    {
      "kind": "text",
      "text": "سَمَاعًا فِي آخَرِينَ، أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(عَبْدُ اللَّهِ بْنُ سَالِمٍ،)"
    },
    {
      "kind": "text",
      "text": "(وَأَحْمَدُ بْنُ مُحَمَّدٍ النَّخْلِيُّ،)"
    },
    {
      "kind": "text",
      "text": "قَالُوا: أَخْبَرَنَا الْمُسْنِدُ"
    },
    {
      "kind": "text",
      "text": "(أَحْمَدُ بْنُ عَبْدِ اللَّطِيفِ الْأَزْهَرِيُّ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(الْبُرْهَانُ إِبْرَاهِيمُ بْنُ إِبْرَاهِيمَ الْمَالِكِيُّ)"
    },
    {
      "kind": "text",
      "text": "ح، قَالَا -أَيْ: سَالِمٌ وَالنَّخْلِيُّ-: وَأَخْبَرَنَا أَعْلَى مِنْ ذَلِكَ الْحَافِظُ"
    },
    {
      "kind": "text",
      "text": "(شَمْسُ الدِّينِ مُحَمَّدُ بْنُ الْعَلَاءِ،)"
    },
    {
      "kind": "text",
      "text": "قَالَ: أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(سَالِمُ بْنُ مُحَمَّدِ بْنِ مُحَمَّدٍ،)"
    },
    {
      "kind": "text",
      "text": "(وَالنُّورُ عَلِيُّ بْنُ يَحْيَى)"
    },
    {
      "kind": "text",
      "text": "قَالَا: أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَحْمَدُ بْنُ مُحَمَّدِ بْنِ أَبِي بَكْرٍ،)"
    },
    {
      "kind": "text",
      "text": "(وَيُوسُفُ بْنُ زَكَرِيَّا،)"
    },
    {
      "kind": "text",
      "text": "(وَيُوسُفُ بْنُ عَبْدِ اللَّهِ)"
    },
    {
      "kind": "text",
      "text": "قَالُوا: أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(مُحَمَّدُ بْنُ عَبْدِ الرَّحْمَنِ الْحَافِظُ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(رِضْوَانُ بْنُ مُحَمَّدِ بْنِ يُوسُفَ الْحَافِظُ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(أَبُو الْحَسَنِ عَلِيُّ بْنُ مُحَمَّدِ بْنِ أَبِي الْمَجْدِ الدِّمَشْقِيُّ،)"
    },
    {
      "kind": "text",
      "text": "قَدِمَ عَلَيْنَا، أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(التَّقِيَّ سُلَيْمَانُ بْنُ حَمْزَةَ الدِّمَشْقِيُّ،)"
    },
    {
      "kind": "text",
      "text": "أَخْبَرَنَا"
    },
    {
      "kind": "text",
      "text": "(عَبْدُ اللَّهُ بْنُ عُمَرَ بْنِ زَيْدٍ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا"
    },
    {
      "kind": "text",
      "text": "(مُحَمَّدُ بْنُ مُحَمَّدِ بْنِ النَّحَّاسِ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا"
    },
    {
      "kind": "text",
      "text": "(عَلِيُّ بْنُ أَحْمَدَ بْنِ السُّدِّيِّ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا"
    },
    {
      "kind": "text",
      "text": "(أَحْمَدُ بْنُ مُحَمَّدِ بْنِ الصَّلْتِ،)"
    },
    {
      "kind": "text",
      "text": "حَدَّثَنَا"
    },
