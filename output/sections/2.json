{
  "node_id": "2",
  "title": "قسم 2",
  "level": 1,
  "idfrom": 2,
  "idto": 2,
  "paragraphs": [
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    },
    {
      "kind": "text",
      "text": "وَهَذَا"
    },
    {
      "kind": "text",
      "text": "بَيَانُ الْكُتُبِ الَّتِي مِنْهَا أَخَذْتُ، وَعَنْهَا بِلَا وَاسِطَةٍ نَقَلْتُ وَاسْتَفَدْتُ،"
    },
    {
      "kind": "text",
      "text": "فَمِنْ ذَلِكَ فِي عِلْمِ اللُّغَةِ شَرْحِي عَلَى الْقَامُوسِ الَّذِي أَحَاطَ بِجَيِّدِ اللُّغَةِ وَحُوشِّيهَا، الَّذِي إِذَا رَآهُ الْمُنْصِفُ الْبَعِيدُ عَنِ الْمِرَا، قَالَ: كُلُّ الصَّيْدِ فِي جَوْفِ الْفَرَا، فَاسْتَغْنَيْتُ بِمُرَاجَعَتِهِ عَنْ جُمْلَةٍ مِنَ الْكُتُبِ الْمُؤَلَّفَةِ فِي الْفَنِّ، وَأَوْرَدْتُ مِنْهُ كُلَّ مُسْتَحْسَنٍ، وَلَمْ أُخْلِ مَعَ ذَلِكَ نَظَرِي فِي كِتَابِ النِّهَايَةِ"
    },
    {
      "kind": "text",
      "text": "(لِابْنِ الْأَثِيرِ)"
    },
    {
      "kind": "text",
      "text": "وَالْفَائِقِ"
    },
    {
      "kind": "text",
      "text": "لِلزَّمَخْشَرِيِّ،"
    },
    {
      "kind": "text",
      "text": "وَالْمُفْرَدَاتِ"
    },
    {
      "kind": "text",
      "text": "(لِأَبِي الْقَاسِمِ الرَّاغِبِ،)"
    },
    {
      "kind": "text",
      "text": "وَعُمْدَةِ الْحُفَّاظِ"
    },
    {
      "kind": "text",
      "text": "(لِلْمُهَيْمِنِ الْحَلَبِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَالتَّوْقِيفِ"
    },
    {
      "kind": "text",
      "text": "(لِلْمَنَاوِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَكِتَابِ الزِّينَةِ"
    },
    {
      "kind": "text",
      "text": "(لِأَبِي حَاتِمٍ الرَّازِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَمُشْكِلِ الْقُرْآنِ"
    },
    {
      "kind": "text",
      "text": "(لِابْنِ قُتَيْبَةَ،)"
    },
    {
      "kind": "text",
      "text": "فَرُبَّمَا اسْتَفَدْتُ مِنْهَا جُمَلًا كَثِيرَةً أَوْرَدْتُهَا مَعَ مُنَاسَبَاتِهَا فِي مَوَاضِعِهَا ."
    },
    {
      "kind": "text",
      "text": "وَمِنْ كُتُبِ أُصُولِ الْفِقْهِ: التَّوْضِيحُ لِصَدْرِ الشَّرِيعَةِ، وَشَرْحَاهُ; التَّنْقِيحُ"
    },
    {
      "kind": "text",
      "text": "(لِلسَّيِّدِ الْجُرْجَانِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَالتَّلْوِيحُ"
    },
    {
      "kind": "text",
      "text": "(لِسَعْدٍ التَّفْتَازَانِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَالْمِنْهَاجُ"
    },
    {
      "kind": "text",
      "text": "لِلْبَيْضَاوِيِّ،"
    },
    {
      "kind": "text",
      "text": "وَشَرْحُهُ"
    },
    {
      "kind": "text",
      "text": "(لِمُحَمَّدِ بْنِ طَاهِرٍ الْقَزْوِينِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَشِفَاءُ الْغَلِيلِ فِي مَسَالِكِ التَّعْلِيلِ لِلْمُصَنِّفِ ."
    },
    {
      "kind": "text",
      "text": "وَمِنْ كُتُبِ الْحَدِيثِ الَّتِي احْتَاجَ الْأَمْرُ إِلَى مُرَاجَعَتِهِ: شَرْحُ"
    },
    {
      "kind": "text",
      "text": "الْبُخَارِيِّ"
    },
    {
      "kind": "text",
      "text": "(لِلْحَافِظِ ابْنِ حَجَرٍ الْعَسْقَلَانِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَالْمُسَمَّى بِفَتْحِ الْبَارِي وَهُوَ الْبَحْرُ الَّذِي تَقِفُ عِنْدَهُ الْأَفْهَامُ، وَتَغْتَرِفُ"
    },
    {
      "kind": "text",
      "text": "مِنْ فُيُوضَاتِهِ الْأَعْلَامُ مَعَ إِعَادَةِ النَّظَرِ فِي كُلٍّ مِنْ شُرُوحِ"
    },
    {
      "kind": "text",
      "text": "(الْقَسْطَلَانِيِّ)"
    },
    {
      "kind": "text",
      "text": "(وَابْنِ الْمُلَقِّنِ)"
    },
    {
      "kind": "text",
      "text": "(وَالْكُورَانِيِّ)"
    },
    {
      "kind": "text",
      "text": "(وَالزَّرْكَشِيِّ)"
    },
    {
      "kind": "text",
      "text": "(وَالسُّيُوطِيِّ)"
    },
    {
      "kind": "text",
      "text": "(وَالسَّنَدِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَشَرْحِ الْجَامِعِ الصَّغِيرِ"
    },
    {
      "kind": "text",
      "text": "(لِلْمَنَاوِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَالسُّنَنِ لِكُلٍّ مِنَ"
    },
    {
      "kind": "text",
      "text": "الْبَيْهَقِيِّ"
    },
    {
      "kind": "text",
      "text": "وَالدَّارَقُطْنِيِّ،"
    },
    {
      "kind": "text",
      "text": "وَشَرْحِ"
    },
    {
      "kind": "text",
      "text": "(السُّيُوطِيِّ)"
    },
    {
      "kind": "text",
      "text": "عَلَى"
    },
    {
      "kind": "text",
      "text": "التِّرْمِذِيِّ."
    },
    {
      "kind": "text",
      "text": "وَمِنَ الْمَسَانِيدِ لِلْإِمَامِ"
    },
    {
      "kind": "text",
      "text": "أَحْمَدَ،"
    },
    {
      "kind": "text",
      "text": "وَعَبْدِ بْنِ حُمَيْدٍ،"
    },
    {
      "kind": "text",
      "text": "وَمُسَدَّدٍ،"
    },
    {
      "kind": "text",
      "text": "وَابْنِ أَبِي شَيْبَةَ،"
    },
    {
      "kind": "text",
      "text": "(وَالدَّيْلَمِيِّ.)"
    },
    {
      "kind": "text",
      "text": "وَمِنَ الْمَعَاجِمِ: الْكَبِيرُ وَالْأَوْسَطُ"
    },
    {
      "kind": "text",
      "text": "لِلطَّبَرَانِيِّ،"
    },
    {
      "kind": "text",
      "text": "(وَلِابْنِ جُمَيْعٍ الْغَسَّانِيِّ.)"
    },
    {
      "kind": "text",
      "text": "وَمِنَ الْكُتُبِ الَّتِي أَعْتَمِدُ عَلَى تَخْرِيجِ أَحَادِيثِ الْكِتَابِ عَلَيْهَا: الْمُغْنِي عَنْ حَمْلِ الْأَسْفَارِ لِلْحَافِظِ"
    },
    {
      "kind": "text",
      "text": "(الْعِرَاقِيِّ)"
    },
    {
      "kind": "text",
      "text": "فِي مُجَلَّدٍ، فَأَذْكُرُ كَلَامَهُ عَقِيبَ الْحَدِيثِ، ثُمَّ أَزِيدُ عَلَيْهِ حَسْبَمَا فَتَحَ اللَّهُ عَلَيَّ، فِي مُطَالَعَتِي لِكُتُبِ الْفَنِّ، وَرُبَّمَا نَقَلْتُ فِي بَعْضِ الْمَوَاضِعِ مِنْ تَخْرِيجِهِ الْكَبِيرِ عَلَيْهِ، وَلَمْ أَظْفَرْ مِنْهُ إِلَّا عَلَى كَرَارِيسَ، وَمِنْ ذَلِكَ الْجَامِعُ الْكَبِيرُ وَالصَّغِيرُ، وَالذَّيْلُ عَلَيْهِ، الثَّلَاثَةُ"
    },
    {
      "kind": "text",
      "text": "(لِلسُّيُوطِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَمَوْضُوعَاتُ"
    },
    {
      "kind": "text",
      "text": "ابْنِ الْجَوْزِيِّ،"
    },
    {
      "kind": "text",
      "text": "وَاللَّآلِئُ الْمَصْنُوعَةُ فِي الْأَحَادِيثِ الْمَوْضُوعَةِ، اسْتِدْرَاكًا عَلَى"
    },
    {
      "kind": "text",
      "text": "ابْنِ الْجَوْزِيِّ"
    },
    {
      "kind": "text",
      "text": "(لِلسُّيُوطِيِّ،)"
    },
    {
      "kind": "text",
      "text": "مَعَ الذَّيْلِ عَلَيْهِ لَهُ، وَنَوَادِرُ الْأُصُولِ"
    },
    {
      "kind": "text",
      "text": "(لِلْحَكِيمِ أَبِي عَبْدِ اللَّهِ مُحَمَّدِ بْنِ عَلِيٍّ التِّرْمِذِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَالْعِلَلُ"
    },
    {
      "kind": "text",
      "text": "لِلدَّارَقُطْنِيِّ،"
    },
    {
      "kind": "text",
      "text": "اثْنَا عَشَرَ مُجَلَّدًا، وَالْكَامِلُ"
    },
    {
      "kind": "text",
      "text": "(لِابْنِ عَدِيٍّ،)"
    },
    {
      "kind": "text",
      "text": "نَحْوُ ذَلِكَ، وَالْإِصْلَاحُ عَلَى الْمُسْتَدْرَكِ"
    },
    {
      "kind": "text",
      "text": "(لِلْعِرَاقِيِّ)"
    },
    {
      "kind": "text",
      "text": "الْحَافِظِ بِخَطِّهِ، وَاقْتِضَاءُ الْعِلْمِ الْعَمَلَ وَشَرَفُ أَصْحَابِ الْحَدِيثِ، كِلَاهُمَا"
    },
    {
      "kind": "text",
      "text": "(لِأَبِي بَكْرٍ الْخَطِيبِ الْحَافِظِ،)"
    },
    {
      "kind": "text",
      "text": "وَتَارِيخُهُ الْكَبِيرُ الْحَافِلُ فِي عَشْرِ مُجَلَّدَاتٍ، وَالذَّيْلُ عَلَيْهِ"
    },
    {
      "kind": "text",
      "text": "(لِلْبُنْدَارِيِّ)"
    },
    {
      "kind": "text",
      "text": "فِي مُجَلَّدٍ، وَأَيْضًا"
    },
    {
      "kind": "text",
      "text": "(لِابْنِ النَّجَّارِ الْحَنْبَلِيِّ)"
    },
    {
      "kind": "text",
      "text": "فِي مُجَلَّدَاتٍ، وَتَجْرِيدُ الصِّحَاحِ، وَالسُّنَنُ"
    },
    {
      "kind": "text",
      "text": "(لِرَزِينِ بْنِ مُعَاوِيَةَ الْعَبْدَرِيِّ السَّرَقُسْطِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَالْقَوْلُ الْمُسَدَّدُ فِي الذَّبِّ عَنْ مُسْنَدِ"
    },
    {
      "kind": "text",
      "text": "الْإِمَامِ أَحْمَدَ"
    },
    {
      "kind": "text",
      "text": "(لِلْحَافِظِ ابْنِ حَجَرٍ،)"
    },
    {
      "kind": "text",
      "text": "وَتَخْرِيجُ أَحَادِيثِ الْأَذْكَارِ لَهُ، وَحِلْيَةُ الْأَوْلِيَاءِ"
    },
    {
      "kind": "text",
      "text": "لِلْحَافِظِ أَبِي نُعَيْمٍ الْأَصْبَهَانِيِّ،"
    },
    {
      "kind": "text",
      "text": "وَتَخْرِيجُ أَحَادِيثِ الْمِنْهَاجِ الْأُصُولِيِّ لِكُلٍّ مِنَ"
    },
    {
      "kind": "text",
      "text": "(التَّاجِ السُّبْكِيِّ،)"
    },
    {
      "kind": "text",
      "text": "(وَابْنِ الْمُلَقِّنِ،)"
    },
    {
      "kind": "text",
      "text": "وَالتَّذْكِرَةُ"
    },
    {
      "kind": "text",
      "text": "(لِلْبَدْرِ الزَّرْكَشِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَالْمَقَاصِدُ الْحَسَنَةُ"
    },
    {
      "kind": "text",
      "text": "لِلْحَافِظِ السَّخَاوِيِّ،"
    },
    {
      "kind": "text",
      "text": "وَالْأَمَالِي عَلَى مَسَانِيدِ"
    },
    {
      "kind": "text",
      "text": "أَبِي حَنِيفَةَ"
    },
    {
      "kind": "text",
      "text": "(لِلزَّيْنِ قَاسِمِ بْنِ قُطْلُوبَغَا الْحَنَفِيُّ الْحَافِظُ،)"
    },
    {
      "kind": "text",
      "text": "وَاللَّآلِئُ الْمُتَنَاثِرَةُ فِي الْأَحَادِيثِ الْمُتَوَاتِرَةِ"
    },
    {
      "kind": "text",
      "text": "(لِابْنِ طُولُونَ الْحَنَفِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَأَطْرَافُ الْمَسَانِيدِ الْعَشَرَةِ"
    },
    {
      "kind": "text",
      "text": "(لِلشِّهَابِ الْأَبُوصِيرِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَجَمْعُ الْفَوَائِدِ"
    },
    {
      "kind": "text",
      "text": "(لِمُحَمَّدِ بْنِ سُلَيْمَانَ،)"
    },
    {
      "kind": "text",
      "text": "وَكِتَابُ الْعِلْمِ"
    },
    {
      "kind": "text",
      "text": "(لِابْنِ خَيْثَمَةَ زُهَيْرِ بْنِ حَرْبٍ النَّسَائِيِّ.)"
    },
    {
      "kind": "text",
      "text": "إِلَى غَيْرِ ذَلِكَ مِمَّا اسْتَفَدْتُ مِنْ مَعَانِيهَا وَأَسْرَارِهَا، كَشَرْحِ الْأَمَالِي عَلَى مُخْتَصَرِ هَذَا الْكِتَابِ الْمُسَمَّى بِعَيْنِ الْعِلْمِ وَالذَّرِيعَةِ إِلَى مَحَاسِنِ الشَّرِيعَةِ،"
    },
    {
      "kind": "text",
      "text": "(لِلْقَفَّالِ الشَّاشِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَالذَّرِيعَةِ إِلَى مَكَارِمِ الشَّرِيعَةِ"
    },
    {
      "kind": "text",
      "text": "(لِأَبِي الْقَاسِمِ الرَّاغِبِ،)"
    },
    {
      "kind": "text",
      "text": "وَالْبَحْرِ الزَّاخِرِ"
    },
    {
      "kind": "text",
      "text": "(لِأَبِي الطَّيِّبِ حَمْدَانَ بْنِ حَمْدَوَيْهِ،)"
    },
    {
      "kind": "text",
      "text": "وَجَوَاهِرِ الْقُرْآنِ لِلْمُصَنِّفِ، وَفَضَائِلِ الْقُرْآنِ"
    },
    {
      "kind": "text",
      "text": "(لِلْقُرْطُبِيِّ.)"
    },
    {
      "kind": "text",
      "text": "وَأَمَّا مَا يَتَعَلَّقُ بِأُصُولِ الدِّينِ وَالِاعْتِقَادِ وَالْفِقْهِ وَفُرُوعِهِ فَسَيَأْتِي بَيَانُ مَآخِذِ كُلِّ ذَلِكَ فِي مَوَاضِعِهِ عَلَى مَا يَسَّرَ اللَّهُ تَعَالَى عَلَيَّ فِي مُرَاجَعَتِهِ، وَالْكَشْفِ عَنْ مَظَانِّهِ، فَأَذْكُرُ فِي كِتَابِ الْعَقَائِدِ مَا تَحَصَّلَ لَدَيَّ، وَفِي الْعِبَادَاتِ كَذَلِكَ ."
    },
    {
      "kind": "text",
      "text": "وَأَمَّا التَّصَوُّفُ وَالرَّقَائِقُ فَقَدْ طَالَعْتُ عَلَيْهِ كُتُبًا كَثِيرَةً، وَأَجَلُّهَا مِقْدَارًا الرِّسَالَةُ لِلْإِمَامِ"
    },
    {
      "kind": "text",
      "text": "(أَبِي الْقَاسِمِ الْقُشَيْرِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَشَرْحَاهَا"
    },
    {
      "kind": "text",
      "text": "(لِأَبِي مُحَمَّدٍ عَبْدِ الْمُعْطِي بْنِ مَحْمُودٍ اللَّخْمِيِّ،)"
    },
    {
      "kind": "text",
      "text": "(وَلِشَيْخِ الْإِسْلَامِ زَكَرِيَّا،)"
