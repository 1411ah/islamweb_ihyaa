  "paragraphs": [
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    },
    {
      "kind": "heading",
      "text": "الشَّطْرُ الثَّانِي مِنَ الْكِتَابِ فِي الشُّكْرِ وَلَهُ ثَلَاثَةُ أَرْكَانٍ :"
    },
    {
      "kind": "text",
      "text": "الْأَوَّلُ فِي"
    },
    {
      "kind": "text",
      "text": "فَضِيلَةِ الشُّكْرِ وَحَقِيقَتِهِ"
    },
    {
      "kind": "text",
      "text": "وَأَقْسَامِهِ وَأَحْكَامِهِ ، الثَّانِي فِي حَقِيقَةِ النِّعْمَةِ وَأَقْسَامِهَا الْخَاصَّةِ وَالْعَامَّةِ ، الثَّالِثُ فِي بَيَانِ الْأَفْضَلِ مِنَ الشُّكْرِ وَالصَّبْرِ ."
    },
    {
      "kind": "text",
      "text": "الرُّكْنُ الْأَوَّلُ فِي نَفْسِ الشُّكْرِ ."
    },
    {
      "kind": "text",
      "text": "بَيَانُ فَضِيلَةِ الشُّكْرِ ."
    },
    {
      "kind": "heading",
      "text": "اعْلَمْ أَنَّ اللَّهَ تَعَالَى قَرَنَ الشُّكْرَ بِالذِّكْرِ فِي كِتَابِهِ مَعَ أَنَّهُ قَالَ :"
    },
    {
      "kind": "text",
      "text": "وَلَذِكْرُ اللَّهِ أَكْبَرُ"
    },
    {
      "kind": "heading",
      "text": "، فَقَالَ تَعَالَى فَاذْكُرُونِي :"
    },
    {
      "kind": "text",
      "text": "أَذْكُرْكُمْ وَاشْكُرُوا لِي وَلا تَكْفُرُونِ"
    },
    {
      "kind": "heading",
      "text": "وَقَالَ تَعَالَى :"
    },
    {
      "kind": "text",
      "text": "مَا يَفْعَلُ اللَّهُ بِعَذَابِكُمْ إِنْ شَكَرْتُمْ وَآمَنْتُمْ"
    },
    {
      "kind": "heading",
      "text": "وَقَالَ تَعَالَى :"
    },
    {
      "kind": "text",
      "text": "وَسَنَجْزِي الشَّاكِرِينَ"
    },
    {
      "kind": "heading",
      "text": "وَقَالَ عَزَّ وَجَلَّ إِخْبَارًا عَنْ إِبْلِيسَ اللَّعِينِ :"
    },
    {
      "kind": "text",
      "text": "لأَقْعُدَنَّ لَهُمْ صِرَاطَكَ الْمُسْتَقِيمَ"
    },
    {
      "kind": "text",
      "text": "، قِيلَ هُوَ طَرِيقُ الشُّكْرِ وَلِعُلُوِّ رُتْبَةِ الشُّكْرِ طَعَنَ اللَّعِينُ فِي الْخَلْقِ فَقَالَ : وَلَا تَجِدُ أَكْثَرَهُمْ شَاكِرِينَ وَقَالَ تَعَالَى :"
    },
    {
      "kind": "text",
      "text": "وَقَلِيلٌ مِنْ عِبَادِيَ الشَّكُورُ"
    },
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    }
  ],
  "has_quran": false,
  "has_hadith": false
}