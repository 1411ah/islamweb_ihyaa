{
  "node_id": "3368",
  "title": "الجملة الثامنة في صفة العمرة وما بعدها إلى طواف الوداع",
  "level": 4,
  "idfrom": 3368,
  "idto": 3368,
  "paragraphs": [
    {
      "kind": "break",
      "text": ""
    },
    {
      "kind": "text",
      "text": "الْجُمْلَةُ الثَّامِنَةُ فِي"
    },
    {
      "kind": "text",
      "text": "صِفَةِ الْعُمْرَةِ ،"
    },
    {
      "kind": "text",
      "text": "وَمَا بَعْدَهَا إِلَى طَوَافِ الْوَدَاعِ ."
    },
    {
      "kind": "text",
      "text": "مَنْ أَرَادَ أَنْ يَعْتَمِرَ قَبْلَ حَجِّهِ أَوْ بَعْدَهُ كَيْفَمَا أَرَادَ فَلْيَغْتَسِلْ وَيَلْبَسْ ، ثِيَابَ الْإِحْرَامِ كَمَا سَبَقَ فِي الْحَجِّ وَيُحْرِمُ بِالْعُمْرَةِ مِنْ مِيقَاتِهَا"
    },
    {
      "kind": "text",
      "text": "وَأَفْضَلُ مَوَاقِيتِهَا"
    },
    {
      "kind": "text",
      "text": "(الْجِعْرَانَةُ)"
    },
    {
      "kind": "text",
      "text": "ثُمَّ"
    },
    {
      "kind": "text",
      "text": "(التَّنْعِيمِ)"
    },
    {
      "kind": "text",
      "text": "ثُمَّ"
    },
    {
      "kind": "text",
      "text": "(الْحُدَيْبِيَةِ)"
    },
    {
      "kind": "text",
      "text": "وَيَنْوِي الْعُمْرَةَ ، وَيُلَبِّي وَيَقْصِدُ مَسْجِدَ"
    },
    {
      "kind": "text",
      "text": "عَائِشَةَ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهَا وَيُصَلِّي رَكْعَتَيْنِ وَيَدْعُو بِمَا شَاءَ ثُمَّ يَعُودُ إِلَى"
    },
    {
      "kind": "text",
      "text": "(مَكَّةَ)"
    },
    {
      "kind": "text",
      "text": "وَهُوَ يُلَبِّي حَتَّى يَدْخُلَ"
    },
    {
      "kind": "text",
      "text": "(الْمَسْجِدَ الْحَرَامَ)"
    },
    {
      "kind": "text",
      "text": "فَإِذَا دَخَلَ الْمَسْجِدَ تَرَكَ التَّلْبِيَةَ ، وَطَافَ سَبْعًا ، وَسَعَى سَبْعًا كَمَا وَصَفْنَا فَإِذَا فَرَغَ حَلَقَ رَأْسَهُ ، وَقَدْ تَمَّتْ عُمْرَتُهُ"
    },
    {
      "kind": "break",
      "text": ""
    }
  ],
  "has_quran": false,
  "has_hadith": false
}