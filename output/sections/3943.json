{
  "node_id": "3943",
  "title": "قسم 3943",
  "idfrom": 3943,
  "idto": 3943,
  "paragraphs": [
    {
      "kind": "text",
      "text": "بَيَانُ"
    },
    {
      "kind": "text",
      "text": "طُرُقِ الْقِسْمَةِ لِأَجْزَاءِ اللَّيْلِ ."
    },
    {
      "kind": "text",
      "text": "اعْلَمْ أَنَّ"
    },
    {
      "kind": "text",
      "text": "إِحْيَاءَ اللَّيْلِ"
    },
    {
      "kind": "heading",
      "text": "مِنْ حَيْثُ الْمِقْدَارِ لَهُ سَبْعُ مَرَاتِبَ:"
    },
    {
      "kind": "text",
      "text": "الْأُولَى : إِحْيَاءُ كُلِّ اللَّيْلِ وَهَذَا شَأْنُ الْأَقْوِيَاءِ الَّذِينَ تَجَرَّدُوا لِعِبَادَةِ اللَّيْلِ وَتَلَذَّذُوا بِمُنَاجَاتِهِ وَصَارَ ذَلِكَ غِذَاءً لَهُمْ وَحَيَاةً لِقُلُوبِهِمْ فَلَمْ يَتْعَبُوا بِطُولِ الْقِيَامِ وَرَدُّوا الْمَنَامَ إِلَى النَّهَارِ وَفِي وَقْتِ اشْتِغَالِ النَّاسِ وَقَدْ كَانَ ذَلِكَ طَرِيقَ جَمَاعَةٍ مِنَ السَّلَفِ كَانُوا يُصَلُّونَ الصُّبْحَ بِوُضُوءِ الْعِشَاءِ حَكَى"
    },
    {
      "kind": "text",
      "text": "أَبُو طَالِبٍ الْمَكِّيُّ"
    },
    {
      "kind": "text",
      "text": "أَنَّ ذَلِكَ حُكِيَ عَلَى سَبِيلِ التَّوَاتُرِ وَالِاشْتِهَارِ عَنْ أَرْبَعِينَ مِنَ"
    },
    {
      "kind": "text",
      "text": "(التَّابِعِينَ ،)"
    },
    {
      "kind": "heading",
      "text": "وَكَانَ فِيهِمْ مَنْ وَاظَبَ عَلَيْهِ أَرْبَعِينَ سَنَةً قَالَ مِنْهُمْ :"
    },
    {
      "kind": "text",
      "text": "سَعِيدُ بْنُ الْمُسَيِّبِ ،"
    },
    {
      "kind": "text",
      "text": "(وَصَفْوَانُ بْنُ سُلَيْمٍ)"
    },
    {
      "kind": "text",
      "text": "الْمَدَنِيَّانِ"
    },
    {
      "kind": "text",
      "text": "وَفُضَيْلُ بْنُ عِيَاضٍ"
    },
    {
      "kind": "text",
      "text": "(وَوُهَيْبُ بْنُ الْوَرْدِ)"
    },
    {
      "kind": "text",
      "text": "الْمَكِّيَّانِ وَطَاوُسُ وَوَهْبُ بْنُ مُنَبِّهٍ الْيَمَانِيَّانِ"
    },
    {
      "kind": "text",
      "text": "(وَالرَّبِيعُ بْنُ خَيْثَمٍ ،)"
    },
    {
      "kind": "text",
      "text": "(وَالْحَكَمُ)"
    },
    {
      "kind": "text",
      "text": "الْكُوفِيَّانِ"
    },
    {
      "kind": "text",
      "text": "(وَأَبُو سُلَيْمَانَ الدَّارَانِيُّ)"
    },
    {
      "kind": "text",
      "text": "(وَعَلِيُّ بْنُ بَكَّارٍ)"
    },
    {
      "kind": "text",
      "text": "الشَّامِيَّانِ"
    },
    {
      "kind": "text",
      "text": "(وَأَبُو عَبْدِ اللَّهِ الْخَوَّاصُ)"
    },
    {
      "kind": "text",
      "text": "(وَأَبُو عَاصِمٍ)"
    },
    {
      "kind": "text",
      "text": "الْعِبَادِيَّانِ"
    },
    {
      "kind": "text",
      "text": "(وَحَبِيبٌ أَبُو مُحَمَّدٍ ،)"
    },
    {
      "kind": "text",
      "text": "(وَأَبُو جَابِرٍ السِّلْمَانِيُّ)"
    },
    {
      "kind": "text",
      "text": "الْفَارِسِيَّانِ"
    },
    {
      "kind": "text",
      "text": "وَمَالِكُ بْنُ دِينَارٍ"
    },
    {
      "kind": "text",
      "text": "(وَسُلَيْمَانُ التَّيْمِيُّ)"
    },
    {
      "kind": "text",
      "text": "(وَيَزِيدُ الرَّقَاشِيُّ)"
    },
    {
      "kind": "text",
      "text": "(وَحَبِيبُ بْنُ أَبِي ثَابِتٍ)"
    },
    {
      "kind": "text",
      "text": "(وَيَحْيَى الْبَكَّاءُ)"
    },
    {
      "kind": "text",
      "text": "الْبَصْرِيُّونَ"
    },
    {
      "kind": "text",
      "text": "(وَكَهْمَسُ بْنُ الْمِنْهَالِ)"
    },
    {
      "kind": "text",
      "text": "وَكَانَ يَخْتِمُ فِي الشَّهْرِ تِسْعِينَ خَتْمَةً ، وَمَا لَمْ يَفْهَمْهُ رَجَعَ وَقَرَأَهُ مَرَّةً أُخْرَى وَأَيْضًا مِنْ"
    },
    {
      "kind": "text",
      "text": "(أَهْلِ الْمَدِينَةِ)"
    },
    {
      "kind": "text",
      "text": "(أَبُو حَازِمٍ)"
    },
    {
      "kind": "text",
      "text": "(وَمُحَمَّدُ بْنُ الْمُنْكَدِرِ)"
    },
    {
      "kind": "text",
      "text": "فِي جَمَاعَةٍ يَكْثُرُ عَدَدُهُمْ"
    }
  ],
  "has_quran": false,
  "has_hadith": false
}