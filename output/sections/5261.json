    },
    {
      "kind": "text",
      "text": "وَمِنْهَا"
    },
    {
      "kind": "text",
      "text": "أَنْ يَسْتُرَ عَوْرَاتِ الْمُسْلِمِينَ كُلَّهُمْ"
    },
    {
      "kind": "heading",
      "text": "قَالَ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ :"
    },
    {
      "kind": "hadith",
      "text": "(( مَنْ سَتَرَ عَلَى مُسْلِمٍ سَتَرَهُ اللَّهُ تَعَالَى فِي الدُّنْيَا وَالْآخِرَةِ ))"
    },
    {
      "kind": "heading",
      "text": "وَقَالَ :"
    },
    {
      "kind": "hadith",
      "text": "(( لَا يَسْتُرُ عَبْدٌ عَبْدًا إِلَّا سَتَرَهُ اللَّهُ يَوْمَ الْقِيَامَةِ ))"
    },
    {
      "kind": "text",
      "text": "وَقَالَ"
    },
    {
      "kind": "text",
      "text": "أَبُو سَعِيدٍ الْخُدْرِيُّ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُ"
    },
    {
      "kind": "hadith",
      "text": "(( لَا يَرَى الْمُؤْمِنُ مِنْ أَخِيهِ عَوْرَةً فَيَسْتُرُهَا عَلَيْهِ إِلَّا دَخَلَ الْجَنَّةَ، ))"
    },
    {
      "kind": "text",
      "text": "وَقَالَ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ"
    },
    {
      "kind": "text",
      "text": "(لِمَاعِزٍ)"
    },
    {
      "kind": "text",
      "text": "لَمَّا أَخْبَرَهُ"
    },
    {
      "kind": "hadith",
      "text": "(( لَوْ سَتَرْتَهُ بِثَوْبِكَ كَانَ خَيْرًا لَكَ ))"
    },
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    }
  ],
  "has_quran": false,
  "has_hadith": true
}