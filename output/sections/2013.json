{
  "node_id": "2013",
  "title": "قسم 2013",
  "idfrom": 2013,
  "idto": 2013,
  "paragraphs": [
    {
      "kind": "text",
      "text": "يُصَلِّي بَعْدَ الْجُمُعَةِ"
    },
    {
      "kind": "text",
      "text": "سِتَّ رَكَعَاتٍ فَقَدْ رَوَى"
    },
    {
      "kind": "text",
      "text": "ابْنُ عُمَرَ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُمَا أَنَّهُ"
    },
    {
      "kind": "hadith",
      "text": "(( صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ كَانَ يُصَلِّي بَعْدَ الْجُمُعَةِ رَكْعَتَيْنِ ))"
    },
    {
      "kind": "text",
      "text": "وَرَوَى"
    },
    {
      "kind": "text",
      "text": "أَبُو هُرَيْرَةَ"
    },
    {
      "kind": "text",
      "text": "أَرْبَعًا وَرَوَى"
    },
    {
      "kind": "text",
      "text": "عَلَيٌّ ،"
    },
    {
      "kind": "text",
      "text": "(وَعَبْدُ اللهِ ابْنُ عَبَّاسٍ)"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُمْ سِتًّا وَالْكُلُّ صَحِيحٌ فِي أَحْوَالٍ مُخْتَلِفَةٍ وَالْأَكْمَلُ أَفْضَلُ ."
    }
  ],
  "has_quran": false,
  "has_hadith": true
}