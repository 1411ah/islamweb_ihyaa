{
  "node_id": "451",
  "title": "قسم 451",
  "level": 1,
  "idfrom": 451,
  "idto": 451,
  "paragraphs": [
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    },
    {
      "kind": "text",
      "text": "وَالذُّكُورَةُ شَرْطُ النُّبُوَّةِ،"
    },
    {
      "kind": "text",
      "text": "وَاخْتَارَهُ كَثِيرٌ مِنْهُمْ،"
    },
    {
      "kind": "text",
      "text": "وَالْمُجْتَهِدُ يُخْطِئُ وَيُصِيبُ،"
    },
    {
      "kind": "text",
      "text": "وَالْحَقُّ عِنْدَ اللَّهِ وَاحِدٌ، وَاخْتَارَهُ"
    },
    {
      "kind": "text",
      "text": "الْمُحَاسَبِيُّ"
    },
    {
      "kind": "text",
      "text": "(وَالْقَطَّانِيُّ)"
    },
    {
      "kind": "text",
      "text": "وَالْأُسْتَاذُ"
    },
    {
      "kind": "text",
      "text": "(أَبُو إِسْحَاقَ)"
    },
    {
      "kind": "text",
      "text": "(وَعَبْدُ الْقَاهِرِ الْبَغْدَادِيُّ،)"
    },
    {
      "kind": "text",
      "text": "وَكَثِيرٌ مِنْهُمْ، كَمَا فِي \"الْكَشْفُ الْكَبِيرُ\"، وَتَصِحُّ"
    },
    {
      "kind": "text",
      "text": "إِمَامَةُ الْمَفْضُولِ،"
    },
    {
      "kind": "text",
      "text": "وَاخْتَارَهُ"
    },
    {
      "kind": "text",
      "text": "الْبَاقِلَّانِيُّ"
    },
    {
      "kind": "text",
      "text": "وَكَثِيرٌ مِنْهُمْ، كَمَا فِي \"الْمَوَاقِفُ\"، وَبِالْمَوْتِ يَحْصُلُ الْخُرُوجُ لِلرُّوحِ وَالْإِزْهَاقُ، لَا قَطْعُ الْبَقَاءِ؛ فَهُوَ وُجُودِيُّ، كَمَا فِي \"التَّبْصِرَةُ النَّسَفِيَّةُ\"، وَاخْتَارَهُ"
    },
    {
      "kind": "text",
      "text": "(الْقَلَانِسِيُّ،)"
    },
    {
      "kind": "text",
      "text": "كَمَا فِي \"التَّبْصِرَةُ الْبَغْدَادِيَّةُ\" ."
    },
    {
      "kind": "text",
      "text": "وَالْأَعْرَاضُ لَا تُعَادُ، وَاخْتَارَهُ الْقَلَانِسِيُّ، وَهُوَ أَحَدُ الرِّوَايَتَيْنِ عَنِ"
    },
    {
      "kind": "text",
      "text": "الْأَشْعَرِيِّ،"
    },
    {
      "kind": "text",
      "text": "كَمَا فِي \"الْمَوَاقِفُ\" ."
    },
    {
      "kind": "text",
      "text": "فَهَذِهِ خَمْسُونَ مَسْأَلَةً خِلَافِيَّةً فِي التَّفَارِيعِ الْكَلَامِيَّةِ، ذَهَبَ إِلَيْهِ جُمْهُورُ"
    },
    {
      "kind": "text",
      "text": "(الْمَاتُرِيدِيَّةِ،)"
    },
    {
      "kind": "text",
      "text": "وَخَالَفَهُمْ فِيهِ جُمْهُورُ"
    },
    {
      "kind": "text",
      "text": "(الْأَشَاعِرَةِ،)"
    },
    {
      "kind": "text",
      "text": "كُلُّ ذَلِكَ مَأْخُوذٌ مِنْ كَلَامِ الْإِمَامِ"
    },
    {
      "kind": "text",
      "text": "أَبِي حَنِيفَةَ،"
    },
    {
      "kind": "text",
      "text": "وَمُسْتَفَادُهَا مِنْهُ إِمَّا مِنَ الْعِبَارَةِ، أَوِ الْإِشَارَةِ، أَوِ الدَّلَالَةِ، أَوْ الِاقْتِضَاءِ، أَوْ مَفْهُومِ الْمُخَالَفَةِ؛ فَإِنَّهُ يُعْتَبَرُ أَكْثَرَهَا فِي الرِّوَايَةِ، وَاللَّهُ أَعْلَمُ ."
    }
  ],
  "has_quran": false,
  "has_hadith": false
}