  "node_id": "1567",
  "title": "قسم 1567",
  "idfrom": 1567,
  "idto": 1567,
  "paragraphs": [
    {
      "kind": "text",
      "text": "ثُمَّ"
    },
    {
      "kind": "text",
      "text": "تَكْبِيرَاتُ الِانْتِقَالَاتِ"
    },
    {
      "kind": "text",
      "text": "ثُمَّ الذِّكْرُ فِي الرُّكُوعِ وَالسُّجُودُ وَالِاعْتِدَالُ عَنْهُمَا ثُمَّ"
    },
    {
      "kind": "text",
      "text": "التَّشَهُّدُ الْأَوَّلُ"
    },
    {
      "kind": "text",
      "text": "وَالصَّلَاةُ فِيهِ عَلَى النَّبِيِّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ"
    },
    {
      "kind": "text",
      "text": "الدُّعَاءُ فِي آخِرِ التَّشَهُّدِ الْأَخِيرِ"
    },
    {
      "kind": "text",
      "text": "ثُمَّ التَّسْلِيمَةُ الثَّانِيَةُ ."
    }
  ],
  "has_quran": false,
  "has_hadith": false
}