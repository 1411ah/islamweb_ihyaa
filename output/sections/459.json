{
  "node_id": "459",
  "title": "الفصل الأول في ترجمة عقيدة أهل السنة في كلمتي الشهادة",
  "idfrom": 459,
  "idto": 459,
  "paragraphs": [
    {
      "kind": "text",
      "text": "كِتَابُ قَوَاعِدِ الْعَقَائِدِ ."
    },
    {
      "kind": "text",
      "text": "بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ ."
    },
    {
      "kind": "text",
      "text": "وَفِيهِ أَرْبَعَةُ فُصُولٍ ."
    },
    {
      "kind": "text",
      "text": "الْفَصْلُ الْأَوَّلُ ."
    },
    {
      "kind": "text",
      "text": "فِي تَرْجَمَةِ"
    },
    {
      "kind": "text",
      "text": "عَقِيدَةِ أَهْلِ السُّنَّةِ فِي كَلِمَتَيِ الشَّهَادَةِ"
    },
    {
      "kind": "text",
      "text": "الَّتِي هِيَ أَحَدُ مَبَانِي الْإِسْلَامِ ."
    },
    {
      "kind": "heading",
      "text": "فَنَقُولُ وَبِاللَّهِ التَّوْفِيقُ :"
    },
    {
      "kind": "text",
      "text": "الْحَمْدُ لِلَّهِ الْمُبْدِئِ الْمُعِيدِ الْفَعَّالِ لِمَا يُرِيدُ ."
    }
  ],
  "has_quran": false,
  "has_hadith": false,
  "level": 3
}