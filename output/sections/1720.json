{
  "node_id": "1720",
  "title": "مما ينبغي أن يحضر في القلب عند كل شرط وركن النية",
  "idfrom": 1720,
  "idto": 1720,
  "paragraphs": [
    {
      "kind": "text",
      "text": "وَمِفْتَاحُ مَزِيدِ الدَّرَجَاتِ هِيَ الصَّلَوَاتُ"
    },
    {
      "kind": "text",
      "text": "قَالَ اللَّهُ عَزَّ وَجَلَّ"
    },
    {
      "kind": "text",
      "text": "قَدْ أَفْلَحَ الْمُؤْمِنُونَ"
    },
    {
      "kind": "text",
      "text": "الَّذِينَ هُمْ فِي صَلاتِهِمْ خَاشِعُونَ"
    },
    {
      "kind": "text",
      "text": "فَمَدَحَهُمْ بَعْدَ الْإِيمَانِ بِصَلَاةٍ مَخْصُوصَةٍ ، وَهِيَ الْمَقْرُونَةُ بِالْخُشُوعِ ."
    }
  ],
  "has_quran": false,
  "has_hadith": false,
  "level": 5
}