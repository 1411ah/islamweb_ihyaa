  "paragraphs": [
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    },
    {
      "kind": "text",
      "text": "الْبَابُ الْأَوَّلُ : ."
    },
    {
      "kind": "text",
      "text": "نَقْلِ الْمَذَاهِبِ وَالْأَقَاوِيلِ"
    },
    {
      "kind": "text",
      "text": "وَذِكْرُ حُجَجِ الْفَرِيقَيْنِ فِي ذَلِكَ ."
    },
    {
      "kind": "text",
      "text": "أَمَّا الْمَذَاهِبُ فَقَدِ اخْتَلَفَ فِيهَا وَظَهَرَ هَذَا الِاخْتِلَافُ بَيْنَ التَّابِعِينَ ."
    },
    {
      "kind": "text",
      "text": "فَذَهَبَ إِلَى"
    },
    {
      "kind": "heading",
      "text": "اخْتِيَارِ الْعُزْلَةِ وَتَفْضِيلِهَا عَلَى الْمُخَالَطَةِ :"
    },
    {
      "kind": "text",
      "text": "سُفْيَانُ الثَّوْرِيُّ"
    },
    {
      "kind": "text",
      "text": "وَإِبْرَاهِيمُ بْنُ أَدْهَمَ"
    },
    {
      "kind": "text",
      "text": "(وَدَاوُدٌ الطَّائِيُّ)"
    },
    {
      "kind": "text",
      "text": "وَفُضَيْلُ بْنُ عِيَاضٍ"
    },
    {
      "kind": "text",
      "text": "وَسُلَيْمَانُ الْخَوَّاصُ"
    },
    {
      "kind": "text",
      "text": "(وَيُوسُفُ بْنُ أَسْبَاطٍ)"
    },
    {
      "kind": "text",
      "text": "(وَحُذَيْفَةُ الْمَرْعَشِيُّ)"
    },
    {
      "kind": "text",
      "text": "(وَبِشْرُ الْحَافِي)"
    },
    {
      "kind": "text",
      "text": "وَقَالَ أَكْثَرُ التَّابِعِينَ بِاسْتِحْبَابِ الْمُخَالَطَةِ وَاسْتِكْثَارِ الْمَعَارِفِ وَالْإِخْوَانِ وَالتَّآلُفِ وَالتَّحَبُّبِ إِلَى الْمُؤْمِنِينَ وَالِاسْتِعَانَةِ بِهِمْ فِي الدِّينِ تَعَاوُنًا عَلَى الْبِرِّ وَالتَّقْوَى وَمَالَ إِلَى هَذَا"
    },
    {
      "kind": "text",
      "text": "سَعِيدُ بْنُ الْمُسَيِّبِ"
    },
    {
      "kind": "text",
      "text": "وَالشَّعْبِيُّ"
    },
    {
      "kind": "text",
      "text": "وَابْنُ أَبِي لَيْلَى"
    },
    {
      "kind": "text",
      "text": "(وَهِشَامُ بْنُ عُرْوَةَ)"
    },
    {
      "kind": "text",
      "text": "(وَابْنُ شُبْرُمَةَ)"
    },
    {
      "kind": "text",
      "text": "(وَشُرَيْحُ)"
    },
    {
      "kind": "text",
      "text": "(وَشَرِيكُ بْنُ عَبْدِ اللَّهِ)"
    },
    {
      "kind": "text",
      "text": "وَابْنُ عُيَيْنَةَ"
    },
    {
      "kind": "text",
      "text": "وَابْنُ الْمُبَارَكِ"
    },
    {
      "kind": "text",
      "text": "(وَالشَّافِعِيُّ)"
    },
    {
      "kind": "text",
      "text": "وَأَحْمَدَ بْنِ حَنْبَلٍ"
    },
    {
      "kind": "text",
      "text": "وَجَمَاعَةٌ ."
    },
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    }
  ],
  "has_quran": false,
  "has_hadith": false
}