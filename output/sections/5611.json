{
  "node_id": "5611",
  "title": "بيان أقاويل العلماء والمتصوفة في تحليل وتحريم السماع",
  "level": 4,
  "idfrom": 5611,
  "idto": 5611,
  "paragraphs": [
    {
      "kind": "break",
      "text": ""
    },
    {
      "kind": "text",
      "text": "وَقَالَ لَمْ يَزَلِ الْحِجَازِيُّونَ عِنْدَنَا"
    },
    {
      "kind": "text",
      "text": "(بِمَكَّةَ)"
    },
    {
      "kind": "text",
      "text": "يَسْمَعُونَ"
    },
    {
      "kind": "text",
      "text": "السَّمَاعَ فِي أَفْضَلِ أَيَّامِ السَّنَةِ"
    },
    {
      "kind": "text",
      "text": "وَهِيَ الْأَيَّامُ الْمَعْدُودَاتُ الَّتِي أَمَرَ اللَّهُ عِبَادَهُ فِيهَا بِذِكْرِهِ كَأَيَّامِ التَّشْرِيقِ وَلَمْ يَزَلْ"
    },
    {
      "kind": "text",
      "text": "(أَهْلُ الْمَدِينَةِ)"
    },
    {
      "kind": "text",
      "text": "مُوَاظِبِينَ"
    },
    {
      "kind": "text",
      "text": "(كَأَهْلِ مَكَّةَ)"
    },
    {
      "kind": "text",
      "text": "عَلَى السَّمَاعِ إِلَى زَمَانِنَا هَذَا فَأَدْرَكْنَا"
    },
    {
      "kind": "text",
      "text": "(أَبَا مَرْوَانَ الْقَاضِيَ)"
    },
    {
      "kind": "text",
      "text": "وَلَهُ جَوَارٍ يُسْمِعْنَ النَّاسَ التَّلْحِينَ قَدْ أَعَدَّهُنَّ"
    },
    {
      "kind": "text",
      "text": "(لِلصُّوفِيَّةِ)"
    },
    {
      "kind": "text",
      "text": "قَالَ وَكَانَ"
    },
    {
      "kind": "text",
      "text": "(لِعَطَاءٍ)"
    },
    {
      "kind": "text",
      "text": "جَارِيَتَانِ يُلَحِّنَانِ فَكَانَ إِخْوَانُهُ يَسْتَمِعُونَ إِلَيْهِمَا  ."
    },
    {
      "kind": "break",
      "text": ""
    }
  ],
  "has_quran": false,
  "has_hadith": false
}