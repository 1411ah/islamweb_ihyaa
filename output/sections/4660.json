{
  "node_id": "4660",
  "title": "قسم 4660",
  "idfrom": 4660,
  "idto": 4660,
  "paragraphs": [
    {
      "kind": "text",
      "text": "الْبَابُ الْأَوَّلُ ."
    },
    {
      "kind": "text",
      "text": "فِي فَضِيلَةِ الْحَلَالِ وَمَذَمَّةِ الْحَرَامِ ."
    },
    {
      "kind": "text",
      "text": "وَبَيَانِ أَصْنَافِ الْحَلَالِ وَدَرَجَاتِهِ وَأَصْنَافِ الْحَرَامِ وَدَرَجَاتِ الْوَرَعِ فِيهِ ."
    },
    {
      "kind": "text",
      "text": "فَضِيلَةُ الْحَلَالِ وَمَذَمَّةُ الْحَرَامِ"
    },
    {
      "kind": "text",
      "text": "قَالَ اللَّهُ تَعَالَى"
    },
    {
      "kind": "text",
      "text": "كُلُوا مِنَ الطَّيِّبَاتِ وَاعْمَلُوا صَالِحًا"
    },
    {
      "kind": "text",
      "text": "أَمَرَ بِالْأَكْلِ مِنَ الطَّيِّبَاتِ قَبْلَ الْعَمَلِ وَقِيلَ : إِنَّ الْمُرَادَ بِهِ الْحَلَالُ ."
    },
    {
      "kind": "heading",
      "text": "وَقَالَ تَعَالَى :"
    },
    {
      "kind": "text",
      "text": "وَلا تَأْكُلُوا أَمْوَالَكُمْ بَيْنَكُمْ بِالْبَاطِلِ"
    },
    {
      "kind": "text",
      "text": "إِنَّ الَّذِينَ يَأْكُلُونَ أَمْوَالَ الْيَتَامَى ظُلْمًا"
    },
    {
      "kind": "text",
      "text": "الْآيَةَ ."
    },
    {
      "kind": "heading",
      "text": "وَقَالَ تَعَالَى:"
    },
    {
      "kind": "text",
      "text": "يَا أَيُّهَا الَّذِينَ آمَنُوا اتَّقُوا اللَّهَ وَذَرُوا مَا بَقِيَ مِنَ الرِّبَا إِنْ كُنْتُمْ مُؤْمِنِينَ"
    },
    {
      "kind": "text",
      "text": "ثُمَّ قَالَ"
    },
    {
      "kind": "text",
      "text": "فَإِنْ لَمْ تَفْعَلُوا فَأْذَنُوا بِحَرْبٍ مِنَ اللَّهِ وَرَسُولِهِ"
    },
    {
      "kind": "text",
      "text": "، ثُمَّ قَالَ"
    },
    {
      "kind": "text",
      "text": "وَإِنْ تُبْتُمْ فَلَكُمْ رُءُوسُ أَمْوَالِكُمْ"
    },
    {
      "kind": "text",
      "text": "وَمَنْ عَادَ فَأُولَئِكَ أَصْحَابُ النَّارِ هُمْ فِيهَا خَالِدُونَ"
    },
    {
      "kind": "text",
      "text": "جَعَلَ آكِلَ الرِّبَا أَوَّلِ الْأَمْرِ مُؤْذَنًا بِمُحَارَبَةِ اللَّهِ وَفِي آخِرِهِ مُتَعَرِّضًا لِلنَّارِ ."
    }
  ],
  "has_quran": false,
  "has_hadith": false
}