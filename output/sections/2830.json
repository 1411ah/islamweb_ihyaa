  "paragraphs": [
    {
      "kind": "heading",
      "text": "وَاسْتَدَلُّوا بِقَوْلِهِ عَزَّ وَجَلَّ :"
    },
    {
      "kind": "text",
      "text": "وَمِمَّا رَزَقْنَاهُمْ يُنْفِقُونَ"
    },
    {
      "kind": "text",
      "text": "وَبِقَوْلِهِ تَعَالَى"
    },
    {
      "kind": "text",
      "text": "أَنْفِقُوا مِمَّا رَزَقْنَاكُمْ"
    },
    {
      "kind": "text",
      "text": "وَزَعَمُوا أَنَّ ذَلِكَ غَيْرُ مَنْسُوخٍ بِآيَةِ الزَّكَاةِ بَلْ هُوَ دَاخِلٌ فِي حَقِّ الْمُسْلِمِ عَلَى الْمُسْلِمِ"
    }
  ],
  "has_quran": false,
  "has_hadith": false
}