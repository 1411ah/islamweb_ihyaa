  "paragraphs": [
    {
      "kind": "break",
      "text": ""
    },
    {
      "kind": "text",
      "text": "وَفَرْضٌ الْوُضُوءِ النِّيَّةُ وَغَسْلُ الْوَجْهِ"
    },
    {
      "kind": "text",
      "text": "وَغَسْلُ الْيَدَيْنِ إِلَى الْمِرْفَقَيْنِ"
    },
    {
      "kind": "text",
      "text": "وَمَسْحُ مَا يَنْطَلِقُ عَلَيْهِ الِاسْمُ مِنَ الرَّأْسِ وَغَسْلُ"
    },
    {
      "kind": "text",
      "text": "الرِّجْلَيْنِ إِلَى الْكَعْبَيْنِ"
    },
    {
      "kind": "text",
      "text": "وَالتَّرْتِيبُ"
    },
    {
      "kind": "text",
      "text": "وَأَمَّا الْمُوَالَاةُ فَلَيْسَتْ بِوَاجِبَةٍ ."
    },
    {
      "kind": "break",
      "text": ""
    }
  ],
