    },
    {
      "kind": "text",
      "text": "بَيَانُ الْآدَابِ ، وَالسُّنَنِ الْخَارِجَةِ ، عَنِ التَّرْتِيبِ السَّابِقِ ."
    },
    {
      "kind": "text",
      "text": "الَّذِي يَعُمُّ جَمِيعَ النَّهَارِ ، وَهِيَ سَبْعَةُ أُمُورٍ ."
    },
    {
      "kind": "heading",
      "text": "الْأَوَّلُ أَنْ ؛ :"
    },
    {
      "kind": "text",
      "text": "يَحْضُرَ مَجَالِسَ الْعِلْمِ"
    },
    {
      "kind": "text",
      "text": "بُكْرَةً أَوْ بَعْدَ الْعَصْرِ وَلَا"
    },
    {
      "kind": "text",
      "text": "يَحْضُرُ مَجَالِسَ الْقُصَّاصِ"
    },
    {
      "kind": "text",
      "text": "فَلَا خَيْرَ فِي كَلَامِهِمْ ."
    },
    {
      "kind": "text",
      "text": "وَلَا يَنْبَغِي أَنْ يَخْلُوَ الْمُرِيدُ فِي جَمِيعِ يَوْمِ الْجُمُعَةِ عَنِ الْخَيْرَاتِ وَالدَّعَوَاتِ حَتَّى تُوَافِيَهُ السَّاعَةُ الشَّرِيفَةُ وَهُوَ فِي خَيْرٍ ."
    },
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    }
  ],
