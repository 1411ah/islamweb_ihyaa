{
  "node_id": "4121",
  "title": "قسم 4121",
  "idfrom": 4121,
  "idto": 4121,
  "paragraphs": [
    {
      "kind": "heading",
      "text": "ثُمَّ قَالَ بَعْدَ ذِكْرِ الْمَنِّ وَالسَّلْوَى :"
    },
    {
      "kind": "text",
      "text": "كُلُوا مِنْ طَيِّبَاتِ مَا رَزَقْنَاكُمْ"
    },
    {
      "kind": "text",
      "text": "فَاللَّحْمُ وَالْحَلَاوَةُ مِنَ الطَّيِّبَاتِ ."
    },
    {
      "kind": "text",
      "text": "قَالَ"
    },
    {
      "kind": "text",
      "text": "أَبُو سُلَيْمَانَ الدَّارَانِيُّ رَضِيَ اللَّهُ عَنْهُ"
    },
    {
      "kind": "text",
      "text": "أَكْلُ الطَّيِّبَاتِ"
    },
    {
      "kind": "text",
      "text": "يُورِثُ الرِّضَا عَنِ اللَّهِ ."
    },
    {
      "kind": "text",
      "text": "وَتَتِمُّ هَذِهِ الطَّيِّبَاتُ بِشُرْبِ الْمَاءِ الْبَارِدِ وَصَبِّ الْمَاءِ الْفَاتِرِ عَلَى الْيَدِ عِنْدَ الْغَسْلِ ."
    },
    {
      "kind": "text",
      "text": "الْمَأْمُونُ"
    },
    {
      "kind": "text",
      "text": "شُرْبُ الْمَاءِ بِثَلْجٍ يُخْلِصُ الشُّكْرَ ."
    }
  ],
  "has_quran": false,
  "has_hadith": false
}