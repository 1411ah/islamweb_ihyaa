{
  "node_id": "310",
  "title": "من وظائف القراءة للإمام الإسرار بدعاء الاستفتاح",
  "level": 5,
  "idfrom": 1766,
  "idto": 1808,
  "paragraphs": [
    {
      "kind": "break",
      "text": ""
    },
    {
      "kind": "text",
      "text": "وَأَمَّا وَظَائِفُ الْقِرَاءَةِ فَثَلَاثَةٌ ."
    },
    {
      "kind": "text",
      "text": ": أَوَّلُهَا أَنْ"
    },
    {
      "kind": "text",
      "text": "يُسِرَّ بِدُعَاءِ الِاسْتِفْتَاحِ وَالتَّعَوُّذِ"
    },
    {
      "kind": "text",
      "text": "كَالْمُنْفَرِدِ وَيَجْهَرُ بِالْفَاتِحَةِ ، وَالسُّورَةِ بَعْدَهَا فِي جَمِيعِ الصُّبْحِ وَأُولَيَيِ الْعِشَاءِ ، وَالْمَغْرِبِ وَكَذَلِكَ ، الْمُنْفَرِدُ ."
    },
    {
      "kind": "text",
      "text": "وَيَجْهَرُ بِقَوْلِهِ : آمِينَ فِي الصَّلَاةِ"
    },
    {
      "kind": "text",
      "text": "الْجَهْرِيَّةِ وَكَذَا الْمَأْمُومُ ."
    },
    {
      "kind": "break",
      "text": ""
    }
  ],
