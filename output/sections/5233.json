{
  "node_id": "5233",
  "title": "حقوق المسلم",
  "idfrom": 5233,
  "idto": 5233,
  "paragraphs": [
    {
      "kind": "text",
      "text": "وَمِنْهَا أَنْ"
    },
    {
      "kind": "text",
      "text": "لَا يَسْمَعَ بَلَاغَاتِ النَّاسِ بَعْضُهُمْ عَلَى بَعْضٍ"
    },
    {
      "kind": "text",
      "text": "وَلَا يُبَلِّغَ بَعْضَهُمْ مَا يَسْمَعُ مِنْ بَعْضٍ ."
    },
    {
      "kind": "heading",
      "text": "قَالَ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ :"
    },
    {
      "kind": "hadith",
      "text": "(( لَا يَدْخُلُ الْجَنَّةَ قَتَّاتٌ ))"
    },
    {
      "kind": "text",
      "text": "وَقَالَ"
    },
    {
      "kind": "text",
      "text": "الْخَلِيلُ بْنُ أَحْمَدَ"
    },
    {
      "kind": "text",
      "text": "مِنْ نَمَّ لَكَ نَمَّ عَلَيْكَ وَمَنْ أَخْبَرَكَ بِخَبَرِ غَيْرِكَ أَخْبَرَ غَيْرَكَ بِخَبَرِكَ ."
    }
  ],
  "has_quran": false,
  "has_hadith": true,
  "level": 4
}