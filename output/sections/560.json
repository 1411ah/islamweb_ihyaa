    {
      "kind": "text",
      "text": "وَقَالَ"
    },
    {
      "kind": "text",
      "text": "أَحْمَدُ"
    },
    {
      "kind": "text",
      "text": "رَحِمَهُ اللَّهُ"
    },
    {
      "kind": "text",
      "text": "عُلَمَاءُ الْكَلَامِ زَنَادِقَةٌ ."
    },
    {
      "kind": "text",
      "text": "مَالِكُ"
    },
    {
      "kind": "text",
      "text": "رَحِمَهُ اللَّهُ أَرَأَيْتَ إِنْ جَاءَهُ مَنْ هُوَ أَجْدَلُ مِنْهُ أَيَدَعُ دِينَهُ كُلَّ يَوْمٍ لِدِينٍ جَدِيدٍ ؟ يَعْنِي أَنَّ أَقْوَالَ الْمُتَجَادِلِينَ تَتَفَاوَتُ ."
    }
  ],
