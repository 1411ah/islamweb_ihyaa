    {
      "kind": "text",
      "text": "وَمِنْ ذَلِكَ أَنْ"
    },
    {
      "kind": "text",
      "text": "يَدْعُوَهُ بِأَحَبِّ أَسْمَائِهِ إِلَيْهِ"
    },
    {
      "kind": "text",
      "text": "فِي غَيْبَتِهِ وَحُضُورِهِ ."
    },
    {
      "kind": "text",
      "text": "قَالَ"
    },
    {
      "kind": "text",
      "text": "عُمَرُ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُ ثَلَاثٌ : يُصَفِّينَ لَكَ وُدَّ أَخِيكَ أَنْ تُسَلِّمَ عَلَيْهِ إِذَا لَقِيتَهُ أَوَّلًا وَتُوسِعَ لَهُ فِي الْمَجْلِسِ وَتَدْعُوهُ بِأَحَبِّ أَسْمَائِهِ إِلَيْهِ ."
    },
