  "paragraphs": [
    {
      "kind": "heading",
      "text": "وَقَالَ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ :"
    },
    {
      "kind": "hadith",
      "text": "(( كُلُّ أُمَّتِي مُعَافًى إِلَّا الْمُجَاهِرِينَ ))"
    },
    {
      "kind": "text",
      "text": "وَإِنَّ"
    },
    {
      "kind": "text",
      "text": "مِنَ الْمُجَاهَرَةِ أَنْ يَعْمَلَ الرَّجُلُ السُّوءَ سِرًّا ثُمَّ يُخْبِرُ بِهِ"
    },
    {
      "kind": "hadith",
      "text": "(( مَنِ اسْتَمَعَ خَبَرَ قَوْمٍ وَهُمْ لَهُ كَارِهُونَ صُبَّ فِي أُذُنِهِ الْآنَكُ يَوْمَ الْقِيَامَةِ ))"
    }
  ],
  "has_quran": false,
  "has_hadith": true
}