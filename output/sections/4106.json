{
  "node_id": "4106",
  "title": "آداب حضور الطعام",
  "idfrom": 4106,
  "idto": 4106,
  "paragraphs": [
    {
      "kind": "text",
      "text": "وَالْمُنْكَرُ"
    },
    {
      "kind": "text",
      "text": "فَرْشُ الدِّيبَاجِ وَاسْتِعْمَالُ"
    },
    {
      "kind": "text",
      "text": "أَوَانِي الْفِضَّةِ وَالذَّهَبِ وَالتَّصْوِيرُ"
    },
    {
      "kind": "text",
      "text": "عَلَى الْحِيطَانِ وَسَمَاعُ"
    },
    {
      "kind": "text",
      "text": "الْمَلَاهِي وَالْمَزَامِيرِ وَحُضُورُ"
    },
    {
      "kind": "text",
      "text": "النِّسْوَةِ الْمُتَكَشِّفَاتِ الْوُجُوهَ وَغَيْرُ ذَلِكَ مِنَ الْمُحَرَّمَاتِ حَتَّى قَالَ أَحْمَدُ رَحِمَهُ اللَّهُ : إِذَا رَأَى مُكْحُلَةً رَأْسُهَا مُفَضَّضٌ يَنْبَغِي أَنْ يَخْرُجَ وَلَمْ يَأْذَنْ فِي الْجُلُوسِ إِلَّا فِي ضَبَّةٍ"
    }
  ],
  "has_quran": false,
  "has_hadith": false,
  "level": 4
}