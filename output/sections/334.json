    {
      "kind": "heading",
      "text": "السَّادِسُ :"
    },
    {
      "kind": "text",
      "text": "الْخُطْبَتَانِ"
    },
    {
      "kind": "text",
      "text": "فَهُمَا فَرِيضَتَانِ وَالْقِيَامُ فِيهِمَا فَرِيضَةٌ"
    },
    {
      "kind": "text",
      "text": "وَالْجِلْسَةُ بَيْنَهُمَا فَرِيضَةٌ"
    },
    {
      "kind": "break",
      "text": ""
