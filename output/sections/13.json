{
  "node_id": "13",
  "title": "قسم 13",
  "idfrom": 13,
  "idto": 13,
  "paragraphs": [
    {
      "kind": "text",
      "text": "(الْفَصْلُ الْحَادِي عَشَرَ فِي"
    },
    {
      "kind": "text",
      "text": "بَيَانِ حَالِ الْمُنْتَسَبِ إِلَيْهِ)"
    },
    {
      "kind": "text",
      "text": "قَالَ صَاحِبُ تُحْفَةِ الْإِرْشَادِ نَقْلًا عَنِ الْإِمَامِ"
    },
    {
      "kind": "text",
      "text": "(النَّوَوِيِّ)"
    },
    {
      "kind": "text",
      "text": "فِي دَقَائِقِ الرَّوْضَةِ: التَّشْدِيدُ فِي"
    },
    {
      "kind": "text",
      "text": "الْغَزَالِيِّ"
    },
    {
      "kind": "text",
      "text": "هُوَ الْمَعْرُوفُ الَّذِي ذَكَرَهُ"
    },
    {
      "kind": "text",
      "text": "(ابْنُ الْأَثِيرِ،)"
    },
    {
      "kind": "text",
      "text": "وَبَلَغَنَا أَنَّهُ قَالَ: مَنْسُوبٌ إِلَى"
    },
    {
      "kind": "text",
      "text": "(غَزَالَةَ)"
    },
    {
      "kind": "text",
      "text": "بِتَخْفِيفِ الزَّايِ، قَرْيَةٍ مِنْ قُرَى"
    },
    {
      "kind": "text",
      "text": "(طُوسٍ.)"
    },
    {
      "kind": "text",
      "text": "قُلْتُ: وَهَكَذَا ذَكَرَهُ"
    },
    {
      "kind": "text",
      "text": "(النَّوَوِيُّ)"
    },
    {
      "kind": "text",
      "text": "أَيْضًا فِي التِّبْيَانِ، وَقَالَ"
    },
    {
      "kind": "text",
      "text": "(الذَّهَبِيُّ)"
    },
    {
      "kind": "text",
      "text": "فِي الْعِبَرِ"
    },
    {
      "kind": "text",
      "text": "(وَابْنُ خِلِّكَانَ)"
    },
    {
      "kind": "text",
      "text": "فِي التَّارِيخِ: عَادَةُ أَهْلِ"
    },
    {
      "kind": "text",
      "text": "(خَوَارِزْمَ)"
    },
    {
      "kind": "text",
      "text": "(وَجُرْجَانَ)"
    },
    {
      "kind": "text",
      "text": "يَقُولُونَ: الْقُصَّارِيُّ وَالْحُبَّارِيُّ بِالْيَاءِ فِيهِمَا، فَنَسَبُوهُ"
    },
    {
      "kind": "text",
      "text": "(لِلْغَزَالِ،)"
    },
    {
      "kind": "text",
      "text": "وَقَالُوا"
    },
    {
      "kind": "text",
      "text": "الْغَزَالِيُّ،"
    },
    {
      "kind": "text",
      "text": "وَمِثْلُ ذَلِكَ"
    },
    {
      "kind": "text",
      "text": "(الشَّحَّامِيُّ،)"
    },
    {
      "kind": "text",
      "text": "وَأَشَارَ لِذَلِكَ"
    },
    {
      "kind": "text",
      "text": "(ابْنُ السَّمْعَانِيِّ)"
    },
    {
      "kind": "text",
      "text": "أَيْضًا، وَأَنْكَرَ التَّخْفِيفَ، وَقَالَ: سَأَلْتُ أَهْلَ"
    },
    {
      "kind": "text",
      "text": "(طُوسَ)"
    },
    {
      "kind": "text",
      "text": "عَنْ هَذِهِ الْقَرْيَةِ فَأَنْكَرُوهَا، وَزِيَادَةُ هَذِهِ الْيَاءِ قَالُوا لِلتَّأْكِيدِ، وَفِي تَقْرِيرِ بَعْضِ شُيُوخِنَا لِلتَّمْيِيزِ بَيْنَ الْمَنْسُوبِ إِلَى نَفْسِ الصَّنْعَةِ وَبَيْنَ الْمَنْسُوبِ إِلَى مَنْ كَانَ صَنْعَتُهُ كَذَلِكَ، وَهَذَا ظَاهِرٌ فِي"
    },
    {
      "kind": "text",
      "text": "(الْعَزَالِيِّ؛)"
    },
    {
      "kind": "text",
      "text": "فَإِنَّهُ لَمْ يَكُنْ مِمَّنْ يَغْزِلُ الصُّوفَ وَيَبِيعُهُ، وَإِنَّمَا هِيَ صَنْعَةُ وَالِدِهِ وَجَدِّهِ ."
    },
    {
      "kind": "text",
      "text": "وَلَكِنْ فِي الْمِصْبَاحِ لِلْفَيُّومِيِّ مَا يُؤَيِّدُ التَّخْفِيفَ، وَأَنَّ غَزَالَةَ قَرْيَةٌ بِطُوسَ، وَإِلَيْهَا نُسِبَ"
    },
    {
      "kind": "text",
      "text": "الْإِمَامُ أَبُو حَامِدٍ،"
    },
    {
      "kind": "text",
      "text": "قَالَ: أَخْبَرَنِي بِذَلِكَ الشَّيْخِ"
    },
    {
      "kind": "text",
      "text": "(مَجْدُ الدِّينِ بْنُ مُحَمَّدِ بْنِ أَبِي الطَّاهِرِ شِرْوَانَ شَاهْ بْنِ أَبِي الْفَضَائِلِ فَخْرَاوَرَ بْنِ عُبَيْدِ اللَّهِ بْنِ سِتِّ الْمَنَا بِنْتِ أَبِي حَامِدٍ الْغَزَالِيِّ)"
    },
    {
      "kind": "text",
      "text": "(بِبَغْدَادَ)"
    },
    {
      "kind": "text",
      "text": "سَنَةَ عَشْرٍ وَسَبْعِمِائَةٍ، وَقَالَ لِي: أَخْطَأَ النَّاسُ فِي تَثْقِيلِ جَدِّنَا، وَإِنَّمَا هُوَ مُخَفَّفٌ ."
    },
    {
      "kind": "text",
      "text": "وَقَالَ"
    },
    {
      "kind": "text",
      "text": "(الشِّهَابُ الْخَفَاجِيُّ)"
    },
    {
      "kind": "text",
      "text": "فِي آخِرِ شَرْحِ الشِّفَا: وَيُقَالُ: إِنَّهُ مَنْسُوبٌ إِلَى"
    },
    {
      "kind": "text",
      "text": "ابْنَةِ"
    },
    {
      "kind": "text",
      "text": "كَعْبِ الْأَحْبَارِ،"
    },
    {
      "kind": "text",
      "text": "وَهَذَا إِنْ صَحَّ فَلَا مَحِيدَ عَنْهُ، وَالْمُعْتَمَدُ الْآنَ عِنْدَ الْمُتَأَخِّرِينَ مِنْ أَئِمَّةِ التَّارِيخِ وَالْأَنْسَابِ أَنَّ الْقَوْلَ قَوْلُ"
    },
    {
      "kind": "text",
      "text": "(ابْنِ الْأَثِيرِ)"
    },
    {
      "kind": "text",
      "text": "أَنَّهُ بِالتَّشْدِيدِ ."
    },
    {
      "kind": "text",
      "text": "وَسَمِعْتُ شَيْخَنَا الْقُطْبَ السَّيِّدَ"
    },
    {
      "kind": "text",
      "text": "(الْعَيْدَرُوسَ)"
    },
    {
      "kind": "text",
      "text": "-نَفَعَ اللَّهُ بِهِ- يَقُولُ: إِنَّهُ هَكَذَا سَمِعَهُ مِنْ لِسَانِ النَّبِيِّ -صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ- فِي وَاقِعَةٍ مَنَامِيَّةٍ، وَعَلَيْهِ أَنْشَدَنَا شَيْخُنَا الْمَرْحُومُ"
    },
    {
      "kind": "text",
      "text": "(عَبْدُ الْخَالِقِ بْنُ أَبِي بَكْرٍ الزَّجَّاجِيُّ)"
    },
    {
      "kind": "text",
      "text": "(بِزَبِيدَ)"
    },
    {
      "kind": "text",
      "text": "لِأَحَدِ شُعَرَاءِ"
    },
    {
      "kind": "text",
      "text": "(الْيَمَنِ)"
    },
    {
      "kind": "heading",
      "text": "وَقَدْ أَجَادَ:"
    },
    {
      "kind": "center",
      "text": "⟪CENTER⟫مَا لِلْعَوَاذِلِ فِي هَوَاكَ وَمَا لِي رُوحِي فِدَاكَ يَا حُبِّي وَمَالِي     غَزَالُ طَرْفِكَ إِنْ رَنَا أَحْيَا بِهِوَكَذَلِكَ الْإِحْيَاءُ لِلْغَزَالِي⟪/CENTER⟫"
    }
  ],
  "has_quran": false,
  "has_hadith": false
}