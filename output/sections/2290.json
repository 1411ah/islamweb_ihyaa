{
  "node_id": "2290",
  "title": "فصل صلاة العيدين واجبة على من تجب عليه الجمعة",
  "idfrom": 2290,
  "idto": 2290,
  "paragraphs": [
    {
      "kind": "text",
      "text": "الْقِسْمُ الثَّالِثُ ."
    },
    {
      "kind": "text",
      "text": "مَا يَتَكَرَّرُ بِتَكَرُّرِ السِّنِينَ ."
    },
    {
      "kind": "heading",
      "text": "وَهِيَ أَرْبَعَةٌ :"
    },
    {
      "kind": "text",
      "text": "صَلَاةُ الْعِيدَيْنِ"
    },
    {
      "kind": "text",
      "text": "وَالتَّرَاوِيحُ ، وَصَلَاةُ رَجَبٍ وَشَعْبَانَ ."
    },
    {
      "kind": "text",
      "text": ". الْأُولَى صَلَاةُ الْعِيدَيْنِ ."
    },
    {
      "kind": "text",
      "text": "وَهِيَ سُنَّةٌ مُؤَكَّدَةٌ وَشِعَارٌ مِنْ شَعَائِرِ الدِّينِ ."
    }
  ],
  "has_quran": false,
  "has_hadith": false,
  "level": 6
}