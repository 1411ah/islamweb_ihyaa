{
  "node_id": "453",
  "title": "قسم 453",
  "idfrom": 453,
  "idto": 453,
  "paragraphs": [
    {
      "kind": "text",
      "text": "وَذَكَرَ"
    },
    {
      "kind": "text",
      "text": "بَعْضَ مَسَائِلِ الْفِقْهِ الْأَكْبَرِ"
    },
    {
      "kind": "text",
      "text": "(شَيْخُ الْإِسْلَامِ مُحَمَّدُ بْنُ إِلْيَاسَ)"
    },
    {
      "kind": "text",
      "text": "فِي فَتَاوِيهِ،"
    },
    {
      "kind": "text",
      "text": "(وَابْنُ الْهُمَامِ)"
    },
    {
      "kind": "text",
      "text": "فِي \"الْمُسَايَرَةِ\"، وَذَكَرَ بَعْضَ مَسَائِلِ الْفِقْهِ الْأَبْسَطِ الْإِمَامُ"
    },
    {
      "kind": "text",
      "text": "(أَبُو الْمُعِينِ النَّسَفِيُّ)"
    },
    {
      "kind": "text",
      "text": "فِي الِاعْتِمَادِ شَرْحِ الْعُمْدَةِ، وَكَشْفِ الْمَنَارِ، وَالنَّاطِفِيُّ فِي الْأَجْنَاسِ،"
    },
    {
      "kind": "text",
      "text": "(وَالْقَاضِي أَبُو الْعَلَاءِ الصَّاعِدِيُّ)"
    },
    {
      "kind": "text",
      "text": "فِي كِتَابِ الِاعْتِقَادِ،"
    },
    {
      "kind": "text",
      "text": "(وَأَبُو شُجَاعٍ النَّاصِرِيُّ)"
    },
    {
      "kind": "text",
      "text": "فِي الْبُرْهَانِ السَّاطِعِ شَرْحِ عَقَائِدِ"
    },
    {
      "kind": "text",
      "text": "الطَّحَاوِيِّ،"
    },
    {
      "kind": "text",
      "text": "(وَأَبُو الْمَحَاسِنِ مَحْمُودٌ الْقُونَوِيُّ)"
    },
    {
      "kind": "text",
      "text": "فِي شَرْحِهَا أَيْضًا، وَشَرَحَهُ الْفَقِيهُ"
    },
    {
      "kind": "text",
      "text": "(عَطَاءُ بْنُ عَلِيٍّ الْجُوزَجَانِيُّ)"
    },
    {
      "kind": "text",
      "text": "شَرْحًا نَفِيسًا، وَذَكَرَ الْوَصِيَّةَ بِتَمَامِهَا الْإِمَامُ"
    },
    {
      "kind": "text",
      "text": "(صَارِمٌ الْمِصْرِيٌّ)"
    },
    {
      "kind": "text",
      "text": "فِي نَظْمِ الْجُمَانِ ."
    },
    {
      "kind": "text",
      "text": "وَمِنَ الْمُتَأَخِّرِينَ"
    },
    {
      "kind": "text",
      "text": "(الْقَاضِي تَقِيُّ الدِّينِ التَّمِيمِيُّ)"
    },
    {
      "kind": "text",
      "text": "فِي الطَّبَقَاتِ السَّنِيَّةِ،"
    },
    {
      "kind": "text",
      "text": "(وَالْقَاضِي أَبُو الْفَضْلِ مُحَمَّدُ بْنُ الشِّحْنَةِ الْحَلَبِيُّ)"
    },
    {
      "kind": "text",
      "text": "فِي أَوَائِلِ شَرْحِ الْهِدَايَةِ، وَذَكَرَ بَعْضَ مَسَائِلِهَا"
    },
    {
      "kind": "text",
      "text": "(ابْنُ الْهُمَامِ)"
    },
    {
      "kind": "text",
      "text": "فِي الْمُسَايَرَةِ، وَشَرَحَهَا الشَّيْخُ"
    },
    {
      "kind": "text",
      "text": "(أَكْمَلُ الدِّينِ الْبَابَرْتِيُّ،)"
    },
    {
      "kind": "text",
      "text": "فَقَدْ ذَكَرَ جُمَلًا مِنْ مَسَائِلِ الْكُتُبِ الْخَمْسَةِ مَنْقُولًا عَنْهَا، نَحْوَ ثَلَاثِينَ كِتَابًا مِنْ كُتُبِ الْأَئِمَّةِ، وَهَذَا الْقَدْرُ كَافٍ فِي تَلَقِّي الْأُمَّةِ لَهَا بِالْقَبُولِ، وَاللَّهُ أَعْلَمُ ."
    }
  ],
  "has_quran": false,
  "has_hadith": false
}