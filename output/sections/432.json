{
  "node_id": "432",
  "title": "قسم 432",
  "idfrom": 432,
  "idto": 432,
  "paragraphs": [
    {
      "kind": "text",
      "text": "وَمِنَ"
    },
    {
      "kind": "text",
      "text": "الْآخِذِينَ عَنِ الْأَشْعَرِيِّ"
    },
    {
      "kind": "text",
      "text": "الْأُسْتَاذُ"
    },
    {
      "kind": "text",
      "text": "أَبُو سَهْلٍ الصُّعْلُوكِيُّ،"
    },
    {
      "kind": "text",
      "text": "(وَأَبُو بَكْرٍ الْجُرْجَانِيُّ الْإِسْمَاعِيلِيُّ،)"
    },
    {
      "kind": "text",
      "text": "وَالشَّيْخُ"
    },
    {
      "kind": "text",
      "text": "(أَبُو بَكْرٍ الْقَفَّالُ،)"
    },
    {
      "kind": "text",
      "text": "وَأَبُو زَيْدٍ الْمَرْوَزِيُّ،"
    },
    {
      "kind": "text",
      "text": "(وَأَبُو عَبْدِ اللَّهِ بْنِ خَفِيفٍ الشِّيرَازِيُّ،)"
    },
    {
      "kind": "text",
      "text": "(وَزَاهِرُ بْنُ أَحْمَدَ السَّرْخَسِيُّ،)"
    },
    {
      "kind": "text",
      "text": "وَالْحَافِظُ أَبُو بَكْرٍ الْجُرْجَانِيُّ الْإِسْمَاعِيلِيُّ، وَالشَّيْخُ أَبُو بَكْرٍ الْأَوْدِفِيُّ، وَالشَّيْخُ"
    },
    {
      "kind": "text",
      "text": "(أَبُو مُحَمَّدٍ الطَّبَرِيُّ الْعِرَاقِيُّ،)"
    },
    {
      "kind": "text",
      "text": "(وَأَبُو جَعْفَرٍ السُّلَمِيُّ النَّقَّاشُ،)"
    },
    {
      "kind": "text",
      "text": "وَغَيْرُهُمْ، هَؤُلَاءِ أَصْحَابُهُ، وَأَمَّا الَّذِينَ جَالَسُوا أَصْحَابَهُ وَأَصْحَابَ أَصْحَابِهِ وَهَلُمَّ جَرًّا، فَهُمْ كَثِيرُونَ عَلَى طَبَقَاتِهِمْ ."
    },
    {
      "kind": "text",
      "text": "وَأَمَّا اجْتِهَادُ الشَّيْخِ فِي الْعِبَادَةِ وَالتَّأَلُّهِ فَأَمْرٌ غَرِيبٌ، ذَكَّرَ"
    },
    {
      "kind": "text",
      "text": "(بُنْدَارُ)"
    },
    {
      "kind": "text",
      "text": "خَادِمَهُ أَنَّهُ مَكَثَ عِشْرِينَ سَنَةً يُصَلِّي الصُّبْحَ بِوُضُوءِ الْعِشَاءِ، وَكَانَ يَأْكُلُ مِنْ غَلَّةِ قَرْيَةٍ وَقَفَهَا جَدُّهُ"
    },
    {
      "kind": "text",
      "text": "(بِلَالُ بْنُ أَبِي بُرْدَةَ)"
    },
    {
      "kind": "text",
      "text": "عَلَى نَسْلِهِ، قَالَ: وَكَانَتْ نَفَقَتُهُ فِي كُلِّ سَنَةٍ سَبْعَةَ عَشَرَ دِرْهَمًا، كُلَّ شَهْرٍ دِرْهَمٌ، وَشَيْءٌ يَسِيرٌ، قَالَ"
    },
    {
      "kind": "text",
      "text": "(ابْنُ كَثِيرٍ:)"
    },
    {
      "kind": "text",
      "text": "قَالَ الْأُسْتَاذُ"
    },
    {
      "kind": "heading",
      "text": "أَبُو إِسْحَاقَ الْإِسْفِرَايِينِيُّ:"
    },
    {
      "kind": "text",
      "text": "كُنْتُ فِي جَنْبِ"
    },
    {
      "kind": "text",
      "text": "(أَبِي الْحَسَنِ الْبَاهِلِيِّ)"
    },
    {
      "kind": "text",
      "text": "كَقَطْرَةٍ فِي الْبَحْرِ، وَسَمِعْتُهُ يَقُولُ: كُنْتُ أَنَا فِي جَنْبِ"
    },
    {
      "kind": "text",
      "text": "أَبِي الْحَسَنِ الْأَشْعَرِيِّ"
    },
    {
      "kind": "text",
      "text": "كَقَطْرَةٍ فِي الْبَحْرِ، وَقَالَ"
    },
    {
      "kind": "text",
      "text": "(الْقَاضِي الْبَاقِلَّانِيُّ:)"
    },
    {
      "kind": "text",
      "text": "أَحْسَنُ أَحْوَالِي أَنْ أَفْهَمَ كَلَامَ"
    },
    {
      "kind": "text",
      "text": "أَبِي الْحَسَنِ الْأَشْعَرِيِّ."
    }
  ],
  "has_quran": false,
  "has_hadith": false
}