  "paragraphs": [
    {
      "kind": "text",
      "text": "الْبَابُ الثَّانِي: فِي"
    },
    {
      "kind": "text",
      "text": "آدَابِ الدُّعَاءِ وَفَضْلِهِ"
    },
    {
      "kind": "text",
      "text": "وَفَضْلِ بَعْضِ الْأَدْعِيَةِ الْمَأْثُورَةِ وَفَضِيلَةِ الِاسْتِغْفَارِ وَالصَّلَاةِ عَلَى رَسُولِ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ ."
    },
    {
      "kind": "text",
      "text": "فَضِيلَةُ الدُّعَاءِ ."
    }
  ],
