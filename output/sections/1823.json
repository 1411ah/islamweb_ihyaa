  "node_id": "1823",
  "title": "قسم 1823",
  "idfrom": 1823,
  "idto": 1823,
  "paragraphs": [
    {
      "kind": "text",
      "text": "وَأَمَّا"
    },
    {
      "kind": "text",
      "text": "وَظَائِفُ التَّحَلُّلِ"
    },
    {
      "kind": "text",
      "text": "فَثَلَاثَةٌ ."
    },
    {
      "kind": "text",
      "text": "؛ أَوَّلُهَا : أَنْ يَنْوِيَ بِالتَّسْلِيمَتَيْنِ السَّلَامَ عَلَى الْقَوْمِ وَالْمَلَائِكَةِ ."
    },
    {
      "kind": "text",
      "text": "الثَّانِيَةُ : أَنْ يَثْبُتُ عَقِيبَ السَّلَامِ كَذَلِكَ فَعَلَ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ ،"
    },
    {
      "kind": "text",
      "text": "وَأَبُو بَكْرٍ"
    },
    {
      "kind": "text",
      "text": "وَعُمَرُ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُمَا ."
    }
  ],
  "has_quran": false,
  "has_hadith": false
}