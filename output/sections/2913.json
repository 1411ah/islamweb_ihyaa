    {
      "kind": "text",
      "text": "الصِّنْفُ الْخَامِسُ الْمُكَاتَبُونَ ."
    },
    {
      "kind": "text",
      "text": "فَيُدْفَعُ إِلَى السَّيِّدِ سَهْمُ الْمُكَاتَبِ وَإِنْ دَفَعَ إِلَى الْمُكَاتَبِ جَازَ"
    },
    {
      "kind": "text",
      "text": "وَلَا يَدْفَعُ السَّيِّدُ زَكَاتَهُ إِلَى مُكَاتَبِ نَفْسِهِ لِأَنَّهُ يُعِدُّ عَبْدًا لَهُ"
    },
    {
