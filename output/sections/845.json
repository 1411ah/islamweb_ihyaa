    {
      "kind": "text",
      "text": "الْبَابُ الثَّانِي ."
    },
    {
      "kind": "text",
      "text": "فِيمَا يُرَاعَى حَالَةَ الْعَقْدِ مِنْ أَحْوَالِ الْمَرْأَةِ وَشُرُوطِ الْعَقْدِ ."
    },
    {
      "kind": "text",
      "text": "الْعَقْدُ ."
    },
    {
      "kind": "heading",
      "text": "، أَمَّا الْعَقْدُ فَأَرْكَانُهُ وَشُرُوطُهُ لِيَنْعَقِدَ وَيُفِيدَ الْحِلَّ أَرْبَعَةٌ :"
    },
    {
      "kind": "text",
      "text": "الْأَوَّلُ"
    },
    {
      "kind": "text",
      "text": "إِذْنُ : الْوَلِيِّ فَإِنْ لَمْ يَكُنْ فَالسُّلْطَانُ"
    },
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    }
