    {
      "kind": "text",
      "text": "وَيُكْرَهْ أَنْ"
    },
    {
      "kind": "text",
      "text": "يَتَوَضَّأَ مِنْ إِنَاءٍ صُفْرٍ"
    },
    {
      "kind": "text",
      "text": "وَأَنْ"
    },
    {
      "kind": "text",
      "text": "يَتَوَضَّأَ بِالْمَاءِ الْمُشَمَّسِ"
    },
    {
      "kind": "text",
      "text": "وَذَلِكَ مِنْ جِهَةِ الطِّبِّ ."
    },
    {
      "kind": "text",
      "text": "وَقَدْ رُوِيَ عَنِ"
    },
    {
      "kind": "text",
      "text": "ابْنِ عُمَرَ"
    },
    {
      "kind": "text",
      "text": "وَأَبِي هُرَيْرَةَ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُمَا"
    },
    {
      "kind": "text",
      "text": "كَرَاهِيَةُ إِنَاءِ الصُّفْرِ"
    },
    {
      "kind": "text",
      "text": ". وَقَالَ بَعْضُهُمْ : أَخْرَجْتُ لِشُعْبَةَ مَاءً فِي إِنَاءٍ صُفْرٍ فَأَبَى أَنْ يَتَوَضَّأَ مِنْهُ ."
    },
    {
      "kind": "text",
      "text": "وَنُقِلَ كَرَاهِيَةُ ذَلِكَ عَنِ"
    },
    {
      "kind": "text",
      "text": "ابْنِ عُمَرَ"
    },
    {
      "kind": "text",
      "text": "وَأَبِي هُرَيْرَةَ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُمَا ."
    },
    {
      "kind": "break",
