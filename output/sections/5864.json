    {
      "kind": "text",
      "text": "وَلَمْ تَكُنْ تُرْفَعُ فِي مَجْلِسِهِ الْأَصْوَاتُ"
    },
    {
      "kind": "text",
      "text": "وَكَانَ إِذَا قَامَ مِنْ مَجْلِسِهِ قَالَ : سُبْحَانَكَ اللَّهُمَّ وَبِحَمْدِكَ ، أَشْهَدُ أَنْ لَا إِلَهَ إِلَّا أَنْتَ أَسْتَغْفِرُكَ وَأَتُوبُ إِلَيْكَ"
    },
    {
      "kind": "text",
      "text": "ثُمَّ يَقُولُ : \" عَلَمَنِيهِنَّ"
    },
    {
      "kind": "text",
      "text": "(جِبْرِيلُ)"
    },
    {
      "kind": "text",
      "text": "عَلَيْهِ السَّلَامُ ."
    },
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    }
  ],
