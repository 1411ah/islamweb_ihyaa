{
  "node_id": "16",
  "title": "قسم 16",
  "idfrom": 16,
  "idto": 16,
  "paragraphs": [
    {
      "kind": "text",
      "text": "(الْفَصْلُ الثَّالِثَ عَشَرَ: فِي"
    },
    {
      "kind": "text",
      "text": "شُيُوخِهِ فِي الْفِقْهِ وَالتَّصَوُّفِ وَالْحَدِيثِ)"
    },
    {
      "kind": "text",
      "text": "أَوَّلُ مَشَايِخِهِ فِي الْفِقْهِ كَمَا تَقَدَّمَ الْإِمَامُ"
    },
    {
      "kind": "text",
      "text": "(أَبُو حَامِدٍ أَحْمَدُ بْنُ مُحَمَّدٍ الرَّازَكَانِيُّ الطُّوسِيُّ،)"
    },
    {
      "kind": "text",
      "text": "ثُمَّ"
    },
    {
      "kind": "text",
      "text": "(أَبُو نَصْرٍ الْإِسْمَاعِيلِيُّ،)"
    },
    {
      "kind": "text",
      "text": "إِمَامُ الْحَرَمَيْنِ،"
    },
    {
      "kind": "text",
      "text": "قَرَأَ عَلَى الْأَوَّلِ"
    },
    {
      "kind": "text",
      "text": "(بِطُوسَ،)"
    },
    {
      "kind": "text",
      "text": "وَعَلَى الثَّانِي"
    },
    {
      "kind": "text",
      "text": "(بِجُرْجَانَ،)"
    },
    {
      "kind": "text",
      "text": "وَعَلَى الثَّالِثِ"
    },
    {
      "kind": "text",
      "text": "(بِنَيْسَابُورَ.)"
    },
    {
      "kind": "text",
      "text": "وَفِي التَّصَوُّفِ الْإِمَامُ الزَّاهِدُ"
    },
    {
      "kind": "text",
      "text": "(أَبُو عَلِيٍّ الْفَضْلُ بْنُ مُحَمَّدِ بْنِ عَلِيٍّ الْفَارْمَذِيُّ الطُّوسِيُّ)"
    },
    {
      "kind": "text",
      "text": "مِنْ أَعْيَانِ تَلَامِذَةِ"
    },
    {
      "kind": "text",
      "text": "(أَبِي الْقَاسِمِ الْقُشَيْرِيِّ،)"
    },
    {
      "kind": "text",
      "text": "صَاحِبِ الرِّسَالَةِ، تُوُفِّيَ"
    },
    {
      "kind": "text",
      "text": "(بِطُوسَ)"
    },
    {
      "kind": "text",
      "text": "سَنَةَ 477، وَمِنْ مَشَايِخِهِ أَيْضًا"
    },
    {
      "kind": "text",
      "text": "(يُوسُفُ السَّجَّاجُ.)"
    },
    {
      "kind": "text",
      "text": "وَفِي الْحَدِيثِ"
    },
    {
      "kind": "text",
      "text": "(أَبُو سَهْلٍ مُحَمَّدُ بْنُ أَحْمَدَ بْنِ عُبَيْدِ اللَّهِ الْحَفْصِيُّ الْمَرْوَزِيُّ،)"
    },
    {
      "kind": "text",
      "text": "(وَالْحَاكِمُ أَبُو الْفَتْحِ نَصْرُ بْنُ عَلِيِّ بْنِ أَحْمَدَ الْحَاكِمِيُّ الطُّوسِيُّ،)"
    },
    {
      "kind": "text",
      "text": "(وَأَبُو مُحَمَّدٍ عَبْدُ اللَّهِ بْنُ مُحَمَّدِ بْنِ أَحْمَدَ الْخُوَارِيُّ)"
    },
    {
      "kind": "text",
      "text": "خُوَارُ طَبَرَانَ،"
    },
    {
      "kind": "text",
      "text": "(وَمُحَمَّدُ بْنُ يَحْيَى بْنِ مُحَمَّدٍ السَّجَّاعِيُّ الزَّوْزَنِيُّ،)"
    },
    {
      "kind": "text",
      "text": "وَالْحَافِظُ"
    },
    {
      "kind": "text",
      "text": "(أَبُو الْفِتْيَانِ عُمَرُ بْنُ أَبِي الْحَسَنِ الرُّؤَاسِيُّ الدِّهِسْتَانِيِّ،)"
    },
    {
      "kind": "text",
      "text": "(وَنَصْرُ بْنُ إِبْرَاهِيمَ الْمَقْدِسِيُّ)"
    },
    {
      "kind": "text",
      "text": "عَلَى قَوْلِ"
    },
    {
      "kind": "text",
      "text": "(الذَّهَبِيِّ،)"
    },
    {
      "kind": "text",
      "text": "وَقَالَ غَيْرُهُ: لَمْ يُدْرِكْهُ ."
    },
    {
      "kind": "text",
      "text": "فَهَؤُلَاءِ شُيُوخُهُ فِي الْعُلُومِ الثَّلَاثَةِ وَلَمْ أَطَّلِعْ عَلَى أَسْمَاءِ شُيُوخِهِ الَّذِي قَرَأَ عَلَيْهِمْ فِي الْكَلَامِ، أَوِ الْجَدَلِ، فَإِنْ عَثَرْتُ عَلَى شَيْءٍ مِنْ ذَلِكَ بَعْدُ أَلْحَقْتُ بِهِ إِنْ شَاءَ اللَّهُ تَعَالَى ."
    },
    {
      "kind": "text",
      "text": "وَأَمَّا عُلُومُ الْفَلْسَفَةِ فَلَا شَيْخَ لَهُ فِيهَا، كَمَا صَرَّحَ فِي كِتَابِهِ الْمُنْقِذِ مِنَ الضَّلَالِ ."
    }
  ],
  "has_quran": false,
  "has_hadith": false
}