    {
      "kind": "text",
      "text": "وَمِنْهَا"
    },
    {
      "kind": "text",
      "text": "أَنْ يُوَقِّرَ الْمَشَايِخَ"
    },
    {
      "kind": "text",
      "text": "وَيَرْحَمُ الصِّبْيَانَ قَالَ"
    },
    {
      "kind": "text",
      "text": "جَابِرُ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُ قَالَ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ : لَيْسَ مِنَّا مَنْ لَمْ يُوَقِّرْ كَبِيرَنَا وَلَمْ يَرْحَمْ صَغِيرَنَا ."
    },
    {
      "kind": "text",
      "text": "وَقَالَ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ مِنْ إِجْلَالِ اللَّهِ إِكْرَامُ ذِي الشَّيْبَةِ الْمُسْلِمِ ."
    },
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    }
  ],
