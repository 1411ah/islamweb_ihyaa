    {
      "kind": "text",
      "text": "وَفِي الْأُولَى أَرْبَعُ فَرَائِضَ : التَّحْمِيدُ وَأَقَلُّهُ الْحَمْدُ لِلَّهِ ."
    },
    {
      "kind": "text",
      "text": "وَالثَّانِيَةُ : الصَّلَاةُ عَلَى النَّبِيِّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ ."
    },
    {
      "kind": "heading",
      "text": "وَالثَّالِثَةُ :"
    },
    {
      "kind": "text",
      "text": "الْوَصِيَّةُ بِتَقْوَى اللَّهِ سُبْحَانَهُ"
    },
    {
      "kind": "text",
      "text": "وَتَعَالَى ."
    },
    {
      "kind": "text",
      "text": "وَالرَّابِعَةُ : قِرَاءَةُ آيَةٍ مِنَ الْقُرْآنِ ."
    },
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    }
  ],
