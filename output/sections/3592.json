    },
    {
      "kind": "text",
      "text": "السَّادِسُ : التَّضَرُّعُ وَالْخُشُوعُ وَالرَّغْبَةُ وَالرَّهْبَةُ قَالَ اللَّهُ تَعَالَى"
    },
    {
      "kind": "text",
      "text": "إِنَّهُمْ كَانُوا يُسَارِعُونَ فِي الْخَيْرَاتِ وَيَدْعُونَنَا رَغَبًا وَرَهَبًا"
    },
    {
      "kind": "heading",
      "text": "وَقَالَ عَزَّ وَجَلَّ :"
    },
    {
      "kind": "text",
      "text": "ادْعُوا رَبَّكُمْ تَضَرُّعًا وَخُفْيَةً"
    },
    {
      "kind": "heading",
      "text": "وَقَالَ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ :"
    },
    {
      "kind": "hadith",
      "text": "(( إِذَا أَحَبَّ اللَّهُ عَبْدًا ابْتَلَاهُ حَتَّى يَسْمَعَ تَضَرُّعَهُ. ))"
    },
    {
      "kind": "break",
      "text": ""
    }
  ],
