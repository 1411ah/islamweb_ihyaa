{
  "node_id": "6434",
  "title": "قسم 6434",
  "idfrom": 6434,
  "idto": 6434,
  "paragraphs": [
    {
      "kind": "text",
      "text": "الْآفَةُ السَّادِسَةَ عَشْرَةَ : النَّمِيمَةُ"
    },
    {
      "kind": "heading",
      "text": "قَالَ اللَّهُ تَعَالَى :"
    },
    {
      "kind": "text",
      "text": "هَمَّازٍ مَشَّاءٍ بِنَمِيمٍ"
    },
    {
      "kind": "heading",
      "text": "، ثُمَّ قَالَ :"
    },
    {
      "kind": "text",
      "text": "عُتُلٍّ بَعْدَ ذَلِكَ زَنِيمٍ"
    },
    {
      "kind": "text",
      "text": "قَالَ"
    },
    {
      "kind": "text",
      "text": "عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ"
    },
    {
      "kind": "text",
      "text": "الزَّنِيمُ وَلَدُ الزِّنَا ، الَّذِي لَا يَكْتُمُ الْحَدِيثَ ، وَأَشَارَ بِهِ إِلَى أَنَّ كُلَّ مَنْ لَمْ يَكْتُمِ الْحَدِيثَ وَمَشَى بِالنَّمِيمَةِ دَلَّ عَلَى أَنَّهُ وَلَدُ زِنًا ؛ اسْتِنْبَاطًا مِنْ قَوْلِهِ عَزَّ وَجَلَّ :"
    },
    {
      "kind": "heading",
      "text": "، وَالزَّنِيمُ هُوَ الدَّعِيُّ وَقَالَ تَعَالَى :"
    },
    {
      "kind": "text",
      "text": "وَيْلٌ لِكُلِّ هُمَزَةٍ لُمَزَةٍ"
    },
    {
      "kind": "text",
      "text": "، قِيلَ : الْهُمْزَةُ : النَّمَّامُ ."
    },
    {
      "kind": "heading",
      "text": "وَقَالَ تَعَالَى :"
    },
    {
      "kind": "text",
      "text": "حَمَّالَةَ الْحَطَبِ"
    },
    {
      "kind": "heading",
      "text": "قِيلَ : إِنَّهَا كَانَتْ نَمَّامَةً حَمَّالَةً لِلْحَدِيثِ وَقَالَ تَعَالَى :"
    },
    {
      "kind": "text",
      "text": "فَخَانَتَاهُمَا فَلَمْ يُغْنِيَا عَنْهُمَا مِنَ اللَّهِ شَيْئًا"
    },
    {
      "kind": "text",
      "text": "، قِيلَ : كَانَتِ امْرَأَةُ"
    },
    {
      "kind": "text",
      "text": "(لُوطٍ)"
    },
    {
      "kind": "text",
      "text": "تُخْبِرُ بِالضِّيفَانِ ، وَامْرَأَةُ"
    },
    {
      "kind": "text",
      "text": "(نُوحٍ)"
    },
    {
      "kind": "heading",
      "text": "تُخْبِرُ أَنَّهُ مَجْنُونٌ وَقَدْ قَالَ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ :"
    },
    {
      "kind": "hadith",
      "text": "(( لَا يَدْخُلُ الْجَنَّةَ نَمَّامٌ ))"
    },
    {
      "kind": "heading",
      "text": "وَفِي حَدِيثٍ آخَرَ :"
    },
    {
      "kind": "hadith",
      "text": "(( لَا يَدْخُلُ الْجَنَّةَ قَتَّاتٌ ))"
    },
    {
      "kind": "text",
      "text": "وَالْقَتَّاتُ هُوَ النَّمَّامُ"
    }
  ],
  "has_quran": false,
  "has_hadith": true
}