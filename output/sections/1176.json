{
  "node_id": "1176",
  "title": "قسم 1176",
  "idfrom": 1176,
  "idto": 1176,
  "paragraphs": [
    {
      "kind": "text",
      "text": "وَأَنْ يَتَكَلَّمَ فِي أَثْنَاءِ الْوُضُوءِ وَأَنْ"
    },
    {
      "kind": "text",
      "text": "يَلْطُمَ وَجْهَهُ بِالْمَاءِ لَطْمًا"
    },
    {
      "kind": "text",
      "text": "وَكَرِهَ قَوْمٌ التَّنْشِيفَ وَقَالُوا الْوُضُوءُ يُوزَنُ قَالَهُ"
    },
    {
      "kind": "text",
      "text": "سَعِيدُ بْنُ الْمُسَيِّبِ"
    },
    {
      "kind": "text",
      "text": "(وَالزُّهْرِيُّ)"
    },
    {
      "kind": "text",
      "text": "لَكِنْ رَوَى"
    },
    {
      "kind": "text",
      "text": "مُعَاذُ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُ"
    },
    {
      "kind": "hadith",
      "text": "(( أَنَّهُ عَلَيْهِ السَّلَامُ مَسَحَ وَجْهَهُ بِطَرَفِ ثَوْبِهِ ))"
    },
    {
      "kind": "text",
      "text": "وَرَوَتْ"
    },
    {
      "kind": "text",
      "text": "عَائِشَةُ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهَا"
    },
    {
      "kind": "hadith",
      "text": "(( أَنَّهُ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ كَانَتْ لَهُ مِنْشَفَةٌ ))"
    },
    {
      "kind": "text",
      "text": "وَلَكِنْ طَعَنَ فِي هَذِهِ الرِّوَايَةِ عَنْ"
    },
    {
      "kind": "text",
      "text": "عَائِشَةَ"
    }
  ],
  "has_quran": false,
  "has_hadith": true
}