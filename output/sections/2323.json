  "paragraphs": [
    {
      "kind": "text",
      "text": "السَّادِسُ فِي"
    },
    {
      "kind": "text",
      "text": "كَيْفِيَّةِ الصَّلَاةِ"
    },
    {
      "kind": "text",
      "text": "؛ فَلْيَخْرُجِ النَّاسُ مُكَبِّرِينَ فِي الطَّرِيقِ ."
    },
    {
      "kind": "text",
      "text": "وَإِذَا بَلَغَ الْإِمَامُ الْمُصَلَّى لَمْ يَجْلِسْ وَلَمْ يَتَنَفَّلْ وَيَقْطَعُ النَّاسُ التَّنَفُّلَ ."
    }
  ],
  "has_quran": false,
  "has_hadith": false
}