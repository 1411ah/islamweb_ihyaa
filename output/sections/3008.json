    {
      "kind": "text",
      "text": "وَمَنْ"
    },
    {
      "kind": "text",
      "text": "نَوَى لَيْلًا ثُمَّ أَكَلَ لَمْ تَفْسُدْ نِيَّتُهُ وَلَوْ"
    },
    {
      "kind": "text",
      "text": "نَوَتِ امْرَأَةٌ فِي الْحَيْضِ ثُمَّ طَهُرَتْ قَبْلَ الْفَجْرِ صَحَّ صَوْمُهَا ."
    },
    {
      "kind": "text",
      "text": "الثَّالِثُ : الْإِمْسَاكُ عَنْ إِيصَالِ شَيْءٍ إِلَى الْجَوْفِ عَمْدًا مَعَ ذِكْرِ الصَّوْمِ"
    },
    {
      "kind": "text",
      "text": "فَيَفْسُدُ صَوْمُهُ بِالْأَكْلِ وَالشُّرْبِ وَالسُّعُوطِ"
    },
    {
      "kind": "break",
      "text": "[SECTION_BREAK]"
    }
  ],
