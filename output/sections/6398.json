  "paragraphs": [
    {
      "kind": "text",
      "text": "وَقَالَ"
    },
    {
      "kind": "text",
      "text": "عُمَرُ"
    },
    {
      "kind": "text",
      "text": "رَضِيَ اللَّهُ عَنْهُ : عَلَيْكُمْ بِذِكْرِ اللَّهِ تَعَالَى ؛ فَإِنَّهُ شِفَاءٌ ، وَإِيَّاكُمْ"
    },
    {
      "kind": "text",
      "text": "وَذِكْرَ النَّاسِ"
    },
    {
      "kind": "text",
      "text": "؛ فَإِنَّهُ دَاءٌ نَسْأَلُ اللَّهَ حُسْنَ التَّوْفِيقِ لِطَاعَتِهِ ."
    }
  ],
